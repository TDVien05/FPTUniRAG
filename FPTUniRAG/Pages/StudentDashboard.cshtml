@page "/StudentDashboard"
@model FPTUniRAG.Pages.StudentDashboardModel
@using System.Text.Json
@{
    Layout = null;
    ViewData["Title"] = "Student UniRAG Dashboard - FPT UniRAG";
    var initialSubjectsJson = JsonSerializer.Serialize(Model.Dashboard.Subjects, new JsonSerializerOptions(JsonSerializerDefaults.Web));
    var initialSessionsJson = JsonSerializer.Serialize(Model.Dashboard.RecentSessions, new JsonSerializerOptions(JsonSerializerDefaults.Web));
    var studentInitial = string.IsNullOrWhiteSpace(Model.Dashboard.StudentName)
        ? "S"
        : Model.Dashboard.StudentName.Trim()[0].ToString().ToUpperInvariant();
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Manrope:wght@600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked@15.0.12/marked.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.6/dist/purify.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        try {
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            primary: "#005bbf",
                            secondary: "#505f76",
                            background: "#f9f9ff",
                            surface: "#f9f9ff",
                            "surface-container-lowest": "#ffffff",
                            "surface-container-low": "#f0f3ff",
                            "surface-container": "#e7eeff",
                            "surface-container-high": "#dee8ff",
                            "surface-container-highest": "#d8e3fb",
                            "on-surface": "#111c2d",
                            "on-surface-variant": "#414754",
                            "outline-variant": "#c1c6d6",
                            outline: "#727785",
                            error: "#ba1a1a"
                        },
                        spacing: {
                            gutter: "24px",
                            base: "8px"
                        },
                        fontFamily: {
                            display: ["Manrope"],
                            body: ["Inter"]
                        }
                    }
                }
            };
        } catch (_e) { }
    </script>
    <style>
        .assistant-markdown > :first-child { margin-top: 0; }
        .assistant-markdown > :last-child { margin-bottom: 0; }
        .assistant-markdown h1, .assistant-markdown h2, .assistant-markdown h3, .assistant-markdown h4 { color: #111c2d; font-weight: 700; line-height: 1.3; margin: 1.25rem 0 0.5rem; }
        .assistant-markdown h1 { font-size: 1.5rem; }
        .assistant-markdown h2 { font-size: 1.25rem; }
        .assistant-markdown h3 { font-size: 1.125rem; }
        .assistant-markdown p, .assistant-markdown ul, .assistant-markdown ol, .assistant-markdown blockquote, .assistant-markdown pre, .assistant-markdown table { margin: 0.75rem 0; }
        .assistant-markdown ul, .assistant-markdown ol { padding-left: 1.5rem; }
        .assistant-markdown ul { list-style: disc; }
        .assistant-markdown ol { list-style: decimal; }
        .assistant-markdown li + li { margin-top: 0.25rem; }
        .assistant-markdown a { color: #005bbf; font-weight: 600; text-decoration: underline; }
        .assistant-markdown blockquote { border-left: 3px solid #005bbf; color: #505f76; padding-left: 1rem; }
        .assistant-markdown code { border-radius: 0.25rem; background: #d8e3fb; padding: 0.125rem 0.25rem; font-size: 0.9em; }
        .assistant-markdown pre { overflow-x: auto; border-radius: 0.75rem; background: #111c2d; color: #f9f9ff; padding: 1rem; }
        .assistant-markdown pre code { background: transparent; padding: 0; color: inherit; }
        .assistant-markdown table { display: block; max-width: 100%; overflow-x: auto; border-collapse: collapse; }
        .assistant-markdown th, .assistant-markdown td { border: 1px solid #c1c6d6; padding: 0.5rem 0.75rem; text-align: left; white-space: nowrap; }
        .assistant-markdown th { background: #dee8ff; color: #111c2d; }
        .assistant-citation-marker { color: #005bbf; font-size: 0.75em; font-weight: 700; vertical-align: super; }
    </style>
</head>
<body class="min-h-screen overflow-hidden bg-background font-body text-on-surface">
    <header class="fixed top-0 left-0 right-0 z-50 h-16 border-b border-outline-variant bg-surface/90 backdrop-blur">
        <div class="flex h-full items-center justify-between px-4 lg:px-6">
            <div class="flex items-center gap-3 lg:gap-6">
                <button id="subjectsToggle" type="button" class="rounded-full p-2 text-on-surface-variant transition-colors hover:bg-surface-container-high md:hidden" aria-label="Open subjects panel" aria-expanded="false" aria-controls="subjectsAside">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <span class="font-display text-2xl font-bold text-primary">FPT UniRAG</span>
                <span class="hidden rounded-full bg-surface-container px-3 py-1 text-sm font-medium text-secondary md:inline-flex">Student Chat</span>
            </div>
            <div class="flex items-center gap-4">
                <div class="hidden items-center gap-2 rounded-full border border-green-100 bg-green-50 px-3 py-1.5 text-sm text-green-700 md:flex">
                    <span class="relative flex h-2 w-2">
                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
                    </span>
                    <span>Connected</span>
                </div>
                <a class="hidden rounded-full border border-outline-variant bg-surface-container-lowest px-4 py-2 text-sm font-medium text-primary transition hover:bg-surface-container-high md:inline-flex" href="/StudentPlans">
                    Upgrade plan
                </a>
                <button id="sourcesToggle" type="button" class="rounded-full p-2 text-on-surface-variant transition-colors hover:bg-surface-container-high lg:hidden" aria-label="Open sources panel" aria-expanded="false" aria-controls="sourcesAside">
                    <span class="material-symbols-outlined">menu_book</span>
                </button>
                <a class="rounded-full p-2 transition-colors hover:bg-surface-container-high" href="/ChangePassword" aria-label="Change password">
                    <span class="material-symbols-outlined text-on-surface-variant">settings</span>
                </a>
                <div class="flex h-9 w-9 items-center justify-center rounded-full border border-outline-variant bg-surface-container text-sm font-semibold text-primary">
                    @studentInitial
                </div>
            </div>
        </div>
    </header>

    <div class="flex h-screen flex-col pt-16 md:flex-row">
        <aside id="subjectsAside" class="fixed inset-y-0 left-0 z-40 flex w-80 max-w-[85vw] -translate-x-full flex-col overflow-y-auto border-r border-outline-variant bg-surface-container-low px-4 pb-4 pt-20 shadow-2xl transition-transform duration-200 ease-out md:static md:z-auto md:h-full md:w-80 md:translate-x-0 md:border-b-0 md:pt-4 md:shadow-none">
            <div class="mb-4 flex items-start justify-between gap-3 px-2">
                <div class="flex items-start gap-3">
                    <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-primary text-white">
                        <span class="material-symbols-outlined">school</span>
                    </div>
                    <div>
                        <h2 class="font-display text-xl font-semibold text-primary">Subjects</h2>
                        <p class="text-sm text-secondary">Choose a subject before chatting</p>
                    </div>
                </div>
                <button id="subjectsClose" type="button" class="rounded-full p-2 text-on-surface-variant transition-colors hover:bg-surface-container-high md:hidden" aria-label="Close subjects panel">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <label class="relative mb-4 block">
                <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant material-symbols-outlined">search</span>
                <input id="subjectSearchInput" class="w-full rounded-2xl border border-outline-variant bg-surface-container-lowest py-3 pl-11 pr-4 text-sm text-on-surface outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/10" placeholder="Search subjects by code or name" aria-label="Search subjects by code or name" type="search" />
            </label>

            <div id="subjectList" class="flex max-h-64 flex-col gap-2 overflow-y-auto pr-1 md:min-h-0 md:max-h-none md:flex-1"></div>

            <div class="mt-4 border-t border-outline-variant pt-4">
                <div class="mb-3 flex items-center justify-between px-2">
                    <div>
                        <h3 class="font-display text-lg font-semibold text-primary">Recent chats</h3>
                        <p class="text-xs text-secondary">Chat history for the selected subject</p>
                    </div>
                    <button
                        id="newChatButton"
                        class="inline-flex items-center gap-1 rounded-xl border border-primary/20 bg-primary/10 px-3 py-2 text-xs font-semibold text-primary transition hover:bg-primary/15 disabled:cursor-not-allowed disabled:border-outline-variant disabled:bg-surface-container disabled:text-secondary/60"
                        type="button"
                        disabled>
                        <span class="material-symbols-outlined text-base" aria-hidden="true">add_comment</span>
                        New Chat
                    </button>
                </div>
                <div id="sessionList" class="flex max-h-56 flex-col gap-2 overflow-y-auto pr-1"></div>
            </div>

            <div class="mt-4 border-t border-outline-variant pt-4">
                <div class="mt-3 flex flex-col gap-1">
                    <a class="rounded-xl px-4 py-3 text-sm text-secondary transition hover:bg-surface-container-high" href="/StudentPlans">Upgrade Plan</a>
                    <a class="rounded-xl px-4 py-3 text-sm text-secondary transition hover:bg-surface-container-high" href="/ChangePassword">Change Password</a>
                    <a class="rounded-xl px-4 py-3 text-sm text-secondary transition hover:bg-surface-container-high" href="/Logout">Logout</a>
                </div>
            </div>
        </aside>

        <main class="relative flex min-h-0 min-w-0 flex-1 flex-col bg-background">
            <div class="flex-1 overflow-y-auto px-4 py-gutter lg:px-6">
                <div class="flex w-full flex-col gap-gutter pb-[240px]">
                    <section id="chatHero" class="rounded-3xl border border-outline-variant bg-surface-container-lowest p-8 shadow-sm">
                        <div class="flex flex-col items-center gap-4 text-center">
                            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 text-primary">
                                <span class="material-symbols-outlined text-4xl">auto_awesome</span>
                            </div>
                            <div>
                                <h1 id="heroTitle" class="font-display text-3xl font-semibold text-on-surface">Choose a subject to start chatting</h1>
                                <p id="heroDescription" class="mx-auto mt-3 max-w-2xl text-base leading-7 text-secondary">Search for a subject on the left, select it, then ask FPT UniRAG about lecture notes, textbook chapters, or concepts from that subject.</p>
                            </div>
                        </div>
                    </section>

                    <section id="chatMessages" class="flex flex-col gap-6" aria-live="polite" aria-atomic="false"></section>
                    <div id="chatBottomSpacer" class="h-8 shrink-0"></div>
                </div>
            </div>

            <div class="pointer-events-none absolute bottom-0 left-0 right-0 bg-gradient-to-t from-background via-background to-transparent px-4 py-gutter lg:px-6">
                <div class="pointer-events-auto w-full">
                    <form id="chatForm" class="rounded-3xl border border-outline-variant bg-surface-container-lowest p-1 shadow-lg transition-shadow focus-within:shadow-xl">
                        <textarea id="messageInput" class="max-h-56 min-h-[76px] w-full resize-none rounded-[20px] border-none bg-transparent px-5 py-4 text-base text-on-surface focus:ring-0" placeholder="Choose a subject, then ask a question..." rows="1"></textarea>
                        <div class="flex items-center justify-between px-4 pb-4">
                            <div>
                                <p id="composerHint" class="text-sm text-secondary">No subject selected.</p>
                                <p id="composerError" class="mt-1 hidden text-sm font-medium text-error"></p>
                                <p class="mt-1 hidden text-xs text-secondary/70 sm:block">
                                    Press <kbd class="rounded border border-outline-variant bg-surface-container px-1 py-0.5 font-sans">Enter</kbd> to send · <kbd class="rounded border border-outline-variant bg-surface-container px-1 py-0.5 font-sans">Shift+Enter</kbd> for a new line
                                </p>
                            </div>
                            <button id="sendButton" class="flex h-11 w-11 items-center justify-center rounded-2xl bg-primary text-white shadow-md transition hover:bg-primary/90 disabled:cursor-not-allowed disabled:bg-primary/40" type="submit" aria-label="Send message">
                                <span class="material-symbols-outlined">send</span>
                            </button>
                        </div>
                    </form>
                    <p class="mt-3 text-center text-xs text-secondary">FPT UniRAG answers from uploaded subject materials. Verify important academic information.</p>
                </div>
            </div>
        </main>

        <aside id="sourcesAside" class="fixed inset-y-0 right-0 z-40 flex w-80 max-w-[85vw] translate-x-full flex-col overflow-y-auto border-l border-outline-variant bg-surface-container-low p-4 pt-20 shadow-2xl transition-transform duration-200 ease-out lg:static lg:z-auto lg:w-80 lg:translate-x-0 lg:pt-4 lg:shadow-none">
            <div class="mb-4 flex items-center justify-between gap-2 px-2">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">menu_book</span>
                    <h3 class="font-display text-xl font-semibold">Sources</h3>
                </div>
                <button id="sourcesClose" type="button" class="rounded-full p-2 text-on-surface-variant transition-colors hover:bg-surface-container-high lg:hidden" aria-label="Close sources panel">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div id="sourcesPanel" class="flex min-h-0 flex-1 flex-col gap-3 overflow-y-auto">
                <div class="rounded-2xl border border-dashed border-outline-variant bg-surface-container-lowest p-5 text-sm leading-6 text-secondary">
                    Ask a question after selecting a subject to see the referenced documents here.
                </div>
            </div>
        </aside>
    </div>

    <div id="subjectsBackdrop" class="fixed inset-0 z-30 hidden bg-slate-950/40 md:hidden" aria-hidden="true"></div>
    <div id="sourcesBackdrop" class="fixed inset-0 z-30 hidden bg-slate-950/40 lg:hidden" aria-hidden="true"></div>

    <div id="citationModal" class="fixed inset-0 z-[70] hidden items-center justify-center bg-slate-950/45 p-4">
        <div class="w-full max-w-3xl rounded-[28px] border border-outline-variant bg-surface-container-lowest shadow-2xl">
            <div class="flex items-start justify-between gap-4 border-b border-outline-variant px-6 py-5">
                <div class="min-w-0">
                    <p id="citationModalEyebrow" class="text-xs font-semibold uppercase tracking-[0.16em] text-primary">Citation</p>
                    <h3 id="citationModalTitle" class="mt-2 truncate font-display text-xl font-semibold text-on-surface">Chunk detail</h3>
                    <p id="citationModalMeta" class="mt-1 text-sm text-secondary"></p>
                </div>
                <button id="citationModalClose" type="button" class="rounded-full p-2 text-on-surface-variant transition hover:bg-surface-container-high" aria-label="Close citation popup">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="max-h-[70vh] overflow-y-auto px-6 py-5">
                <div id="citationModalBody" class="whitespace-pre-wrap text-sm leading-7 text-on-surface-variant"></div>
            </div>
        </div>
    </div>

    <script>
        const initialSubjects = @Html.Raw(initialSubjectsJson);
        const initialSessions = @Html.Raw(initialSessionsJson);
        const state = {
            subjects: initialSubjects,
            sessions: initialSessions,
            selectedSubjectId: null,
            selectedSubjectName: "",
            selectedSubjectCode: "",
            sessionId: null,
            messages: [],
            latestSources: [],
            sending: false,
            loadingSessions: false,
            loadingSessionDetail: false,
            loadingCitation: false,
            activeAssistantMessage: null,
            activeUserMessage: null,
            connectionReady: false,
            citationModalOpen: false
        };

        const elements = {
            subjectList: document.getElementById("subjectList"),
            sessionList: document.getElementById("sessionList"),
            subjectSearchInput: document.getElementById("subjectSearchInput"),
            chatMessages: document.getElementById("chatMessages"),
            chatBottomSpacer: document.getElementById("chatBottomSpacer"),
            sourcesPanel: document.getElementById("sourcesPanel"),
            citationModal: document.getElementById("citationModal"),
            citationModalClose: document.getElementById("citationModalClose"),
            citationModalEyebrow: document.getElementById("citationModalEyebrow"),
            citationModalTitle: document.getElementById("citationModalTitle"),
            citationModalMeta: document.getElementById("citationModalMeta"),
            citationModalBody: document.getElementById("citationModalBody"),
            heroTitle: document.getElementById("heroTitle"),
            heroDescription: document.getElementById("heroDescription"),
            messageInput: document.getElementById("messageInput"),
            chatForm: document.getElementById("chatForm"),
            composerHint: document.getElementById("composerHint"),
            composerError: document.getElementById("composerError"),
            sendButton: document.getElementById("sendButton"),
            newChatButton: document.getElementById("newChatButton"),
            subjectsAside: document.getElementById("subjectsAside"),
            subjectsToggle: document.getElementById("subjectsToggle"),
            subjectsClose: document.getElementById("subjectsClose"),
            subjectsBackdrop: document.getElementById("subjectsBackdrop"),
            sourcesAside: document.getElementById("sourcesAside"),
            sourcesToggle: document.getElementById("sourcesToggle"),
            sourcesClose: document.getElementById("sourcesClose"),
            sourcesBackdrop: document.getElementById("sourcesBackdrop")
        };

        function toggleSubjectsDrawer(forceOpen) {
            const isOpen = elements.subjectsAside.classList.contains("translate-x-0");
            const open = forceOpen ?? !isOpen;
            elements.subjectsAside.classList.toggle("translate-x-0", open);
            elements.subjectsAside.classList.toggle("-translate-x-full", !open);
            elements.subjectsBackdrop.classList.toggle("hidden", !open);
            elements.subjectsToggle.setAttribute("aria-expanded", String(open));
            if (open) {
                elements.subjectsClose.focus();
            } else if (document.activeElement && elements.subjectsAside.contains(document.activeElement)) {
                elements.subjectsToggle.focus();
            }
        }

        function toggleSourcesDrawer(forceOpen) {
            const isOpen = elements.sourcesAside.classList.contains("translate-x-0");
            const open = forceOpen ?? !isOpen;
            elements.sourcesAside.classList.toggle("translate-x-0", open);
            elements.sourcesAside.classList.toggle("translate-x-full", !open);
            elements.sourcesBackdrop.classList.toggle("hidden", !open);
            elements.sourcesToggle.setAttribute("aria-expanded", String(open));
            if (open) {
                elements.sourcesClose.focus();
            } else if (document.activeElement && elements.sourcesAside.contains(document.activeElement)) {
                elements.sourcesToggle.focus();
            }
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#39;");
        }

        function renderAssistantMarkdown(value, citations = []) {
            const markdown = String(value ?? "");
            if (!markdown) {
                return "";
            }

            if (!window.marked || !window.DOMPurify) {
                return escapeHtml(markdown).replaceAll("\n", "<br />");
            }

            try {
                const citationNumbers = new Set(citations.map((citation, index) => citation.citationNumber || index + 1));
                const markdownWithCitationButtons = markdown.replace(/\[(\d+)\]/g, (match, rawNumber) => {
                    const citationNumber = Number.parseInt(rawNumber, 10);
                    return citationNumbers.has(citationNumber)
                        ? `<button type="button" class="assistant-citation-marker" data-citation-number="${citationNumber}">[${citationNumber}]</button>`
                        : match;
                });
                const renderedHtml = window.marked.parse(markdownWithCitationButtons, {
                    breaks: true,
                    gfm: true
                });

                return window.DOMPurify.sanitize(renderedHtml, {
                    USE_PROFILES: { html: true },
                    FORBID_TAGS: ["style"],
                    FORBID_ATTR: ["style"],
                    ADD_TAGS: ["button"],
                    ADD_ATTR: ["type", "class", "data-citation-number"]
                });
            } catch (_error) {
                return escapeHtml(markdown).replaceAll("\n", "<br />");
            }
        }

        function isAssistantMessage(message) {
            return String(message?.senderRole || "").toLowerCase() === "assistant";
        }

        function escapeAttribute(value) {
            return escapeHtml(value).replaceAll("`", "&#96;");
        }

        function setComposerError(message) {
            if (!message) {
                elements.composerError.textContent = "";
                elements.composerError.classList.add("hidden");
                return;
            }

            elements.composerError.textContent = message;
            elements.composerError.classList.remove("hidden");
        }

        function scrollChatToBottom() {
            requestAnimationFrame(() => {
                elements.chatBottomSpacer?.scrollIntoView({ behavior: "smooth", block: "end" });
            });
        }

        function openCitationModalShell() {
            state.citationModalOpen = true;
            elements.citationModal.classList.remove("hidden");
            elements.citationModal.classList.add("flex");
        }

        function closeCitationModal() {
            state.citationModalOpen = false;
            state.loadingCitation = false;
            elements.citationModal.classList.add("hidden");
            elements.citationModal.classList.remove("flex");
        }

        function renderCitationModalLoading(citation) {
            elements.citationModalEyebrow.textContent = citation.subjectCode || "Citation";
            elements.citationModalTitle.textContent = citation.documentTitle || "Chunk detail";
            elements.citationModalMeta.textContent = `${citation.chapterTitle || ""} · Chunk ${citation.chunkIndex}`;
            elements.citationModalBody.textContent = "Loading cited chunk...";
            openCitationModalShell();
        }

        function renderCitationModal(citationDetail) {
            elements.citationModalEyebrow.textContent = citationDetail.subjectCode || "Citation";
            elements.citationModalTitle.textContent = citationDetail.documentTitle || "Chunk detail";
            elements.citationModalMeta.textContent = `${citationDetail.chapterTitle || ""} · Chunk ${citationDetail.chunkIndex}`;
            elements.citationModalBody.textContent = citationDetail.chunkContent || "";
            openCitationModalShell();
        }

        function appendAssistantDelta(delta) {
            const assistantPlaceholder = state.activeAssistantMessage;
            if (!assistantPlaceholder || !delta) {
                return;
            }

            assistantPlaceholder.messageContent += delta;
            assistantPlaceholder.isStreaming = true;
            updateStreamingMessageDom(assistantPlaceholder);
            scrollChatToBottom();
        }

        function formatSessionTime(value) {
            if (!value) {
                return "";
            }

            const parsed = new Date(value);
            if (Number.isNaN(parsed.getTime())) {
                return "";
            }

            return parsed.toLocaleString([], {
                month: "short",
                day: "numeric",
                hour: "2-digit",
                minute: "2-digit"
            });
        }

        function updateLatestSourcesFromMessages(messages) {
            const assistantMessages = messages.filter(message =>
                isAssistantMessage(message)
                && Array.isArray(message.citations)
                && message.citations.length);
            const latestAssistantMessage = assistantMessages.at(-1);
            state.latestSources = (latestAssistantMessage?.citations || [])
                .map(citation => ({ ...citation, messageId: latestAssistantMessage.messageId }));
        }

        function upsertSessionSummary(sessionId, previewText, activityAt) {
            if (!sessionId || !state.selectedSubjectId) {
                return;
            }

            const nextSummary = {
                sessionId,
                subjectId: state.selectedSubjectId,
                subjectCode: state.selectedSubjectCode,
                subjectName: state.selectedSubjectName,
                startedAt: activityAt || new Date().toISOString(),
                lastMessageAt: activityAt || new Date().toISOString(),
                previewText: (previewText || "Untitled chat").trim()
            };

            const existingIndex = state.sessions.findIndex(session => session.sessionId === sessionId);
            if (existingIndex >= 0) {
                const existing = state.sessions[existingIndex];
                nextSummary.startedAt = existing.startedAt || nextSummary.startedAt;
                state.sessions.splice(existingIndex, 1);
            }

            state.sessions.unshift(nextSummary);
            renderSessions();
        }

        function renderSubjects() {
            if (!state.subjects.length) {
                elements.subjectList.innerHTML = `
                    <div class="rounded-2xl border border-dashed border-outline-variant bg-surface-container-lowest p-4 text-sm text-secondary">
                        No subjects match your search.
                    </div>`;
                return;
            }

            elements.subjectList.innerHTML = state.subjects.map(subject => {
                const selected = state.selectedSubjectId === subject.subjectId;
                const readyClass = subject.hasUsableContent
                    ? "bg-green-50 text-green-700 border-green-100"
                    : "bg-amber-50 text-amber-700 border-amber-100";

                return `
                    <button
                        type="button"
                        data-subject-id="${subject.subjectId}"
                        data-subject-code="${escapeHtml(subject.subjectCode)}"
                        data-subject-name="${escapeHtml(subject.subjectName)}"
                        aria-pressed="${selected}"
                        class="subject-option w-full rounded-2xl border p-4 text-left transition ${selected ? "border-primary bg-surface-container-high shadow-sm" : "border-outline-variant bg-surface-container-lowest hover:border-primary/40 hover:bg-surface-container-high"}">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="text-sm font-semibold text-primary">${escapeHtml(subject.subjectCode)}</p>
                                <h4 class="mt-1 text-base font-semibold text-on-surface">${escapeHtml(subject.subjectName)}</h4>
                            </div>
                            <span class="rounded-full border px-2 py-1 text-[11px] font-semibold ${readyClass}">
                                ${subject.hasUsableContent ? "Ready" : "No docs"}
                            </span>
                        </div>
                        <p class="mt-2 text-sm leading-6 text-secondary">${escapeHtml(subject.description || "No description provided.")}</p>
                    </button>`;
            }).join("");

            document.querySelectorAll(".subject-option").forEach(button => {
                button.addEventListener("click", async () => {
                    const subjectId = button.getAttribute("data-subject-id");
                    const subjectCode = button.getAttribute("data-subject-code") || "";
                    const subjectName = button.getAttribute("data-subject-name") || "";
                    const subjectChanged = state.selectedSubjectId !== subjectId;

                    if (subjectChanged) {
                        state.messages = [];
                        state.latestSources = [];
                        state.sessionId = null;
                        state.sessions = [];
                    }

                    state.selectedSubjectId = subjectId;
                    state.selectedSubjectCode = subjectCode;
                    state.selectedSubjectName = subjectName;
                    setComposerError("");
                    renderSubjects();
                    renderSessions();
                    renderChat();
                    renderSources();

                    if (subjectChanged) {
                        await refreshSessions(subjectId);
                    }

                    if (window.matchMedia("(max-width: 767px)").matches) {
                        toggleSubjectsDrawer(false);
                    }
                });
            });
        }

        function renderSessions() {
            if (!state.selectedSubjectId) {
                elements.sessionList.innerHTML = `
                    <div class="rounded-2xl border border-dashed border-outline-variant bg-surface-container-lowest p-4 text-sm text-secondary">
                        Choose a subject to view its saved chats.
                    </div>`;
                return;
            }

            if (state.loadingSessions) {
                elements.sessionList.innerHTML = `
                    <div class="rounded-2xl border border-outline-variant bg-surface-container-lowest p-4 text-sm text-secondary">
                        Loading chat history...
                    </div>`;
                return;
            }

            if (!state.sessions.length) {
                elements.sessionList.innerHTML = `
                    <div class="rounded-2xl border border-dashed border-outline-variant bg-surface-container-lowest p-4 text-sm text-secondary">
                        No saved chats for this subject yet.
                    </div>`;
                return;
            }

            elements.sessionList.innerHTML = state.sessions.map(session => {
                const selected = state.sessionId === session.sessionId;
                return `
                    <button
                        type="button"
                        data-session-id="${session.sessionId}"
                        aria-pressed="${selected}"
                        class="session-option w-full rounded-2xl border p-3 text-left transition ${selected ? "border-primary bg-surface-container-high shadow-sm" : "border-outline-variant bg-surface-container-lowest hover:border-primary/40 hover:bg-surface-container-high"}">
                        <div class="flex items-start justify-between gap-3">
                            <p class="line-clamp-2 text-sm font-semibold text-on-surface">${escapeHtml(session.previewText || "Untitled chat")}</p>
                            <span class="shrink-0 text-[11px] text-secondary">${escapeHtml(formatSessionTime(session.lastMessageAt || session.startedAt))}</span>
                        </div>
                    </button>`;
            }).join("");

            document.querySelectorAll(".session-option").forEach(button => {
                button.addEventListener("click", async () => {
                    const sessionId = button.getAttribute("data-session-id");
                    if (!sessionId) {
                        return;
                    }

                    await openSession(sessionId);

                    if (window.matchMedia("(max-width: 767px)").matches) {
                        toggleSubjectsDrawer(false);
                    }
                });
            });
        }

        function updateNewChatButtonState() {
            elements.newChatButton.disabled = !state.selectedSubjectId
                || state.sending
                || state.loadingSessionDetail;
        }

        function startNewChat() {
            if (!state.selectedSubjectId || state.sending || state.loadingSessionDetail) {
                return;
            }

            state.sessionId = null;
            state.messages = [];
            state.latestSources = [];
            state.activeAssistantMessage = null;
            state.activeUserMessage = null;
            elements.messageInput.value = "";
            setComposerError("");
            closeCitationModal();
            autoResizeTextarea();
            renderSessions();
            renderChat();
            renderSources();
            elements.messageInput.focus();
        }

        function renderChat() {
            updateNewChatButtonState();
            const selectedLabel = state.selectedSubjectId
                ? `${state.selectedSubjectCode} - ${state.selectedSubjectName}`
                : "";

            elements.heroTitle.textContent = state.selectedSubjectId
                ? `Chatting about ${selectedLabel}`
                : "Choose a subject to start chatting";

            elements.heroDescription.textContent = state.selectedSubjectId
                ? "Ask about the uploaded materials for this subject. Your message appears immediately, then the answer streams back like a ChatGPT conversation."
                : "Search for a subject on the left, select it, then ask FPT UniRAG about lecture notes, textbook chapters, or concepts from that subject.";

            elements.composerHint.textContent = state.selectedSubjectId
                ? `Selected subject: ${selectedLabel}`
                : "No subject selected.";

            elements.messageInput.placeholder = state.selectedSubjectId
                ? `Ask about ${selectedLabel}...`
                : "Choose a subject, then ask a question...";

            if (state.loadingSessionDetail) {
                elements.chatMessages.innerHTML = `
                    <div class="rounded-3xl border border-outline-variant bg-surface-container-lowest p-6 text-sm text-secondary shadow-sm">
                        Loading saved messages...
                    </div>`;
                return;
            }

            if (!state.messages.length) {
                elements.chatMessages.innerHTML = "";
                return;
            }

            elements.chatMessages.innerHTML = state.messages.map(buildMessageHtml).join("");

            bindCitationTriggers(elements.chatMessages);
            bindAssistantCitationTriggers(elements.chatMessages);
        }

        function buildMessageHtml(message) {
            if (String(message.senderRole || "").toLowerCase() !== "assistant") {
                return `
                    <div class="flex justify-end">
                        <div class="max-w-[72%] rounded-3xl border border-outline-variant bg-surface-container-lowest px-6 py-4 shadow-sm">
                            <p class="whitespace-pre-wrap text-base leading-7 text-on-surface">${escapeHtml(message.messageContent)}</p>
                        </div>
                    </div>`;
            }

            return `
                <div class="flex gap-3">
                    <div class="mt-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-2xl bg-primary text-white">
                        <span class="material-symbols-outlined text-[18px]">bolt</span>
                    </div>
                    ${buildAssistantBubbleHtml(message)}
                </div>`;
        }

        function buildAssistantBubbleHtml(message) {
            const citationTags = (message.citations || []).map((citation, index) => `
                <button
                    type="button"
                    class="citation-trigger rounded-full bg-surface-container-high px-2 py-1 text-xs font-medium text-secondary transition hover:bg-surface-container-highest"
                    data-document-id="${citation.documentId}"
                    data-chunk-index="${citation.chunkIndex}"
                    data-session-id="${state.sessionId || ""}"
                    data-message-id="${message.messageId || ""}"
                    data-document-title="${escapeAttribute(citation.documentTitle)}"
                    data-chapter-title="${escapeAttribute(citation.chapterTitle)}"
                    data-subject-code="${escapeAttribute(citation.subjectCode)}">
                    [${citation.citationNumber || index + 1}] ${escapeHtml(citation.documentTitle)}
                </button>`).join("");

            const cardClasses = message.isError
                ? "bg-red-50 border border-red-100"
                : "bg-surface-container-low";

            const progressMarkup = message.isStreaming && !message.messageContent && message.progressStage
                ? renderProcessingProgress(message.progressStage)
                : null;
            const assistantContent = progressMarkup
                ?? `${renderAssistantMarkdown(message.messageContent || (message.isStreaming ? "Thinking..." : ""), message.citations || [])}${message.isStreaming && message.messageContent ? "<span class=\"ml-1 inline-block h-5 w-0.5 animate-pulse bg-primary align-middle\"></span>" : ""}`;

            return `
                <div class="assistant-message max-w-[82%] min-w-0 rounded-3xl px-6 py-5 shadow-sm ${cardClasses}" data-message-key="${escapeAttribute(message.messageId || message.clientId || "")}">
                    <div class="assistant-markdown break-words text-base leading-7 text-on-surface-variant">${assistantContent}</div>
                    ${citationTags ? `<div class="mt-4 flex flex-wrap gap-2">${citationTags}</div>` : ""}
                </div>`;
        }

        function updateStreamingMessageDom(message) {
            const key = String(message.messageId || message.clientId || "");
            const node = key
                ? elements.chatMessages.querySelector(`.assistant-message[data-message-key="${CSS.escape(key)}"]`)
                : null;

            if (!node) {
                renderChat();
                return;
            }

            node.outerHTML = buildAssistantBubbleHtml(message);
            const refreshedNode = elements.chatMessages.querySelector(`.assistant-message[data-message-key="${CSS.escape(key)}"]`);
            if (refreshedNode) {
                bindAssistantCitationTriggers(refreshedNode);
            }
        }

        const processingStages = [
            { key: "validating-request", label: "Checking your request" },
            { key: "searching-materials", label: "Searching course materials" },
            { key: "generating-answer", label: "Generating the answer" },
            { key: "finalizing-answer", label: "Finalizing the response" }
        ];

        function renderProcessingProgress(activeStage) {
            const activeIndex = processingStages.findIndex(stage => stage.key === activeStage);
            if (activeIndex < 0) {
                return renderAssistantMarkdown("Thinking...", []);
            }

            return `
                <div class="space-y-3" role="status" aria-live="polite" aria-label="Chat response progress">
                    ${processingStages.map((stage, index) => {
                        const isComplete = index < activeIndex;
                        const isActive = index === activeIndex;
                        const icon = isComplete
                            ? `<span class="material-symbols-outlined text-[18px] text-green-600">check_circle</span>`
                            : isActive
                                ? `<span class="material-symbols-outlined animate-spin text-[18px] text-primary">progress_activity</span>`
                                : `<span class="h-[18px] w-[18px] rounded-full border border-outline-variant"></span>`;
                        const textClass = isActive
                            ? "font-semibold text-on-surface"
                            : isComplete
                                ? "text-secondary"
                                : "text-secondary/60";

                        return `<div class="flex items-center gap-3">${icon}<span class="text-sm ${textClass}">${stage.label}</span></div>`;
                    }).join("")}
                </div>`;
        }

        function renderSources() {
            if (!state.latestSources.length) {
                elements.sourcesPanel.innerHTML = `
                    <div class="rounded-2xl border border-dashed border-outline-variant bg-surface-container-lowest p-5 text-sm leading-6 text-secondary">
                        Ask a question after selecting a subject to see the referenced documents here.
                    </div>`;
                return;
            }

            elements.sourcesPanel.innerHTML = state.latestSources.map((source, index) => `
                <button
                    type="button"
                    class="citation-trigger rounded-2xl border border-outline-variant bg-surface-container-lowest p-4 text-left shadow-sm transition hover:border-primary/40 hover:bg-surface-container-high"
                    data-document-id="${source.documentId}"
                    data-chunk-index="${source.chunkIndex}"
                    data-session-id="${state.sessionId || ""}"
                    data-message-id="${source.messageId || ""}"
                    data-document-title="${escapeAttribute(source.documentTitle)}"
                    data-chapter-title="${escapeAttribute(source.chapterTitle)}"
                    data-subject-code="${escapeAttribute(source.subjectCode)}">
                    <div class="flex items-start justify-between gap-3">
                        <div class="rounded-xl bg-blue-50 p-2 text-primary">
                            <span class="material-symbols-outlined">${source.documentTitle.toLowerCase().endsWith(".pdf") ? "picture_as_pdf" : "description"}</span>
                        </div>
                        <span class="rounded-full border border-green-100 bg-green-50 px-2 py-1 text-[11px] font-semibold text-green-700">
                            ${Math.round((source.similarityScore || 0) * 100)}% Match
                        </span>
                    </div>
                    <div class="mt-3">
                        <h4 class="truncate text-sm font-semibold text-on-surface">[${source.citationNumber || index + 1}] ${escapeHtml(source.documentTitle)}</h4>
                        <p class="mt-1 text-xs text-secondary">${escapeHtml(source.subjectCode)} · ${escapeHtml(source.chapterTitle)}</p>
                    </div>
                </button>`).join("");

            bindCitationTriggers(elements.sourcesPanel);
        }

        function bindCitationTriggers(container) {
            container.querySelectorAll(".citation-trigger").forEach(button => {
                button.addEventListener("click", async () => {
                    const sessionId = button.getAttribute("data-session-id");
                    const messageId = button.getAttribute("data-message-id");
                    const documentId = button.getAttribute("data-document-id");
                    const chunkIndexRaw = button.getAttribute("data-chunk-index");
                    const chunkIndex = Number.parseInt(chunkIndexRaw || "", 10);

                    if (!sessionId || !messageId || !documentId || Number.isNaN(chunkIndex)) {
                        return;
                    }

                    await openCitationDetail({
                        sessionId,
                        messageId,
                        documentId,
                        chunkIndex,
                        documentTitle: button.getAttribute("data-document-title") || "Chunk detail",
                        chapterTitle: button.getAttribute("data-chapter-title") || "",
                        subjectCode: button.getAttribute("data-subject-code") || "Citation"
                    });
                });
            });
        }

        function bindAssistantCitationTriggers(container) {
            container.querySelectorAll(".assistant-citation-marker").forEach(button => {
                button.addEventListener("click", async () => {
                    const messageKey = button.closest(".assistant-message")?.getAttribute("data-message-key");
                    const message = state.messages.find(item => String(item.messageId || item.clientId || "") === messageKey);
                    const citations = message?.citations || [];
                    const citationNumber = Number.parseInt(button.getAttribute("data-citation-number") || "", 10);
                    const citation = citations.find((item, index) => (item.citationNumber || index + 1) === citationNumber);
                    if (!citation) {
                        return;
                    }

                    await openCitationDetail({
                        sessionId: state.sessionId,
                        messageId: message.messageId,
                        documentId: citation.documentId,
                        chunkIndex: citation.chunkIndex,
                        documentTitle: citation.documentTitle,
                        chapterTitle: citation.chapterTitle,
                        subjectCode: citation.subjectCode
                    });
                });
            });
        }

        async function openCitationDetail(citation) {
            state.loadingCitation = true;
            renderCitationModalLoading(citation);

            try {
                const url = new URL(`/api/student/chat/sessions/${encodeURIComponent(citation.sessionId)}/citations`, window.location.origin);
                url.searchParams.set("messageId", citation.messageId);
                url.searchParams.set("documentId", citation.documentId);
                url.searchParams.set("chunkIndex", String(citation.chunkIndex));

                const response = await fetch(url, {
                    headers: {
                        "Accept": "application/json"
                    }
                });

                if (!response.ok) {
                    throw new Error("Unable to load the cited chunk right now.");
                }

                const payload = await response.json();
                if (!payload.citation) {
                    throw new Error("The cited chunk is no longer available.");
                }

                renderCitationModal(payload.citation);
            } catch (error) {
                elements.citationModalEyebrow.textContent = citation.subjectCode || "Citation";
                elements.citationModalTitle.textContent = citation.documentTitle || "Chunk detail";
                elements.citationModalMeta.textContent = `${citation.chapterTitle || ""} · Chunk ${citation.chunkIndex}`;
                elements.citationModalBody.textContent = error instanceof Error ? error.message : "Unable to load the cited chunk right now.";
                openCitationModalShell();
            } finally {
                state.loadingCitation = false;
            }
        }

        async function refreshSubjects(query) {
            const url = new URL("/api/student/chat/subjects", window.location.origin);
            if (query) {
                url.searchParams.set("q", query);
            }

            const response = await fetch(url, {
                headers: {
                    "Accept": "application/json"
                }
            });

            if (!response.ok) {
                return;
            }

            const payload = await response.json();
            state.subjects = payload.subjects || [];
            renderSubjects();
        }

        async function refreshSessions(subjectId = state.selectedSubjectId) {
            if (!subjectId) {
                state.sessions = [];
                renderSessions();
                return;
            }

            state.loadingSessions = true;
            renderSessions();

            try {
                const url = new URL("/api/student/chat/sessions", window.location.origin);
                url.searchParams.set("subjectId", subjectId);

                const response = await fetch(url, {
                    headers: {
                        "Accept": "application/json"
                    }
                });

                if (!response.ok) {
                    throw new Error("Unable to load chat history right now.");
                }

                const payload = await response.json();
                state.sessions = Array.isArray(payload.sessions) ? payload.sessions : [];
            } catch (error) {
                state.sessions = [];
                setComposerError(error instanceof Error ? error.message : "Unable to load chat history right now.");
            } finally {
                state.loadingSessions = false;
                renderSessions();
            }
        }

        async function openSession(sessionId) {
            state.loadingSessionDetail = true;
            setComposerError("");
            renderSessions();
            renderChat();

            try {
                const response = await fetch(`/api/student/chat/sessions/${encodeURIComponent(sessionId)}`, {
                    headers: {
                        "Accept": "application/json"
                    }
                });

                if (!response.ok) {
                    throw new Error("Unable to load that chat session right now.");
                }

                const payload = await response.json();
                const session = payload.session;
                if (!session) {
                    throw new Error("The selected chat session is no longer available.");
                }

                state.sessionId = session.sessionId;
                state.selectedSubjectId = session.subjectId;
                state.selectedSubjectCode = session.subjectCode || state.selectedSubjectCode;
                state.selectedSubjectName = session.subjectName || state.selectedSubjectName;
                state.messages = Array.isArray(session.messages) ? session.messages : [];
                updateLatestSourcesFromMessages(state.messages);
                renderSubjects();
                renderSessions();
                renderSources();
            } catch (error) {
                state.messages = [];
                state.latestSources = [];
                setComposerError(error instanceof Error ? error.message : "Unable to load that chat session right now.");
                renderSources();
            } finally {
                state.loadingSessionDetail = false;
                renderChat();
            }
        }

        function autoResizeTextarea() {
            elements.messageInput.style.height = "auto";
            elements.messageInput.style.height = `${Math.min(elements.messageInput.scrollHeight, 224)}px`;
        }

        function handleChatEvent(eventName, payload) {
            const optimisticUserMessage = state.activeUserMessage;
            const assistantPlaceholder = state.activeAssistantMessage;

            if (!payload) {
                return;
            }

            if (eventName === "session-started") {
                state.sessionId = payload.sessionId;
                upsertSessionSummary(payload.sessionId, state.activeUserMessage?.messageContent || "New chat", new Date().toISOString());
                renderSessions();
                return;
            }

            if (eventName === "user-message-ack" && optimisticUserMessage) {
                optimisticUserMessage.messageId = payload.messageId;
                optimisticUserMessage.createdAt = payload.createdAt;
                upsertSessionSummary(state.sessionId, optimisticUserMessage.messageContent, payload.createdAt);
                return;
            }

            if (eventName === "processing-progress" && assistantPlaceholder) {
                assistantPlaceholder.progressStage = payload.stage || null;
                updateStreamingMessageDom(assistantPlaceholder);
                scrollChatToBottom();
                return;
            }

            if (eventName === "assistant-delta" && assistantPlaceholder) {
                assistantPlaceholder.progressStage = null;
                appendAssistantDelta(payload.delta || "");
                return;
            }

            if (eventName === "assistant-complete" && assistantPlaceholder) {
                assistantPlaceholder.messageId = payload.messageId;
                assistantPlaceholder.messageContent = payload.messageContent || assistantPlaceholder.messageContent;
                assistantPlaceholder.createdAt = payload.createdAt;
                assistantPlaceholder.citations = (Array.isArray(payload.citations) ? payload.citations : [])
                    .map(citation => ({ ...citation, messageId: assistantPlaceholder.messageId }));
                assistantPlaceholder.isStreaming = false;
                assistantPlaceholder.progressStage = null;
                state.latestSources = assistantPlaceholder.citations;
                upsertSessionSummary(state.sessionId, assistantPlaceholder.messageContent, payload.createdAt);
                state.activeAssistantMessage = null;
                state.activeUserMessage = null;
                renderChat();
                renderSources();
                return;
            }

            if (eventName === "error") {
                if (assistantPlaceholder) {
                    assistantPlaceholder.isStreaming = false;
                    assistantPlaceholder.isError = true;
                    assistantPlaceholder.progressStage = null;
                    if (!assistantPlaceholder.messageContent.trim()) {
                        assistantPlaceholder.messageContent = payload.message || "Unable to generate an answer right now.";
                    } else {
                        setComposerError(payload.message || "Unable to generate an answer right now.");
                    }
                    renderChat();
                } else {
                    setComposerError(payload.message || "Unable to generate an answer right now.");
                }

                state.activeAssistantMessage = null;
                state.activeUserMessage = null;
            }
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/student-chat")
            .withAutomaticReconnect()
            .build();

        connection.on("chatEvent", (eventName, payload) => {
            handleChatEvent(eventName, payload);
        });

        connection.onreconnected(() => {
            state.connectionReady = true;
        });

        connection.onclose(() => {
            state.connectionReady = false;
        });

        async function ensureChatConnection() {
            if (connection.state === signalR.HubConnectionState.Connected) {
                state.connectionReady = true;
                return;
            }

            await connection.start();
            state.connectionReady = true;
        }

        async function streamMessage(message, optimisticUserMessage, assistantPlaceholder) {
            await ensureChatConnection();
            state.activeUserMessage = optimisticUserMessage;
            state.activeAssistantMessage = assistantPlaceholder;

            await connection.invoke("SendMessage", {
                sessionId: state.sessionId,
                subjectId: state.selectedSubjectId,
                message
            });

            if (assistantPlaceholder.isStreaming) {
                assistantPlaceholder.isStreaming = false;
                renderChat();
            }
        }

        let searchTimer = null;
        elements.subjectSearchInput.addEventListener("input", event => {
            window.clearTimeout(searchTimer);
            searchTimer = window.setTimeout(() => {
                refreshSubjects(event.target.value.trim());
            }, 200);
        });

        elements.messageInput.addEventListener("input", autoResizeTextarea);
        elements.messageInput.addEventListener("keydown", event => {
            if (event.key === "Enter" && !event.shiftKey && !event.isComposing) {
                event.preventDefault();
                elements.chatForm.requestSubmit();
            }
        });
        elements.newChatButton.addEventListener("click", startNewChat);
        elements.citationModalClose.addEventListener("click", closeCitationModal);
        elements.citationModal.addEventListener("click", event => {
            if (event.target === elements.citationModal) {
                closeCitationModal();
            }
        });

        elements.subjectsToggle.addEventListener("click", () => toggleSubjectsDrawer());
        elements.subjectsClose.addEventListener("click", () => toggleSubjectsDrawer(false));
        elements.subjectsBackdrop.addEventListener("click", () => toggleSubjectsDrawer(false));

        elements.sourcesToggle.addEventListener("click", () => toggleSourcesDrawer());
        elements.sourcesClose.addEventListener("click", () => toggleSourcesDrawer(false));
        elements.sourcesBackdrop.addEventListener("click", () => toggleSourcesDrawer(false));

        window.matchMedia("(min-width: 768px)").addEventListener("change", event => {
            if (event.matches) {
                toggleSubjectsDrawer(false);
            }
        });
        window.matchMedia("(min-width: 1024px)").addEventListener("change", event => {
            if (event.matches) {
                toggleSourcesDrawer(false);
            }
        });

        document.addEventListener("keydown", event => {
            if (event.key !== "Escape") {
                return;
            }

            if (state.citationModalOpen) {
                closeCitationModal();
                return;
            }

            if (elements.subjectsAside.classList.contains("translate-x-0")) {
                toggleSubjectsDrawer(false);
                return;
            }

            if (elements.sourcesAside.classList.contains("translate-x-0")) {
                toggleSourcesDrawer(false);
            }
        });

        elements.chatForm.addEventListener("submit", async event => {
            event.preventDefault();
            const message = elements.messageInput.value.trim();

            if (!state.selectedSubjectId) {
                setComposerError("Please choose a subject before chatting.");
                return;
            }

            if (!message) {
                setComposerError("Please enter a message before sending.");
                return;
            }

            setComposerError("");
            state.sending = true;
            elements.sendButton.disabled = true;
            elements.sendButton.innerHTML = `<span class="material-symbols-outlined animate-spin">progress_activity</span>`;

            const optimisticUserMessage = {
                clientId: crypto.randomUUID(),
                messageId: null,
                senderRole: "student",
                messageContent: message,
                createdAt: null,
                citations: []
            };

            const assistantPlaceholder = {
                clientId: crypto.randomUUID(),
                messageId: null,
                senderRole: "assistant",
                messageContent: "",
                createdAt: null,
                citations: [],
                isStreaming: true,
                isError: false,
                progressStage: null
            };

            state.latestSources = [];
            state.messages.push(optimisticUserMessage, assistantPlaceholder);
            elements.messageInput.value = "";
            autoResizeTextarea();
            renderChat();
            renderSources();
            scrollChatToBottom();

            try {
                await streamMessage(message, optimisticUserMessage, assistantPlaceholder);
            } catch (error) {
                state.activeAssistantMessage = null;
                state.activeUserMessage = null;
                if (!assistantPlaceholder.messageContent.trim()) {
                    assistantPlaceholder.messageContent = error instanceof Error ? error.message : "Unable to generate an answer right now.";
                    assistantPlaceholder.isError = true;
                    assistantPlaceholder.isStreaming = false;
                    renderChat();
                } else {
                    setComposerError(error instanceof Error ? error.message : "Unable to generate an answer right now.");
                }
            } finally {
                state.sending = false;
                elements.sendButton.disabled = false;
                elements.sendButton.innerHTML = `<span class="material-symbols-outlined">send</span>`;
                updateNewChatButtonState();
            }
        });

        renderSubjects();
        renderSessions();
        renderChat();
        renderSources();
        autoResizeTextarea();
        ensureChatConnection().catch(() => {
            setComposerError("Unable to connect to live chat right now. Please refresh the page.");
        });
    </script>
</body>
</html>
