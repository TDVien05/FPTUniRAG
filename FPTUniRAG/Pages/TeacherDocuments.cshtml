@page "/TeacherDocuments"
@model FPTUniRAG.Pages.TeacherDocumentsModel
@{
    Layout = null;
    ViewData["Title"] = "Document Management - Teacher List - FPT UniRAG";
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Manrope:wght@600;700&amp;family=JetBrains+Mono&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        try {
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            "primary-fixed-dim": "#adc7ff",
                            "primary": "#005bbf",
                            "secondary": "#505f76",
                            "tertiary-fixed-dim": "#c4c7c9",
                            "secondary-fixed": "#d3e4fe",
                            "on-error": "#ffffff",
                            "on-primary-fixed-variant": "#004493",
                            "on-tertiary-container": "#ffffff",
                            "on-secondary": "#ffffff",
                            "surface-tint": "#005bc0",
                            "on-primary-fixed": "#001a41",
                            "on-primary-container": "#ffffff",
                            "inverse-primary": "#adc7ff",
                            "surface-bright": "#f9f9ff",
                            "inverse-on-surface": "#ecf1ff",
                            "tertiary-fixed": "#e0e3e5",
                            "background": "#f9f9ff",
                            "on-secondary-fixed": "#0b1c30",
                            "on-secondary-fixed-variant": "#38485d",
                            "on-tertiary-fixed": "#191c1e",
                            "primary-container": "#1a73e8",
                            "on-surface": "#111c2d",
                            "outline-variant": "#c1c6d6",
                            "surface": "#f9f9ff",
                            "on-primary": "#ffffff",
                            "on-tertiary-fixed-variant": "#444749",
                            "on-secondary-container": "#54647a",
                            "secondary-container": "#d0e1fb",
                            "on-surface-variant": "#414754",
                            "surface-container-lowest": "#ffffff",
                            "surface-container-highest": "#d8e3fb",
                            "surface-container": "#e7eeff",
                            "error-container": "#ffdad6",
                            "primary-fixed": "#d8e2ff",
                            "on-tertiary": "#ffffff",
                            "inverse-surface": "#263143",
                            "surface-container-low": "#f0f3ff",
                            "error": "#ba1a1a",
                            "tertiary-container": "#747779",
                            "surface-container-high": "#dee8ff",
                            "on-background": "#111c2d",
                            "surface-dim": "#cfdaf2",
                            "outline": "#727785",
                            "tertiary": "#5b5e60",
                            "secondary-fixed-dim": "#b7c8e1",
                            "on-error-container": "#93000a",
                            "surface-variant": "#d8e3fb"
                        },
                        borderRadius: {
                            "DEFAULT": "0.25rem",
                            "lg": "0.5rem",
                            "xl": "0.75rem",
                            "full": "9999px"
                        },
                        spacing: {
                            "margin-desktop": "32px",
                            "container-max-width": "1280px",
                            "margin-mobile": "16px",
                            "gutter": "24px",
                            "base": "8px"
                        },
                        fontFamily: {
                            "label-md": ["Inter"],
                            "label-sm": ["Inter"],
                            "headline-lg": ["Manrope"],
                            "body-lg": ["Inter"],
                            "headline-xl": ["Manrope"],
                            "headline-lg-mobile": ["Manrope"],
                            "body-md": ["Inter"]
                        },
                        fontSize: {
                            "label-md": ["14px", { "lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500" }],
                            "label-sm": ["12px", { "lineHeight": "1.2", "fontWeight": "600" }],
                            "headline-lg": ["32px", { "lineHeight": "1.25", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                            "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                            "headline-xl": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                            "headline-lg-mobile": ["24px", { "lineHeight": "1.3", "fontWeight": "600" }],
                            "body-md": ["16px", { "lineHeight": "1.5", "fontWeight": "400" }]
                        }
                    }
                }
            };
        } catch (_e) { }
    </script>
</head>
<body class="font-body-md text-on-surface bg-background">
    <nav class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-md border-b border-outline-variant/30 shadow-sm">
        <div class="flex items-center justify-between px-gutter w-full h-16">
            <div class="flex items-center gap-base md:gap-gutter">
                <span class="font-headline-lg text-[24px] font-bold text-primary">FPT UniRAG</span>
                <div class="hidden md:flex gap-gutter"></div>
            </div>
            <div class="flex items-center gap-base">
                <button class="material-symbols-outlined text-secondary hover:bg-surface-container-low p-2 rounded-full transition-all" type="button">notifications</button>
                <a class="material-symbols-outlined text-secondary hover:bg-surface-container-low p-2 rounded-full transition-all" href="/ChangePassword">settings</a>
                <div class="h-8 w-8 rounded-full bg-primary-container flex items-center justify-center text-white font-semibold">
                    @(string.IsNullOrWhiteSpace(User.Identity?.Name) ? "T" : User.Identity!.Name![0].ToString().ToUpperInvariant())
                </div>
            </div>
        </div>
    </nav>

    <aside class="h-screen w-64 fixed left-0 top-0 hidden md:flex flex-col bg-surface-container-lowest border-r border-outline-variant/20 pt-20 p-base gap-base">
        <div class="flex flex-col gap-1 mb-6 px-2">
            <span class="font-headline-lg text-[20px] font-bold text-primary leading-tight">FPT UniRAG</span>
            <span class="font-label-sm text-secondary opacity-70 uppercase tracking-wider text-[10px]">Academic AI Assistant</span>
        </div>
        <nav class="flex flex-col gap-1">
            <a class="flex items-center gap-base p-3 text-secondary hover:bg-surface-container-high rounded-lg transition-all" href="/TeacherHome">
                <span class="material-symbols-outlined">home</span>
                <span class="font-label-md">Home</span>
            </a>
            <a class="flex items-center gap-base p-3 bg-primary/10 text-primary rounded-lg transition-all" href="/TeacherDocuments">
                <span class="material-symbols-outlined">folder_open</span>
                <span class="font-label-md">Document Management</span>
            </a>
        </nav>
        <div class="mt-auto flex flex-col gap-1 border-t border-outline-variant/10 pt-base">
            <a class="flex items-center gap-base p-3 text-secondary hover:bg-surface-container-high rounded-lg transition-all" href="/ChangePassword">
                <span class="material-symbols-outlined">lock</span>
                <span class="font-label-md">Change Password</span>
            </a>
            <a class="flex items-center gap-base p-3 text-secondary hover:bg-surface-container-high rounded-lg transition-all" href="#">
                <span class="material-symbols-outlined">help</span>
                <span class="font-label-md">Help</span>
            </a>
            <a class="flex items-center gap-base p-3 text-secondary hover:bg-surface-container-high rounded-lg transition-all" href="/Logout">
                <span class="material-symbols-outlined">logout</span>
                <span class="font-label-md">Logout</span>
            </a>
        </div>
    </aside>

    <main class="md:ml-64 pt-20 px-gutter pb-8">
        <div class="mb-8">
            <nav class="flex items-center gap-2 text-sm text-secondary mb-2" aria-label="Breadcrumb">
                <span>Workspace</span>
                <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span>
                <span class="text-on-surface font-medium">Document Management</span>
            </nav>
            <h1 class="font-headline-lg text-on-surface">Knowledge Library</h1>
            <p class="font-body-md text-secondary mt-1">Choose a subject to manage its chapters, documents, and generated chunks.</p>
        </div>

        @if (Model.ManagedSubjects.Count == 0)
        {
            <section class="rounded-xl border border-outline-variant/30 bg-surface-container-lowest p-10 text-center shadow-sm">
                <span class="material-symbols-outlined text-4xl text-secondary" aria-hidden="true">folder_off</span>
                <h2 class="mt-3 font-headline-lg text-xl text-on-surface">No managed subjects</h2>
                <p class="mt-2 text-sm text-secondary">No subjects are assigned to you yet.</p>
            </section>
        }
        else
        {
            <form class="mb-5 lg:hidden" method="get">
                <label class="mb-2 block text-sm font-semibold text-on-surface" for="subject-selector">Subject</label>
                <select class="min-h-11 w-full rounded-xl border border-outline-variant/40 bg-white px-4 text-sm text-on-surface focus:border-primary focus:ring-primary" id="subject-selector" name="subjectId" onchange="this.form.submit()">
                    @foreach (var subject in Model.ManagedSubjects)
                    {
                        <option value="@subject.SubjectId" selected="@(subject.SubjectId == Model.SubjectId)">@subject.SubjectCode — @subject.SubjectName (@subject.DocumentCount)</option>
                    }
                </select>
            </form>

            <div class="grid items-start gap-6 lg:grid-cols-[280px_minmax(0,1fr)]">
                <aside class="sticky top-20 hidden overflow-hidden rounded-xl border border-outline-variant/30 bg-surface-container-lowest shadow-sm lg:block" aria-label="Managed subjects">
                    <div class="border-b border-outline-variant/20 px-4 py-4">
                        <h2 class="font-semibold text-on-surface">Your Subjects</h2>
                        <p class="mt-1 text-xs text-secondary">@Model.ManagedSubjects.Count subject(s) assigned</p>
                    </div>
                    <nav class="max-h-[calc(100vh-12rem)] space-y-1 overflow-y-auto p-2">
                        @foreach (var subject in Model.ManagedSubjects)
                        {
                            var isActive = subject.SubjectId == Model.SubjectId;
                            <a class="flex min-h-14 items-center justify-between gap-3 rounded-lg px-3 py-2 transition-colors @(isActive ? "bg-primary/10 text-primary" : "text-secondary hover:bg-surface-container-high")"
                               href="/TeacherDocuments?subjectId=@subject.SubjectId"
                               aria-current="@(isActive ? "page" : null)">
                                <span class="min-w-0">
                                    <strong class="block truncate text-sm">@subject.SubjectCode</strong>
                                    <span class="block truncate text-xs opacity-80">@subject.SubjectName</span>
                                </span>
                                <span class="shrink-0 rounded-full bg-surface-container px-2 py-1 text-[11px] font-semibold">@subject.DocumentCount</span>
                            </a>
                        }
                    </nav>
                </aside>

                @if (Model.SelectedSubject is not null)
                {
                    <div class="min-w-0 space-y-6">
                        <section class="flex flex-col gap-5 rounded-xl border border-outline-variant/30 bg-surface-container-lowest p-5 shadow-sm xl:flex-row xl:items-end xl:justify-between">
                            <div class="min-w-0">
                                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary">@Model.SelectedSubject.SubjectCode</p>
                                <h2 class="mt-1 truncate font-headline-lg text-2xl text-on-surface">@Model.SelectedSubject.SubjectName</h2>
                                <p class="mt-1 text-sm text-secondary">
                                    Only documents from this subject are shown below.
                                    @if (!Model.SelectedSubject.CanManage)
                                    {
                                        <span class="ml-1 font-medium text-secondary">You have read-only access to this subject; only the department head can upload, retry, or delete.</span>
                                    }
                                </p>
                            </div>
                            @if (Model.SelectedSubject.CanManage)
                            {
                                <a class="inline-flex min-h-11 shrink-0 items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/40"
                                   href="/TeacherUpload?subjectId=@Model.SelectedSubject.SubjectId">
                                    <span class="material-symbols-outlined text-lg" aria-hidden="true">upload_file</span>
                                    Upload Document
                                </a>
                            }
                        </section>

                        <section class="grid grid-cols-1 gap-4 sm:grid-cols-3" aria-label="Selected subject statistics">
                            <div class="rounded-xl border border-outline-variant/30 bg-surface-container-lowest px-5 py-4 shadow-sm">
                                <span class="text-[10px] font-semibold uppercase tracking-wider text-secondary">Documents</span>
                                <strong class="mt-1 block text-xl text-primary">@Model.SelectedSubject.DocumentCount</strong>
                            </div>
                            <div class="rounded-xl border border-outline-variant/30 bg-surface-container-lowest px-5 py-4 shadow-sm">
                                <span class="text-[10px] font-semibold uppercase tracking-wider text-secondary">Completed</span>
                                <strong class="mt-1 block text-xl text-on-surface">@Model.CompletedDocumentCount</strong>
                            </div>
                            <div class="rounded-xl border border-outline-variant/30 bg-surface-container-lowest px-5 py-4 shadow-sm">
                                <span class="text-[10px] font-semibold uppercase tracking-wider text-secondary">Last Updated</span>
                                <strong class="mt-1 block text-sm text-on-surface">@(Model.SelectedSubject.LastUpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "No uploads")</strong>
                            </div>
                        </section>

                        <section class="flex flex-col overflow-hidden rounded-xl border border-outline-variant/30 bg-surface-container-lowest shadow-sm">
                            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                            {
                                <div class="mx-4 mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900" role="status">@Model.SuccessMessage</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                            {
                                <div class="mx-4 mt-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-900" role="alert">@Model.ErrorMessage</div>
                            }

                            <div class="flex flex-col gap-4 border-b border-outline-variant/20 p-4 sm:flex-row sm:items-center sm:justify-between">
                                <div>
                                    <h3 class="font-semibold text-on-surface">Chapters and Documents</h3>
                                    <p class="mt-1 text-xs text-secondary">@Model.VisibleDocuments.Count matching document(s)</p>
                                </div>
                                <form class="flex w-full gap-2 sm:w-auto" method="get">
                                    <input name="subjectId" type="hidden" value="@Model.SelectedSubject.SubjectId" />
                                    <label class="sr-only" for="document-query">Search documents in @Model.SelectedSubject.SubjectCode</label>
                                    <div class="relative min-w-0 flex-1 sm:w-72">
                                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-sm text-secondary" aria-hidden="true">search</span>
                                        <input asp-for="Query" class="min-h-11 w-full rounded-lg border border-outline-variant/30 bg-surface-container-low py-2 pl-9 pr-3 text-sm outline-none focus:border-primary focus:ring-1 focus:ring-primary/30" id="document-query" placeholder="Search chapter or document..." type="search" />
                                    </div>
                                    <button class="inline-flex min-h-11 items-center justify-center rounded-lg border border-outline-variant/30 px-4 text-sm font-medium text-secondary hover:bg-surface-container-low" type="submit">Search</button>
                                </form>
                            </div>

                            <div class="overflow-x-auto">
                                <table class="w-full min-w-[760px] text-left">
                                    <thead>
                                        <tr class="border-b border-outline-variant/10 bg-surface-container-low/30 text-secondary">
                                            <th class="px-6 py-4 text-[10px] font-semibold uppercase tracking-wider">Chapter</th>
                                            <th class="px-6 py-4 text-[10px] font-semibold uppercase tracking-wider">Document</th>
                                            <th class="px-6 py-4 text-[10px] font-semibold uppercase tracking-wider">Status</th>
                                            <th class="px-6 py-4 text-[10px] font-semibold uppercase tracking-wider">Uploaded</th>
                                            <th class="px-6 py-4 text-right text-[10px] font-semibold uppercase tracking-wider">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-outline-variant/10">
                                        @if (Model.VisibleDocuments.Count == 0)
                                        {
                                            <tr>
                                                <td class="px-6 py-12 text-center text-sm text-secondary" colspan="5">
                                                    @(string.IsNullOrWhiteSpace(Model.Query) ? "No documents have been uploaded for this subject." : "No chapters or documents match your search.")
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            foreach (var document in Model.VisibleDocuments)
                                            {
                                                <tr class="group transition-colors hover:bg-surface-container-low/50">
                                                    <td class="px-6 py-4 text-sm font-medium text-on-surface">@document.ChapterTitle</td>
                                                    <td class="px-6 py-4 text-sm text-secondary">
                                                        <strong class="block max-w-xs truncate text-on-surface">@document.DocumentTitle</strong>
                                                        <span class="text-xs">@document.ChunkCount chunk(s)</span>
                                                    </td>
                                                    <td class="px-6 py-4 text-sm text-secondary">
                                                        <span class="uppercase tracking-wide text-primary">@document.Status</span>
                                                        @if (!string.IsNullOrWhiteSpace(document.ProcessingError))
                                                        {
                                                            <span class="mt-1 block max-w-sm text-xs normal-case text-rose-700">@document.ProcessingError</span>
                                                        }
                                                    </td>
                                                    <td class="px-6 py-4 text-sm text-secondary">@(document.CreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</td>
                                                    <td class="px-6 py-4 text-right">
                                                        <div class="flex justify-end gap-2">
                                                            <a class="inline-flex min-h-9 items-center gap-1 rounded border border-outline-variant/40 px-3 py-1 text-xs font-medium hover:bg-surface-container-low" href="/TeacherDocuments/Details?documentId=@document.DocumentId&subjectId=@Model.SelectedSubject.SubjectId&query=@Uri.EscapeDataString(Model.Query ?? string.Empty)">
                                                                <span class="material-symbols-outlined text-sm" aria-hidden="true">visibility</span>View Chunks
                                                            </a>
                                                            @if (Model.SelectedSubject.CanManage)
                                                            {
                                                                @if (string.Equals(document.Status, "failed", StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <form method="post" asp-page-handler="Retry">
                                                                        <input type="hidden" name="documentId" value="@document.DocumentId" />
                                                                        <input type="hidden" name="subjectId" value="@Model.SelectedSubject.SubjectId" />
                                                                        <input type="hidden" name="Query" value="@Model.Query" />
                                                                        <button class="inline-flex min-h-9 items-center gap-1 rounded border border-amber-300 bg-amber-50 px-3 py-1 text-xs font-medium text-amber-900 hover:bg-amber-100" type="submit">
                                                                            <span class="material-symbols-outlined text-sm" aria-hidden="true">refresh</span>Retry Sync
                                                                        </button>
                                                                    </form>
                                                                }
                                                                <form class="delete-chapter-form" method="post" asp-page-handler="DeleteChapter" data-chapter-title="@document.ChapterTitle">
                                                                    <input type="hidden" name="subjectId" value="@Model.SelectedSubject.SubjectId" />
                                                                    <input type="hidden" name="chapterId" value="@document.ChapterId" />
                                                                    <input type="hidden" name="Query" value="@Model.Query" />
                                                                    <button class="inline-flex min-h-9 items-center gap-1 rounded border border-rose-300 bg-rose-50 px-3 py-1 text-xs font-medium text-rose-800 hover:bg-rose-100" type="submit">
                                                                        <span class="material-symbols-outlined text-sm" aria-hidden="true">delete</span>Delete Chapter
                                                                    </button>
                                                                </form>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    </div>
                }
            </div>
        }
    </main>

    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-surface/95 backdrop-blur-md border-t border-outline-variant/20 flex justify-around p-2 z-50">
        <a class="flex flex-col items-center gap-1 text-secondary" href="/TeacherHome">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[10px] font-medium">Home</span>
        </a>
        <a class="flex flex-col items-center gap-1 text-primary" href="/TeacherDocuments">
            <span class="material-symbols-outlined">folder_open</span>
            <span class="text-[10px] font-medium">Files</span>
        </a>
        <a class="flex flex-col items-center gap-1 text-secondary" href="/ChangePassword">
            <span class="material-symbols-outlined">lock</span>
            <span class="text-[10px] font-medium">Password</span>
        </a>
    </nav>

    <div id="delete-progress-overlay" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-slate-900/50 px-4" aria-live="polite">
        <div class="w-full max-w-sm rounded-2xl border border-outline-variant/30 bg-white p-6 shadow-xl">
            <p class="font-headline-lg text-base font-bold text-on-surface">Deleting chapter</p>
            <p class="mt-1 text-sm text-secondary" id="delete-progress-stage">Removing quiz questions…</p>
            <div class="mt-4 h-3 overflow-hidden rounded-full bg-surface-container-high">
                <div id="delete-progress-bar" class="h-full w-0 rounded-full bg-rose-600 transition-all duration-500" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"></div>
            </div>
            <p class="mt-2 text-right text-xs font-semibold text-secondary" id="delete-progress-value">0%</p>
        </div>
    </div>

    <script>
        (() => {
            const overlay = document.getElementById("delete-progress-overlay");
            const stageEl = document.getElementById("delete-progress-stage");
            const barEl = document.getElementById("delete-progress-bar");
            const valueEl = document.getElementById("delete-progress-value");
            const stages = [
                { percent: 15, label: "Removing quiz questions…" },
                { percent: 30, label: "Removing chunk embeddings…" },
                { percent: 45, label: "Removing embedding run records…" },
                { percent: 60, label: "Removing processing jobs…" },
                { percent: 80, label: "Removing chunks and document…" },
                { percent: 95, label: "Removing chapter and uploaded file…" }
            ];

            document.querySelectorAll(".delete-chapter-form").forEach((form) => {
                form.addEventListener("submit", (event) => {
                    const chapterTitle = form.dataset.chapterTitle || "this chapter";
                    if (!window.confirm(`Delete chapter ${chapterTitle} and all related document, chunk, embedding, and question data? This cannot be undone.`)) {
                        event.preventDefault();
                        return;
                    }

                    const submitButton = form.querySelector("button[type=submit]");
                    if (submitButton) {
                        submitButton.disabled = true;
                    }

                    overlay.classList.remove("hidden");
                    let stepIndex = 0;
                    const applyStep = () => {
                        const step = stages[stepIndex];
                        stageEl.textContent = step.label;
                        barEl.style.width = `${step.percent}%`;
                        barEl.setAttribute("aria-valuenow", step.percent);
                        valueEl.textContent = `${step.percent}%`;
                    };
                    applyStep();
                    window.setInterval(() => {
                        stepIndex = Math.min(stepIndex + 1, stages.length - 1);
                        applyStep();
                    }, 450);
                });
            });
        })();
    </script>
</body>
</html>
