@page "/Subjects"
@model FPTUniRAG.Pages.SubjectsModel
@{
    Layout = null;
    ViewData["Title"] = "Manage Subjects - FPT UniRAG";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page accounts-page">
    <main class="admin-shell" aria-label="Subject management">
        <aside class="admin-sidebar" aria-label="Admin navigation">
            <a class="admin-logo" href="/AdminDashboard" aria-label="FPT UniRAG dashboard">
                <span class="admin-logo-mark" aria-hidden="true">
                    <span class="material-symbols-outlined">school</span>
                </span>
                <span>
                    <strong>FPT UniRAG</strong>
                    <small>Academic RAG</small>
                </span>
            </a>

            <nav class="admin-nav">
                <a class="admin-nav-item" href="/AdminDashboard">
                    <span class="material-symbols-outlined" aria-hidden="true">dashboard</span>
                    Dashboard
                </a>
                <details class="admin-nav-group" open>
                    <summary class="admin-nav-item active">
                        <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                        Subjects
                        <span class="material-symbols-outlined admin-nav-chevron" aria-hidden="true">expand_more</span>
                    </summary>
                    <div class="admin-subnav">
                        <a class="active" href="/Subjects" aria-current="page">Manage Subjects</a>
                        <a href="/Subjects/AssignTeacher">Assign Teacher</a>
                        <a href="/Subjects/AssignHeader">Assign Header</a>
                    </div>
                </details>
                <a class="admin-nav-item" href="/Accounts">
                    <span class="material-symbols-outlined" aria-hidden="true">groups</span>
                    Accounts
                </a>
                <a class="admin-nav-item" href="/SubscriptionPlans">
                    <span class="material-symbols-outlined" aria-hidden="true">payments</span>
                    Subscription Plans
                </a>
                <a class="admin-nav-item" href="/Analysis">
                    <span class="material-symbols-outlined" aria-hidden="true">analytics</span>
                    Analytics
                </a>
            </nav>

            <section class="admin-sidebar-footer" aria-label="Sidebar actions">
                <a class="admin-sidebar-footer-link" href="#">
                    <span class="material-symbols-outlined" aria-hidden="true">help_outline</span>
                    <span>Help</span>
                </a>
                <a class="admin-sidebar-footer-link" href="/ChangePassword">
                    <span class="material-symbols-outlined" aria-hidden="true">lock</span>
                    <span>Change Password</span>
                </a>
                <a class="admin-sidebar-footer-link" href="/Login?logout=true">
                    <span class="material-symbols-outlined" aria-hidden="true">logout</span>
                    <span>Logout</span>
                </a>
            </section>
        </aside>

        <section class="accounts-main">
            <div class="accounts-canvas">
                <nav class="subject-breadcrumbs" aria-label="Breadcrumb">
                    <a href="/AdminDashboard">Dashboard</a>
                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                    <strong>Subjects</strong>
                </nav>

                <header class="subject-create-header accounts-header">
                    <div>
                        <h1>Subject Management</h1>
                        <p>Manage subject metadata and choose whether each subject uses fixed-size or semantic chunking for future document uploads.</p>
                    </div>
                    <a class="subject-submit-button" href="/Subjects/Create">
                        Create Subject
                        <span class="material-symbols-outlined" aria-hidden="true">add</span>
                    </a>
                </header>

                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                {
                    <div class="accounts-feedback accounts-feedback-success" role="status">
                        @Model.SuccessMessage
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="accounts-feedback accounts-feedback-error" role="alert">
                        @Model.ErrorMessage
                    </div>
                }

                <section class="accounts-card accounts-table-card subject-table-card" aria-labelledby="subject-table-title">
                    <div class="accounts-card-header">
                        <div>
                            <p class="accounts-eyebrow">Current Schema</p>
                            <h2 id="subject-table-title">Subjects</h2>
                        </div>
                        <span class="accounts-card-icon" aria-hidden="true">
                            <span class="material-symbols-outlined">menu_book</span>
                        </span>
                    </div>

                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Subject</th>
                                    <th>Description</th>
                                    <th>Chunking</th>
                                    <th>Created At</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Subjects.Count == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="subject-empty-state">No subjects found.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var subject in Model.Subjects)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@subject.SubjectCode</strong>
                                                <span>@subject.SubjectName</span>
                                            </td>
                                            <td class="subject-description-cell">@(string.IsNullOrWhiteSpace(subject.Description) ? "No description provided." : subject.Description)</td>
                                            <td>
                                                @(subject.DefaultChunkingStrategy == "semantic"
                                                    ? "Semantic chunking"
                                                    : $"Fixed size ({subject.DefaultFixedChunkSize})")
                                            </td>
                                            <td>@(subject.CreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</td>
                                            <td class="admin-user-actions subject-table-actions">
                                                <a class="admin-success-button" asp-page="/Subjects/Edit" asp-route-subjectId="@subject.SubjectId">Edit</a>
                                                <a class="admin-danger-button" asp-page="/Subjects/Delete" asp-route-subjectId="@subject.SubjectId">Delete</a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>
        </section>
    </main>
</body>
</html>
