@page "/Subjects"
@inject IConfiguration Configuration
@{
    Layout = null;
    ViewData["Title"] = "Create New Subject - FPT UniRAG";

    var adminEmail = Configuration["AdminCredentials:Email"] ?? "admin@fpt.edu.vn";
    var adminName = Configuration["AdminCredentials:DisplayName"] ?? "Admin User";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page subject-create-page">
    <main class="admin-shell" aria-label="Create new subject">
        <aside class="admin-sidebar" aria-label="Admin navigation">
            <a class="admin-logo" href="/AdminDashboard" aria-label="FPT UniRAG dashboard">
                <span class="admin-logo-mark" aria-hidden="true">
                    <span class="material-symbols-outlined">school</span>
                </span>
                <span>
                    <strong>FPT UniRAG</strong>
                    <small>Academic RAG</small>
                </span>
            </a>

            <nav class="admin-nav">
                <a class="admin-nav-item" href="/AdminDashboard">
                    <span class="material-symbols-outlined" aria-hidden="true">dashboard</span>
                    Dashboard
                </a>
                <details class="admin-nav-group" open>
                    <summary class="admin-nav-item active">
                        <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                        Subjects
                        <span class="material-symbols-outlined admin-nav-chevron" aria-hidden="true">expand_more</span>
                    </summary>
                    <div class="admin-subnav">
                        <a class="active" href="/Subjects" aria-current="page">New Subject</a>
                        <a href="/Subjects/Delete">Delete Subject</a>
                    </div>
                </details>
                <a class="admin-nav-item" href="/Accounts">
                    <span class="material-symbols-outlined" aria-hidden="true">groups</span>
                    Accounts
                </a>
                <a class="admin-nav-item" href="/Analysis">
                    <span class="material-symbols-outlined" aria-hidden="true">analytics</span>
                    Analytics
                </a>
            </nav>

            <section class="admin-sidebar-footer" aria-label="Sidebar actions">
                <a class="admin-sidebar-footer-link" href="#">
                    <span class="material-symbols-outlined" aria-hidden="true">help_outline</span>
                    <span>Help</span>
                </a>
                <a class="admin-sidebar-footer-link" href="/Login">
                    <span class="material-symbols-outlined" aria-hidden="true">logout</span>
                    <span>Logout</span>
                </a>
            </section>
        </aside>

        <section class="subject-create-main">
            <div class="subject-create-canvas">
                <nav class="subject-breadcrumbs" aria-label="Breadcrumb">
                    <a href="/Subjects">Subjects</a>
                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                    <strong>New Subject</strong>
                </nav>

                <header class="subject-create-header">
                    <div>
                        <h1>Create New Subject</h1>
                        <p>Register a new academic unit into the FPT UniRAG knowledge ecosystem.</p>
                    </div>
                    <a class="subject-close-button" href="/AdminDashboard" aria-label="Close create subject screen">
                        <span class="material-symbols-outlined" aria-hidden="true">close</span>
                    </a>
                </header>

                <section class="subject-form-card" aria-labelledby="create-subject-title">
                    <div class="subject-progress" aria-hidden="true">
                        <span></span>
                    </div>

                    <div class="subject-form-content">
                        <h2 id="create-subject-title" class="visually-hidden">Create subject form</h2>
                        <form class="subject-form" method="post" onsubmit="return false;">
                            <div class="subject-form-grid">
                                <label class="subject-field">
                                    <span>Subject Code</span>
                                    <div class="subject-input-with-icon">
                                        <span class="material-symbols-outlined" aria-hidden="true">tag</span>
                                        <input name="SubjectCode" type="text" placeholder="e.g. PRN211" autocomplete="off" />
                                    </div>
                                    <small>Must be a unique institutional identifier.</small>
                                </label>

                                <label class="subject-field">
                                    <span>Subject Name</span>
                                    <input name="SubjectName" type="text" placeholder="e.g. Advanced Cross-Platform Programming with .NET" autocomplete="off" />
                                </label>
                            </div>

                            <label class="subject-field">
                                <span>Subject Description</span>
                                <textarea name="SubjectDescription" placeholder="Provide a brief overview of the subject syllabus and learning objectives..."></textarea>
                            </label>

                            <footer class="subject-form-actions">
                                <a class="subject-cancel-button" href="/AdminDashboard">Cancel</a>
                                <button class="subject-submit-button" type="submit">
                                    Create Subject
                                    <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                                </button>
                            </footer>
                        </form>
                    </div>
                </section>

                <aside class="subject-help-card" aria-label="Subject creation tip">
                    <span class="subject-help-icon" aria-hidden="true">
                        <span class="material-symbols-outlined">lightbulb</span>
                    </span>
                    <div>
                        <h3>Pro Tip: Knowledge Partitioning</h3>
                        <p>After creating this subject, you'll be prompted to upload relevant PDF files. Our AI engine will automatically vectorise these documents, allowing students to query specific syllabus items instantly.</p>
                    </div>
                </aside>
            </div>
        </section>
    </main>
</body>
</html>
