@page "/Subjects/Delete"
@inject IConfiguration Configuration
@{
    Layout = null;
    ViewData["Title"] = "Delete Subjects - FPT UniRAG";

    var subjects = new[]
    {
        new { Code = "SWD392", Name = "Software Architecture", Owner = "Minh Tran", Status = "Indexed", StatusClass = "success", LastUpdate = "Today, 09:42", Documents = 24 },
        new { Code = "PRN222", Name = ".NET Web Development", Owner = "Hoa Dao", Status = "Ready", StatusClass = "success", LastUpdate = "Yesterday, 15:10", Documents = 18 },
        new { Code = "NWC203", Name = "Computer Networks", Owner = "Quang Nguyen", Status = "Processing", StatusClass = "pending", LastUpdate = "Jul 01, 11:24", Documents = 12 },
        new { Code = "AIL303", Name = "Artificial Intelligence", Owner = "An Le", Status = "Review", StatusClass = "draft", LastUpdate = "Jun 30, 18:02", Documents = 16 }
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page delete-subject-page">
    <main class="admin-shell" aria-label="Delete subjects">
        <aside class="admin-sidebar" aria-label="Admin navigation">
            <a class="admin-logo" href="/AdminDashboard" aria-label="FPT UniRAG dashboard">
                <span class="admin-logo-mark" aria-hidden="true">
                    <span class="material-symbols-outlined">school</span>
                </span>
                <span>
                    <strong>FPT UniRAG</strong>
                    <small>Academic RAG</small>
                </span>
            </a>

            <nav class="admin-nav">
                <a class="admin-nav-item" href="/AdminDashboard">
                    <span class="material-symbols-outlined" aria-hidden="true">dashboard</span>
                    Dashboard
                </a>
                <details class="admin-nav-group" open>
                    <summary class="admin-nav-item active">
                        <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                        Subjects
                        <span class="material-symbols-outlined admin-nav-chevron" aria-hidden="true">expand_more</span>
                    </summary>
                    <div class="admin-subnav">
                        <a href="/Subjects">New Subject</a>
                        <a class="active" href="/Subjects/Delete" aria-current="page">Delete Subject</a>
                    </div>
                </details>
                <a class="admin-nav-item" href="/Accounts">
                    <span class="material-symbols-outlined" aria-hidden="true">groups</span>
                    Accounts
                </a>
                <a class="admin-nav-item" href="/Analysis">
                    <span class="material-symbols-outlined" aria-hidden="true">analytics</span>
                    Analytics
                </a>
            </nav>

            <section class="admin-sidebar-footer" aria-label="Sidebar actions">
                <a class="admin-sidebar-footer-link" href="#">
                    <span class="material-symbols-outlined" aria-hidden="true">help_outline</span>
                    <span>Help</span>
                </a>
                <a class="admin-sidebar-footer-link" href="/Login">
                    <span class="material-symbols-outlined" aria-hidden="true">logout</span>
                    <span>Logout</span>
                </a>
            </section>
        </aside>

        <section class="delete-subject-main">
            <div class="delete-subject-canvas">
                <nav class="subject-breadcrumbs" aria-label="Breadcrumb">
                    <a href="/AdminDashboard">Dashboard</a>
                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                    <a href="/Subjects">Subjects</a>
                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                    <strong>Delete Subject</strong>
                </nav>

                <header class="subject-create-header delete-subject-header">
                    <div>
                        <h1>Delete Subjects</h1>
                        <p>Review existing academic subjects and remove the ones that should no longer stay in the knowledge base.</p>
                    </div>
                </header>

                <section class="delete-subject-panel" aria-labelledby="delete-subject-list-title">
                    <div class="delete-subject-panel-header">
                        <div>
                            <h2 id="delete-subject-list-title">Current subjects</h2>
                            <p>Each subject card includes the current owner, index status, and a delete action for admin control.</p>
                        </div>
                        <span class="delete-subject-count">@subjects.Length subjects</span>
                    </div>

                    <div class="delete-subject-grid">
                        @foreach (var subject in subjects)
                        {
                            <article class="delete-subject-card">
                                <div class="delete-subject-card-top">
                                    <div>
                                        <strong>@subject.Code</strong>
                                        <h3>@subject.Name</h3>
                                    </div>
                                    <span class="admin-badge @subject.StatusClass">@subject.Status</span>
                                </div>

                                <dl class="delete-subject-meta">
                                    <div>
                                        <dt>Owner</dt>
                                        <dd>@subject.Owner</dd>
                                    </div>
                                    <div>
                                        <dt>Documents</dt>
                                        <dd>@subject.Documents files</dd>
                                    </div>
                                    <div>
                                        <dt>Last update</dt>
                                        <dd>@subject.LastUpdate</dd>
                                    </div>
                                </dl>

                                <div class="delete-subject-actions">
                                    <button class="admin-danger-button delete-subject-button" type="button">
                                        <span class="material-symbols-outlined" aria-hidden="true">delete</span>
                                        Delete Subject
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                </section>
            </div>
        </section>
    </main>
</body>
</html>
