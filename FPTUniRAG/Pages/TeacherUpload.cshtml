@page "/TeacherUpload"
@model FPTUniRAG.Pages.TeacherUploadModel
@{
    Layout = null;
    ViewData["Title"] = "Upload Document - FPT UniRAG";
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Manrope:wght@600;700&amp;display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
</head>
<body class="min-h-screen bg-slate-50 text-slate-900 font-[Inter]">
    <main class="mx-auto max-w-5xl px-6 py-10">
        <div class="mb-8 flex items-center justify-between gap-4">
            <div>
                <p class="text-sm font-medium text-blue-700">Teacher Upload</p>
                <h1 class="mt-2 font-[Manrope] text-3xl font-bold">
                    @(Model.UploadContext is null ? "Upload Document" : $"{Model.UploadContext.SubjectCode} · {Model.UploadContext.SubjectName}")
                </h1>
                <p class="mt-2 max-w-2xl text-sm text-slate-600">
                    Only subjects where you are the header teacher can upload documents. Each chapter can store one document.
                </p>
            </div>
            <div class="flex gap-3">
                <a class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700" href="/TeacherDocuments">Document Management</a>
                <a class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white" href="/TeacherHome">Back Home</a>
            </div>
        </div>

        @if (Model.UploadContext is null)
        {
            <div class="rounded-2xl border border-amber-200 bg-amber-50 p-6 text-sm text-amber-900">
                This subject is unavailable for upload or you are not the header teacher for it.
            </div>
        }
        else
        {
            <div class="grid gap-6 lg:grid-cols-[1.35fr,0.65fr]">
                <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                    @if (!ViewContext.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="mb-5 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800"></div>
                    }

                    <form method="post" enctype="multipart/form-data" class="space-y-5">
                        <input asp-for="Input.SubjectId" type="hidden" />

                        <div>
                            <label asp-for="Input.Title" class="mb-2 block text-sm font-semibold text-slate-800"></label>
                            <input asp-for="Input.Title" class="block w-full rounded-xl border-slate-300 bg-slate-50 px-4 py-3 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Lecture 3 - Dynamic Programming Overview" />
                            <span asp-validation-for="Input.Title" class="mt-1 block text-sm text-rose-700"></span>
                        </div>

                        <div>
                            <label asp-for="Input.ChapterTitle" class="mb-2 block text-sm font-semibold text-slate-800"></label>
                            <input asp-for="Input.ChapterTitle" class="block w-full rounded-xl border-slate-300 bg-slate-50 px-4 py-3 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Chapter 3 - Dynamic Programming" />
                            <p class="mt-2 text-xs text-slate-500">If the chapter does not exist yet, the system will create it for this subject.</p>
                            <span asp-validation-for="Input.ChapterTitle" class="mt-1 block text-sm text-rose-700"></span>
                        </div>

                        <div>
                            <label asp-for="Input.File" class="mb-2 block text-sm font-semibold text-slate-800"></label>
                            <input asp-for="Input.File" class="block w-full rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm file:mr-4 file:rounded-lg file:border-0 file:bg-blue-600 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-blue-700" />
                            <p class="mt-2 text-xs text-slate-500">Allowed file types: @string.Join(", ", Model.UploadContext.AllowedFileTypes)</p>
                            <span asp-validation-for="Input.File" class="mt-1 block text-sm text-rose-700"></span>
                        </div>

                        <div class="flex items-center justify-end gap-3 pt-4">
                            <a class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700" href="/TeacherDocuments">Cancel</a>
                            <button class="rounded-xl bg-blue-700 px-5 py-2.5 text-sm font-semibold text-white hover:bg-blue-800" type="submit">Upload and Generate Chunks</button>
                        </div>
                    </form>
                </section>

                <aside class="space-y-4">
                    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                        <h2 class="font-[Manrope] text-lg font-bold text-slate-900">Current Ingestion Settings</h2>
                        <dl class="mt-4 space-y-3 text-sm">
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-slate-500">Chunking</dt>
                                <dd class="font-semibold text-slate-900">@Model.ChunkingStrategyLabel</dd>
                            </div>
                            @if (Model.UploadContext?.DefaultChunkingStrategy == "semantic")
                            {
                                <div class="flex items-center justify-between gap-4">
                                    <dt class="text-slate-500">Max Chunk Size</dt>
                                    <dd class="font-semibold text-slate-900">@Model.SemanticMaxChunkSize</dd>
                                </div>
                                <div class="flex items-center justify-between gap-4">
                                    <dt class="text-slate-500">Min Chunk Size</dt>
                                    <dd class="font-semibold text-slate-900">@Model.SemanticMinChunkSize</dd>
                                </div>
                            }
                            else
                            {
                                <div class="flex items-center justify-between gap-4">
                                    <dt class="text-slate-500">Chunk Size</dt>
                                    <dd class="font-semibold text-slate-900">@Model.FixedChunkSize</dd>
                                </div>
                                <div class="flex items-center justify-between gap-4">
                                    <dt class="text-slate-500">Chunk Overlap</dt>
                                    <dd class="font-semibold text-slate-900">@Model.FixedChunkOverlap</dd>
                                </div>
                            }
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-slate-500">Embedding Model</dt>
                                <dd class="text-right font-semibold text-slate-900">@Model.EmbeddingModel</dd>
                            </div>
                        </dl>
                    </section>

                    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                        <h2 class="font-[Manrope] text-lg font-bold text-slate-900">Subject Notes</h2>
                        <p class="mt-3 text-sm leading-6 text-slate-600">
                            @(string.IsNullOrWhiteSpace(Model.UploadContext?.SubjectDescription)
                                ? "No subject description is currently set."
                                : Model.UploadContext.SubjectDescription)
                        </p>
                    </section>
                </aside>
            </div>
        }
    </main>
</body>
</html>
