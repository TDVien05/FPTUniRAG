@page "/ChangePassword"
@model FPTUniRAG.Pages.ChangePasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Change Password - FPT UniRAG";
    var backLink = Model.Role == "teacher" ? "/TeacherHome" : "/StudentDashboard";
    var backLabel = Model.Role == "teacher" ? "Teacher dashboard" : "Student dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page accounts-page">
    <main class="admin-shell" aria-label="Change password">
        <section class="accounts-main" style="margin-left:0; width:100%;">
            <div class="accounts-canvas" style="max-width:720px;">
                <nav class="subject-breadcrumbs" aria-label="Breadcrumb">
                    <a href="@backLink">@backLabel</a>
                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                    <strong>Change Password</strong>
                </nav>

                <header class="subject-create-header accounts-header">
                    <div>
                        <h1>Change Password</h1>
                        <p>Update your password for this account. Your current password is required.</p>
                    </div>
                </header>

                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                {
                    <div class="accounts-feedback accounts-feedback-success" role="status">
                        @Model.SuccessMessage
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="ModelOnly" class="accounts-feedback accounts-feedback-error" role="alert"></div>
                }

                <section class="accounts-card" aria-labelledby="change-password-title">
                    <div class="accounts-card-header">
                        <div>
                            <p class="accounts-eyebrow">Account Security</p>
                            <h2 id="change-password-title">Password details</h2>
                        </div>
                        <span class="accounts-card-icon" aria-hidden="true">
                            <span class="material-symbols-outlined">lock</span>
                        </span>
                    </div>

                    <form class="accounts-form" method="post">
                        <label class="subject-field">
                            <span>Current Password</span>
                            <input asp-for="Input.CurrentPassword" type="password" autocomplete="current-password" />
                            <span asp-validation-for="Input.CurrentPassword" class="accounts-field-error"></span>
                        </label>

                        <label class="subject-field">
                            <span>New Password</span>
                            <input asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
                            <span asp-validation-for="Input.NewPassword" class="accounts-field-error"></span>
                        </label>

                        <label class="subject-field">
                            <span>Confirm New Password</span>
                            <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="accounts-field-error"></span>
                        </label>

                        <footer class="subject-form-actions accounts-actions">
                            <a class="admin-success-button" href="@backLink">Back</a>
                            <button class="subject-submit-button" type="submit">
                                Update Password
                                <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                            </button>
                        </footer>
                    </form>
                </section>
            </div>
        </section>
    </main>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
