@page "/ChangePassword"
@model FPTUniRAG.Pages.ChangePasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Change Password - FPT UniRAG";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .change-password-page {
            min-height: 100vh;
            margin: 0;
            background:
                radial-gradient(circle at top left, rgba(208, 225, 251, 0.7), transparent 34%),
                linear-gradient(180deg, #f7f9ff 0%, #eef4ff 100%);
            color: #111c2d;
            font-family: Inter, system-ui, sans-serif;
        }

        .change-password-shell {
            width: min(1180px, 100%);
            margin: 0 auto;
            padding: 40px 20px 56px;
        }

        .change-password-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 28px;
        }

        .change-password-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #005bbf;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
        }

        .change-password-back:hover {
            text-decoration: underline;
        }

        .change-password-role {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 36px;
            padding: 0 14px;
            border: 1px solid #d0e1fb;
            border-radius: 999px;
            background: rgba(208, 225, 251, 0.5);
            color: #005bbf;
            font-size: 13px;
            font-weight: 700;
        }

        .change-password-grid {
            display: grid;
            grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
            gap: 24px;
            align-items: start;
        }

        .change-password-panel,
        .change-password-card {
            border: 1px solid rgba(193, 198, 214, 0.45);
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
            backdrop-filter: blur(16px);
        }

        .change-password-panel {
            padding: 28px;
        }

        .change-password-panel h1,
        .change-password-card h2 {
            margin: 0;
            font-family: Manrope, Inter, sans-serif;
            color: #111c2d;
        }

        .change-password-panel h1 {
            font-size: 34px;
            font-weight: 800;
            line-height: 1.15;
        }

        .change-password-panel p {
            margin: 10px 0 0;
            color: #54647a;
            font-size: 15px;
            line-height: 1.65;
        }

        .change-password-user {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-top: 28px;
            padding: 16px;
            border-radius: 14px;
            background: #f4f7ff;
        }

        .change-password-avatar {
            width: 52px;
            height: 52px;
            flex: 0 0 52px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 16px;
            background: #005bbf;
            color: #ffffff;
            font-size: 20px;
            font-weight: 800;
        }

        .change-password-user strong {
            display: block;
            color: #111c2d;
            font-size: 15px;
        }

        .change-password-user span,
        .change-password-user small {
            display: block;
            color: #64748b;
            font-size: 13px;
            line-height: 1.5;
        }

        .change-password-note {
            margin-top: 18px;
            padding: 16px;
            border-radius: 14px;
            background: #fff9eb;
            color: #92400e;
            font-size: 13px;
            line-height: 1.6;
        }

        .change-password-card {
            padding: 32px;
        }

        .change-password-card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 22px;
        }

        .change-password-card-header p {
            margin: 6px 0 0;
            color: #64748b;
            font-size: 14px;
            line-height: 1.6;
        }

        .change-password-card-icon {
            width: 52px;
            height: 52px;
            flex: 0 0 52px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 16px;
            background: #e7eeff;
            color: #005bbf;
        }

        .change-password-form {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .change-password-field {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .change-password-field > span {
            color: #414754;
            font-size: 14px;
            font-weight: 700;
        }

        .change-password-field input {
            min-height: 48px;
            padding: 10px 14px;
            border: 1px solid #c1c6d6;
            border-radius: 14px;
            background: #f9fbff;
            color: #111c2d;
            font: inherit;
            font-size: 15px;
            outline: 0;
            transition: border-color 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
        }

        .change-password-field input:focus {
            border-color: #005bbf;
            box-shadow: 0 0 0 3px rgba(0, 91, 191, 0.12);
            background: #ffffff;
        }

        .change-password-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 14px;
            margin-top: 8px;
        }

        .change-password-secondary,
        .change-password-primary {
            min-height: 46px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 0 20px;
            border-radius: 14px;
            font: inherit;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
            transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease;
        }

        .change-password-secondary {
            border: 1px solid #d0d7e7;
            background: #ffffff;
            color: #54647a;
        }

        .change-password-secondary:hover {
            background: #f4f7ff;
            color: #111c2d;
        }

        .change-password-primary {
            border: 1px solid #005bbf;
            background: #005bbf;
            color: #ffffff;
        }

        .change-password-primary:hover {
            background: #004da1;
            border-color: #004da1;
        }

        .change-password-primary:active {
            transform: scale(0.98);
        }

        .change-password-feedback {
            margin-bottom: 18px;
        }

        @@media (max-width: 900px) {
            .change-password-grid {
                grid-template-columns: 1fr;
            }

            .change-password-topbar,
            .change-password-card-header,
            .change-password-actions {
                align-items: stretch;
                flex-direction: column;
            }

            .change-password-primary,
            .change-password-secondary {
                width: 100%;
            }
        }
    </style>
</head>
<body class="change-password-page">
    <main class="change-password-shell" aria-label="Change password">
        <div class="change-password-topbar">
            @if (!Model.IsPasswordChangeRequired)
            {
                <a class="change-password-back" href="@Model.BackLink">
                    <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
                    Back to @Model.BackLabel
                </a>
            }
            else
            {
                <span></span>
            }
            <span class="change-password-role">
                <span class="material-symbols-outlined" aria-hidden="true">shield_lock</span>
                @Model.RoleLabel
            </span>
        </div>

        <div class="change-password-grid">
            <section class="change-password-panel" aria-labelledby="change-password-overview">
                <h1 id="change-password-overview">Update your password</h1>
                <p>Use your current password to confirm ownership of this account, then set a new password with at least 8 characters.</p>

                <div class="change-password-user">
                    <div class="change-password-avatar" aria-hidden="true">
                        @(string.IsNullOrWhiteSpace(Model.DisplayName) ? "U" : Model.DisplayName[0].ToString().ToUpperInvariant())
                    </div>
                    <div>
                        <strong>@Model.DisplayName</strong>
                        <span>@Model.Email</span>
                        <small>@Model.RoleLabel account</small>
                    </div>
                </div>

                <div class="change-password-note">
                    @(Model.IsPasswordChangeRequired
                        ? "You must replace the temporary password before using your account."
                        : "After changing your password, your current signed-in session stays active and the updated credentials apply to your next sign-in on all roles.")
                </div>
            </section>

            <section class="change-password-card" aria-labelledby="change-password-form-title">
                <div class="change-password-card-header">
                    <div>
                        <h2 id="change-password-form-title">Password details</h2>
                        <p>This flow is shared across admin, teacher, and student accounts.</p>
                    </div>
                    <span class="change-password-card-icon" aria-hidden="true">
                        <span class="material-symbols-outlined">lock</span>
                    </span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                {
                    <div class="accounts-feedback accounts-feedback-success change-password-feedback" role="status">
                        @Model.SuccessMessage
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="ModelOnly" class="accounts-feedback accounts-feedback-error change-password-feedback" role="alert"></div>
                }

                <form class="change-password-form" method="post">
                    <label class="change-password-field">
                        <span>Current Password</span>
                        <input asp-for="Input.CurrentPassword" type="password" autocomplete="current-password" />
                        <span asp-validation-for="Input.CurrentPassword" class="accounts-field-error"></span>
                    </label>

                    <label class="change-password-field">
                        <span>New Password</span>
                        <input asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
                        <span asp-validation-for="Input.NewPassword" class="accounts-field-error"></span>
                    </label>

                    <label class="change-password-field">
                        <span>Confirm New Password</span>
                        <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="accounts-field-error"></span>
                    </label>

                    <div class="change-password-actions">
                        @if (!Model.IsPasswordChangeRequired)
                        {
                            <a class="change-password-secondary" href="@Model.BackLink">Cancel</a>
                        }
                        <button class="change-password-primary" type="submit">
                            Save New Password
                            <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                        </button>
                    </div>
                </form>
            </section>
        </div>
    </main>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
