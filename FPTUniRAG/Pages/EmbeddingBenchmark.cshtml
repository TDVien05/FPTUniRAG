@page "/EmbeddingBenchmark"
@model FPTUniRAG.Pages.EmbeddingBenchmarkModel
@using System.Globalization
@{
    Layout = null;
    ViewData["Title"] = "Embedding Benchmark - FPT UniRAG";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined&display=block" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page accounts-page">
    <main class="admin-shell" aria-label="Embedding benchmark">
        <aside class="admin-sidebar" aria-label="Admin navigation">
            <a class="admin-logo" href="/AdminDashboard" aria-label="FPT UniRAG dashboard">
                <span class="admin-logo-mark"><span class="material-symbols-outlined">school</span></span>
                <span><strong>FPT UniRAG</strong><small>Academic RAG</small></span>
            </a>
            <nav class="admin-nav">
                <a class="admin-nav-item" href="/AdminDashboard"><span class="material-symbols-outlined">dashboard</span>Dashboard</a>
                <a class="admin-nav-item" href="/Accounts"><span class="material-symbols-outlined">groups</span>Accounts</a>
                <a class="admin-nav-item" href="/SubscriptionPlans"><span class="material-symbols-outlined">payments</span>Subscription Plans</a>
                <a class="admin-nav-item" href="/EmbeddingSettings"><span class="material-symbols-outlined">tune</span>Embedding Settings</a>
                <a class="admin-nav-item active" href="/EmbeddingBenchmark" aria-current="page"><span class="material-symbols-outlined">speed</span>Embedding Benchmark</a>
                <a class="admin-nav-item" href="/Analysis"><span class="material-symbols-outlined">analytics</span>Analytics</a>
            </nav>
            <section class="admin-sidebar-footer">
                <a class="admin-sidebar-footer-link" href="/ChangePassword"><span class="material-symbols-outlined">lock</span><span>Change Password</span></a>
                <a class="admin-sidebar-footer-link" href="/Logout"><span class="material-symbols-outlined">logout</span><span>Logout</span></a>
            </section>
        </aside>
        <section class="accounts-main">
            <div class="accounts-canvas">
                <header class="accounts-header">
                    <div>
                        <p class="accounts-eyebrow">Embedding operations</p>
                        <h1>Embedding Benchmark</h1>
                        <p>Performance summary from documents that have been embedded by each model.</p>
                    </div>
                </header>

                <section class="accounts-card">
                    <div class="accounts-card-header">
                        <div>
                            <h2>Model comparison</h2>
                            <p>Metrics are based on the latest successful embedding run for each document and model.</p>
                        </div>
                    </div>
                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Model</th>
                                    <th>Documents</th>
                                    <th>Chunks</th>
                                    <th>Vectors</th>
                                    <th>Dimensions</th>
                                    <th>Completion</th>
                                    <th>Document size</th>
                                    <th>Avg. time</th>
                                    <th>Last embedded</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var row in Model.Rows)
                            {
                                <tr>
                                    <td><strong>@row.Model</strong><span>@(row.HasData ? "Data available" : "No data yet")</span></td>
                                    @if (!row.HasData)
                                    {
                                        <td colspan="8"><span class="text-secondary">No document has been embedded with this model.</span></td>
                                    }
                                    else
                                    {
                                        <td>@row.DocumentCount.ToString("N0")</td>
                                        <td>@row.ChunkCount.ToString("N0")</td>
                                        <td>@row.VectorCount.ToString("N0")</td>
                                        <td>@row.Dimensions.ToString("N0")</td>
                                        <td>@row.CompletionRate.ToString("0.##", CultureInfo.InvariantCulture)%</td>
                                        <td>@FormatBytes(row.DocumentSizeBytes)</td>
                                        <td>@(row.AverageDurationMs is null ? "—" : $"{row.AverageDurationMs.Value / 1000:0.##} s")</td>
                                        <td>@(row.LatestEmbeddedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                                    }
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </section>
                <p class="text-secondary" style="margin-top: 16px;">Retries and re-embeddings are retained in history; totals use the latest successful run per document and model.</p>
            </div>
        </section>
    </main>
</body>
</html>

@functions {
    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes:N0} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024d:0.##} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024d * 1024):0.##} MB";
        return $"{bytes / (1024d * 1024 * 1024):0.##} GB";
    }
}
