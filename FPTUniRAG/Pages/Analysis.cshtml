@page "/Analysis"
@model FPTUniRAG.Pages.AnalysisModel
@using System.Globalization
@{
    Layout = null;
    ViewData["Title"] = "Admin Analytics & User Usage - FPT UniRAG";
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;family=Manrope:wght@600;700&amp;family=JetBrains+Mono&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        try {
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            "primary-fixed-dim": "#adc7ff",
                            "primary": "#005bbf",
                            "secondary": "#505f76",
                            "tertiary-fixed-dim": "#c4c7c9",
                            "secondary-fixed": "#d3e4fe",
                            "on-error": "#ffffff",
                            "on-primary-fixed-variant": "#004493",
                            "on-tertiary-container": "#ffffff",
                            "on-secondary": "#ffffff",
                            "surface-tint": "#005bc0",
                            "on-primary-fixed": "#001a41",
                            "on-primary-container": "#ffffff",
                            "inverse-primary": "#adc7ff",
                            "surface-bright": "#f9f9ff",
                            "inverse-on-surface": "#ecf1ff",
                            "tertiary-fixed": "#e0e3e5",
                            "background": "#f9f9ff",
                            "on-secondary-fixed": "#0b1c30",
                            "on-secondary-fixed-variant": "#38485d",
                            "on-tertiary-fixed": "#191c1e",
                            "primary-container": "#1a73e8",
                            "on-surface": "#111c2d",
                            "outline-variant": "#c1c6d6",
                            "surface": "#f9f9ff",
                            "on-primary": "#ffffff",
                            "on-tertiary-fixed-variant": "#444749",
                            "on-secondary-container": "#54647a",
                            "secondary-container": "#d0e1fb",
                            "on-surface-variant": "#414754",
                            "surface-container-lowest": "#ffffff",
                            "surface-container-highest": "#d8e3fb",
                            "surface-container": "#e7eeff",
                            "error-container": "#ffdad6",
                            "primary-fixed": "#d8e2ff",
                            "on-tertiary": "#ffffff",
                            "inverse-surface": "#263143",
                            "surface-container-low": "#f0f3ff",
                            "error": "#ba1a1a",
                            "tertiary-container": "#747779",
                            "surface-container-high": "#dee8ff",
                            "on-background": "#111c2d",
                            "surface-dim": "#cfdaf2",
                            "outline": "#727785",
                            "tertiary": "#5b5e60",
                            "secondary-fixed-dim": "#b7c8e1",
                            "on-error-container": "#93000a",
                            "surface-variant": "#d8e3fb"
                        },
                        borderRadius: {
                            "DEFAULT": "0.25rem",
                            "lg": "0.5rem",
                            "xl": "0.75rem",
                            "full": "9999px"
                        },
                        spacing: {
                            "margin-desktop": "32px",
                            "container-max": "1280px",
                            "margin-mobile": "16px",
                            "gutter": "24px",
                            "base": "8px"
                        },
                        fontFamily: {
                            "label-md": ["Inter"],
                            "label-sm": ["Inter"],
                            "headline-lg": ["Manrope"],
                            "body-lg": ["Inter"],
                            "headline-xl": ["Manrope"],
                            "headline-lg-mobile": ["Manrope"],
                            "body-md": ["Inter"],
                            "code": ["JetBrains Mono"]
                        },
                        fontSize: {
                            "label-md": ["14px", { "lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500" }],
                            "label-sm": ["12px", { "lineHeight": "1.2", "fontWeight": "600" }],
                            "headline-lg": ["32px", { "lineHeight": "1.25", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                            "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                            "headline-xl": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                            "headline-lg-mobile": ["24px", { "lineHeight": "1.3", "fontWeight": "600" }],
                            "body-md": ["16px", { "lineHeight": "1.5", "fontWeight": "400" }],
                            "body-sm": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }],
                            "headline-md": ["24px", { "lineHeight": "1.4", "fontWeight": "600" }],
                            "code": ["14px", { "lineHeight": "1.6", "fontWeight": "400" }]
                        }
                    }
                }
            };
        } catch (_e) { }
    </script>
</head>
<body class="admin-dashboard-page bg-background text-on-background overflow-x-hidden">
    <main class="admin-shell" aria-label="Platform analytics">
        <aside class="admin-sidebar" aria-label="Admin navigation">
            <a class="admin-logo" href="/AdminDashboard" aria-label="FPT UniRAG dashboard">
                <span class="admin-logo-mark" aria-hidden="true"><span class="material-symbols-outlined">school</span></span>
                <span><strong>FPT UniRAG</strong><small>Academic RAG</small></span>
            </a>

            <nav class="admin-nav">
                <a class="admin-nav-item" href="/AdminDashboard"><span class="material-symbols-outlined" aria-hidden="true">dashboard</span>Dashboard</a>
                <details class="admin-nav-group">
                    <summary class="admin-nav-item"><span class="material-symbols-outlined" aria-hidden="true">menu_book</span>Subjects<span class="material-symbols-outlined admin-nav-chevron" aria-hidden="true">expand_more</span></summary>
                    <div class="admin-subnav">
                        <a href="/Subjects">Manage Subjects</a>
                        <a href="/Subjects/AssignTeacher">Assign Teacher</a>
                        <a href="/Subjects/AssignHeader">Assign Header</a>
                    </div>
                </details>
                <a class="admin-nav-item" href="/Accounts"><span class="material-symbols-outlined" aria-hidden="true">groups</span>Accounts</a>
                <a class="admin-nav-item" href="/SubscriptionPlans"><span class="material-symbols-outlined" aria-hidden="true">payments</span>Subscription Plans</a>
                <a class="admin-nav-item active" href="/Analysis" aria-current="page"><span class="material-symbols-outlined" aria-hidden="true">analytics</span>Analytics</a>
            </nav>

            <section class="admin-sidebar-footer" aria-label="Sidebar actions">
                <a class="admin-sidebar-footer-link" href="#"><span class="material-symbols-outlined" aria-hidden="true">help_outline</span><span>Help</span></a>
                <a class="admin-sidebar-footer-link" href="/ChangePassword"><span class="material-symbols-outlined" aria-hidden="true">lock</span><span>Change Password</span></a>
                <a class="admin-sidebar-footer-link" href="/Logout"><span class="material-symbols-outlined" aria-hidden="true">logout</span><span>Logout</span></a>
            </section>
        </aside>

        <section class="admin-main min-h-screen pb-10">
        <header class="sticky top-0 z-30 bg-surface/80 backdrop-blur-md border-b border-outline-variant/30 h-16 flex items-center shadow-sm">
            <div class="flex items-center justify-between px-8 w-full h-16">
                <div class="flex items-center gap-6 flex-1">
                    <div class="relative w-full max-w-md hidden sm:block">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-secondary">search</span>
                        <input class="w-full pl-10 pr-4 py-2 bg-surface-container-low border-none rounded-full text-body-sm font-body-sm focus:ring-2 focus:ring-primary/20 transition-all" placeholder="Search analytics, subjects..." type="text" />
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <button class="w-10 h-10 rounded-full flex items-center justify-center text-secondary hover:bg-surface-container-low transition-all" type="button">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>
                    <button class="w-10 h-10 rounded-full flex items-center justify-center text-secondary hover:bg-surface-container-low transition-all" type="button">
                        <span class="material-symbols-outlined">settings</span>
                    </button>
                    <div class="h-8 w-[1px] bg-outline-variant/30 mx-1"></div>
                    <div class="flex items-center gap-2 cursor-pointer hover:bg-surface-container-low p-1 rounded-full transition-all">
                        <img class="w-8 h-8 rounded-full border border-primary/20 object-cover" alt="Admin User" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC8sYnbJAHq94QvxdRgg6AC1K0uAtUBuA2P4mZALzC2n0i4SqdBx9M529cGIA2WkS8DP8WsSfgr29CzQu5VF_IKCHuqdPM8zyLkgVs_dbpqpABVHXhwPnkzzgrpkliaUcfKSSSmxUnzu3aGeYdNJkt2BJPZyvxEBDgQQ7bsgtgjiSTAWJEW3fvsLH3UN689nLJMiJNJbBB0sF08RxYpgJaXzDtU6NQrAUIXVwxyHfq7pLOdeQMLxViZEcZFsbxwPMpfP_llGPwA85Tf" />
                        <span class="font-label-md text-label-md hidden lg:block text-on-surface">Admin User</span>
                    </div>
                </div>
            </div>
        </header>

        <div class="pt-24 px-8 w-full">
            <div class="flex items-center gap-2 text-secondary font-label-sm text-label-sm mb-6">
                <span>Management</span>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <span class="text-primary font-bold">Analytics</span>
            </div>

            <section class="mb-10">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h2 class="font-headline-md text-headline-md text-on-surface">Platform Analytics</h2>
                        <p class="text-secondary font-body-sm text-body-sm">Monitor system usage and token consumption for @Model.SelectedPeriodLabel.ToLowerInvariant()</p>
                    </div>
                    <div class="flex bg-surface-container-low p-1 rounded-lg">
                        <a class="px-4 py-1.5 text-label-sm font-label-sm rounded-md @(Model.SelectedPeriod == "day" ? "bg-white shadow-sm text-primary" : "text-secondary hover:text-on-surface")" href="/Analysis?period=day">Day</a>
                        <a class="px-4 py-1.5 text-label-sm font-label-sm rounded-md @(Model.SelectedPeriod == "month" ? "bg-white shadow-sm text-primary" : "text-secondary hover:text-on-surface")" href="/Analysis?period=month">Month</a>
                        <a class="px-4 py-1.5 text-label-sm font-label-sm rounded-md @(Model.SelectedPeriod == "year" ? "bg-white shadow-sm text-primary" : "text-secondary hover:text-on-surface")" href="/Analysis?period=year">Year</a>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                    <div class="lg:col-span-4 flex flex-col gap-6">
                        <div class="bg-white rounded-xl border border-outline-variant/30 p-6 shadow-sm">
                            <p class="text-secondary font-label-md text-label-md uppercase tracking-wider mb-1">Active Subscribers</p>
                            <div class="flex items-end gap-2 mb-2">
                                <h3 class="text-headline-lg font-headline-lg text-on-surface">@Model.ActiveSubscriberCount.ToString("N0")</h3>
                            </div>
                            <p class="text-secondary font-body-sm text-body-sm">Students with an active plan</p>
                        </div>

                        <div class="bg-white rounded-xl border border-outline-variant/30 p-6 shadow-sm">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <p class="text-secondary font-label-md text-label-md uppercase tracking-wider mb-1">Paid Purchases · @Model.SelectedPeriodLabel</p>
                                    <h3 class="text-headline-lg font-headline-lg text-on-surface">@Model.PaidPurchaseCount.ToString("N0")</h3>
                                </div>
                                <span class="material-symbols-outlined text-primary">database</span>
                            </div>
                            <div class="flex justify-between text-label-sm mb-1">
                                <span class="text-secondary">Revenue</span>
                                <span class="text-secondary">@Model.PaidRevenue.ToString("N0") VND</span>
                            </div>
                            <div class="w-full bg-surface-container h-2 rounded-full overflow-hidden">
                                <div class="bg-primary h-full w-full"></div>
                            </div>
                        </div>
                    </div>

                    <div class="lg:col-span-8 bg-white rounded-xl border border-outline-variant/30 p-6 shadow-sm">
                        <div class="flex items-center justify-between mb-6">
                            <h4 class="font-label-md text-label-md text-on-surface">Token Usage Trend</h4>
                            <span class="material-symbols-outlined text-secondary cursor-pointer">more_vert</span>
                        </div>
                        <div class="h-48 w-full flex items-end gap-1 px-2">
                            @foreach (var point in Model.TokenUsageTrend)
                            {
                                <div class="group relative flex-1 min-w-[1px] h-full flex items-end" title="@point.Label: @point.TotalTokens.ToString("N0") tokens">
                                    <div class="w-full min-h-px rounded-t bg-primary/20 transition-all group-hover:bg-primary" style="height: @point.Percentage.ToString("0.##", CultureInfo.InvariantCulture)%;"></div>
                                </div>
                            }
                        </div>
                        <div class="flex justify-between mt-4 text-[10px] text-secondary uppercase font-bold px-2 gap-2">
                            @foreach (var point in Model.TokenUsageTrend)
                            {
                                <span class="truncate">@point.Label</span>
                            }
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-10 bg-white rounded-xl border border-outline-variant/30 overflow-hidden shadow-sm">
                <div class="p-6 border-b border-outline-variant/10 flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h2 class="font-headline-md text-headline-md text-on-surface">Subscription Purchases by Plan</h2>
                        <p class="text-secondary font-body-sm text-body-sm">Track active students, successful purchases, and paid revenue for @Model.SelectedPeriodLabel.ToLowerInvariant().</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-secondary text-sm">search</span>
                            <input class="pl-9 pr-4 py-2 bg-surface-container-low border-none rounded-lg text-label-sm focus:ring-2 focus:ring-primary/20 w-64" placeholder="Search students..." type="text" />
                        </div>
                        <button class="flex items-center gap-2 px-4 py-2 border border-outline-variant/30 rounded-lg text-label-sm font-medium text-secondary hover:bg-surface-container-low transition-all" type="button">
                            <span class="material-symbols-outlined text-[18px]">download</span>
                            Export
                        </button>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-surface-container-low/50 border-b border-outline-variant/10">
                            <tr class="text-secondary font-label-sm text-label-sm uppercase tracking-wider">
                                <th class="px-6 py-4 font-medium">Subscription Plan</th>
                                <th class="px-6 py-4 font-medium">Price</th>
                                <th class="px-6 py-4 font-medium">Active Students</th>
                                <th class="px-6 py-4 font-medium">Paid Purchases</th>
                                <th class="px-6 py-4 font-medium">Revenue</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/10">
                            @if (Model.PlanAnalytics.Count == 0)
                            {
                                <tr>
                                    <td class="px-6 py-8 text-secondary text-sm" colspan="5">No subscription plans have been configured.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var plan in Model.PlanAnalytics)
                                {
                                    <tr class="hover:bg-surface-container-low/30 transition-all">
                                        <td class="px-6 py-4 font-medium text-on-surface">@plan.PlanName</td>
                                        <td class="px-6 py-4 text-secondary">@plan.MonthlyPrice.ToString("N0") VND</td>
                                        <td class="px-6 py-4 text-on-surface">@plan.ActiveStudentCount.ToString("N0")</td>
                                        <td class="px-6 py-4 text-on-surface">@plan.PaidPurchaseCount.ToString("N0")</td>
                                        <td class="px-6 py-4 text-on-surface">@plan.PaidRevenue.ToString("N0") VND</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="p-4 border-t border-outline-variant/10 flex justify-center">
                    <span class="text-secondary font-label-sm text-label-sm">Purchase and revenue data is calculated from successful Stripe Sandbox payments in the selected period.</span>
                </div>
            </section>
        </div>
        </section>
    </main>

    <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-surface/90 border-t border-outline-variant/10 px-4 py-2 flex justify-around items-center z-50">
        <button class="flex flex-col items-center gap-1 text-secondary" type="button">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[10px] font-medium">Home</span>
        </button>
        <button class="flex flex-col items-center gap-1 text-secondary" type="button">
            <span class="material-symbols-outlined">school</span>
            <span class="text-[10px] font-medium">Courses</span>
        </button>
        <div class="relative -top-6">
            <button class="w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg shadow-primary/30" type="button">
                <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>add</span>
            </button>
        </div>
        <button class="flex flex-col items-center gap-1 text-primary font-bold" type="button">
            <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>admin_panel_settings</span>
            <span class="text-[10px] font-medium">Admin</span>
        </button>
        <button class="flex flex-col items-center gap-1 text-secondary" type="button">
            <span class="material-symbols-outlined">person</span>
            <span class="text-[10px] font-medium">Profile</span>
        </button>
    </nav>
</body>
</html>
