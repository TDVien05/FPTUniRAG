@page "/Accounts"
@model FPTUniRAG.Pages.AccountsModel
@{
    Layout = null;
    ViewData["Title"] = "Accounts - FPT UniRAG";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page accounts-page">
    <main class="admin-shell" aria-label="Account management">
        @await Html.PartialAsync("_AdminNavigation")
        @* <aside class="admin-sidebar" aria-label="Admin navigation">
            <a class="admin-logo" href="/AdminDashboard" aria-label="FPT UniRAG dashboard">
                <span class="admin-logo-mark" aria-hidden="true">
                    <span class="material-symbols-outlined">school</span>
                </span>
                <span>
                    <strong>FPT UniRAG</strong>
                    <small>Academic RAG</small>
                </span>
            </a>

            <nav class="admin-nav">
                <a class="admin-nav-item" href="/AdminDashboard">
                    <span class="material-symbols-outlined" aria-hidden="true">dashboard</span>
                    Dashboard
                </a>
                <details class="admin-nav-group">
                    <summary class="admin-nav-item">
                        <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                        Subjects
                        <span class="material-symbols-outlined admin-nav-chevron" aria-hidden="true">expand_more</span>
                    </summary>
                    <div class="admin-subnav">
                        <a href="/Subjects">Manage Subjects</a>
                        <a href="/Subjects/AssignTeacher">Assign Teacher</a>
                        <a href="/Subjects/AssignHeader">Assign Header</a>
                    </div>
                </details>
                <a class="admin-nav-item active" href="/Accounts" aria-current="page">
                    <span class="material-symbols-outlined" aria-hidden="true">groups</span>
                    Accounts
                </a>
                <a class="admin-nav-item" href="/SubscriptionPlans">
                    <span class="material-symbols-outlined" aria-hidden="true">payments</span>
                    Subscription Plans
                </a>
                <a class="admin-nav-item" href="/Analysis">
                    <span class="material-symbols-outlined" aria-hidden="true">analytics</span>
                    Analytics
                </a>
            </nav>

            <section class="admin-sidebar-footer" aria-label="Sidebar actions">
                <a class="admin-sidebar-footer-link" href="#">
                    <span class="material-symbols-outlined" aria-hidden="true">help_outline</span>
                    <span>Help</span>
                </a>
                <a class="admin-sidebar-footer-link" href="/ChangePassword">
                    <span class="material-symbols-outlined" aria-hidden="true">lock</span>
                    <span>Change Password</span>
                </a>
                <a class="admin-sidebar-footer-link" href="/Logout">
                    <span class="material-symbols-outlined" aria-hidden="true">logout</span>
                    <span>Logout</span>
                </a>
            </section>
        </aside> *@

        <section class="accounts-main">
            <div class="accounts-canvas">
                <nav class="subject-breadcrumbs" aria-label="Breadcrumb">
                    <a href="/AdminDashboard">Dashboard</a>
                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                    <strong>Accounts</strong>
                </nav>

                <header class="subject-create-header accounts-header">
                    <div>
                        <h1>Account Provisioning</h1>
                        <p>Import student accounts in bulk, create teacher accounts, and control account status from one admin screen.</p>
                    </div>
                </header>

                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                {
                    <div class="accounts-feedback accounts-feedback-success" role="status">
                        @Model.SuccessMessage
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="accounts-feedback accounts-feedback-error" role="alert">
                        @Model.ErrorMessage
                    </div>
                }

                <div class="accounts-grid">
                    <section class="accounts-card" aria-labelledby="student-import-title">
                        <div class="accounts-card-header">
                            <div>
                                <p class="accounts-eyebrow">Bulk Student Import</p>
                                <h2 id="student-import-title">Import student accounts from Sheets</h2>
                            </div>
                            <span class="accounts-card-icon" aria-hidden="true">
                                <span class="material-symbols-outlined">upload_file</span>
                            </span>
                        </div>

                        <div class="accounts-template-card" aria-label="Expected import format">
                            <div class="accounts-template-header">
                                <strong>Accepted columns</strong>
                                <span>CSV / XLSX</span>
                            </div>
                            <div class="accounts-template-table-wrap">
                                <table class="accounts-template-table">
                                    <thead>
                                        <tr>
                                            <th>MSSV</th>
                                            <th>Name</th>
                                            <th>Email</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>SE173245</td>
                                            <td>Nguyen Minh Anh</td>
                                            <td>anhnmse173245@fpt.edu.vn</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        @{
                            var importInFlight = Model.ImportJobId.HasValue
                                && Model.ImportResult is null
                                && string.IsNullOrWhiteSpace(Model.ErrorMessage);
                        }

                        @if (importInFlight)
                        {
                            <section id="import-progress" class="accounts-progress-box" aria-live="polite">
                                <div class="accounts-progress-header">
                                    <div>
                                        <p class="accounts-progress-stage" id="import-progress-stage">Queued</p>
                                        <p class="accounts-progress-message" id="import-progress-message">Import has been queued.</p>
                                    </div>
                                    <span class="accounts-progress-value" id="import-progress-value">0%</span>
                                </div>
                                <div class="accounts-progress-track">
                                    <div id="import-progress-bar" class="accounts-progress-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"></div>
                                </div>
                            </section>
                        }

                        <form class="accounts-form @(importInFlight ? "is-busy" : "")" id="student-import-form" method="post" enctype="multipart/form-data" asp-page-handler="ImportStudents">
                            <label class="subject-field">
                                <span>Upload sheet file</span>
                                <div class="accounts-upload-box">
                                    <span class="material-symbols-outlined" aria-hidden="true">description</span>
                                    <div>
                                        <strong>Select spreadsheet file</strong>
                                        <small>Columns must follow: MSSV, Name, Email</small>
                                    </div>
                                    <input asp-for="StudentSheet" accept=".xlsx,.csv" />
                                </div>
                                <span asp-validation-for="StudentSheet" class="accounts-field-error"></span>
                            </label>

                            <footer class="subject-form-actions accounts-actions">
                                <button class="subject-submit-button" type="submit">
                                    Import Students
                                    <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                                </button>
                            </footer>
                        </form>

                        @if (Model.ImportResult is not null)
                        {
                            <section class="accounts-import-summary" aria-label="Import summary">
                                <div class="accounts-summary-badges">
                                    <span class="admin-badge success">@Model.ImportResult.CreatedCount created</span>
                                    <span class="admin-badge draft">@Model.ImportResult.SkippedCount skipped</span>
                                </div>

                                <div class="accounts-template-table-wrap">
                                    <table class="accounts-template-table">
                                        <thead>
                                            <tr>
                                                <th>Row</th>
                                                <th>MSSV</th>
                                                <th>Email</th>
                                                <th>Result</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in Model.ImportResult.Rows)
                                            {
                                                <tr>
                                                    <td>@row.RowNumber</td>
                                                    <td>@row.StudentCode</td>
                                                    <td>@row.Email</td>
                                                    <td>@row.Message</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </section>
                        }
                    </section>

                    <section class="accounts-card" aria-labelledby="teacher-create-title">
                        <div class="accounts-card-header">
                            <div>
                                <p class="accounts-eyebrow">Teacher Account Creation</p>
                                <h2 id="teacher-create-title">Create teacher account</h2>
                            </div>
                            <span class="accounts-card-icon" aria-hidden="true">
                                <span class="material-symbols-outlined">person_add</span>
                            </span>
                        </div>

                        <section id="teacher-progress" class="accounts-progress-box" style="display: none;" aria-live="polite">
                            <div class="accounts-progress-header">
                                <div>
                                    <p class="accounts-progress-stage" id="teacher-progress-stage">Validating</p>
                                    <p class="accounts-progress-message" id="teacher-progress-message">Checking teacher email…</p>
                                </div>
                                <span class="accounts-progress-value">Working…</span>
                            </div>
                            <div class="accounts-progress-track">
                                <div class="accounts-progress-bar is-indeterminate"></div>
                            </div>
                        </section>

                        <form class="accounts-form" id="teacher-create-form" method="post" asp-page-handler="CreateTeacher">
                            <label class="subject-field">
                                <span>Teacher email</span>
                                <input asp-for="TeacherEmail" type="email" placeholder="teacher@fpt.edu.vn" autocomplete="off" />
                                <small>This email will be used as the login account for the teacher.</small>
                                <span asp-validation-for="TeacherEmail" class="accounts-field-error"></span>
                            </label>

                            <footer class="subject-form-actions accounts-actions">
                                <button class="subject-submit-button" type="submit">
                                    Create Teacher
                                    <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                                </button>
                            </footer>
                        </form>
                    </section>
                </div>

                <section class="accounts-card accounts-table-card" aria-labelledby="account-table-title">
                    <div class="accounts-card-header">
                        <div>
                            <p class="accounts-eyebrow">Access Control</p>
                            <h2 id="account-table-title">Managed accounts</h2>
                        </div>
                        <span class="accounts-card-icon" aria-hidden="true">
                            <span class="material-symbols-outlined">shield_person</span>
                        </span>
                    </div>

                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var account in Model.Accounts)
                                {
                                    var roleBadgeClass = account.Role switch
                                    {
                                        "teacher" => "info",
                                        "admin" => "pending",
                                        _ => "cyan"
                                    };
                                    var statusBadgeClass = account.IsBlocked ? "draft" : "success";
                                    var statusText = account.IsBlocked ? "Blocked" : "Active";
                                    <tr>
                                        <td>
                                            <strong>@account.FullName</strong>
                                            <span>@(string.IsNullOrWhiteSpace(account.StudentCode) ? account.Role : account.StudentCode)</span>
                                        </td>
                                        <td>@account.Email</td>
                                        <td><span class="admin-badge @roleBadgeClass">@account.Role</span></td>
                                        <td><span class="admin-badge @statusBadgeClass">@statusText</span></td>
                                        <td class="admin-user-actions">
                                            @if (account.Role == "admin")
                                            {
                                                <span class="accounts-action-disabled">Protected</span>
                                            }
                                            else if (account.IsBlocked)
                                            {
                                                <form method="post" asp-page-handler="SetAccountStatus">
                                                    <input type="hidden" name="userId" value="@account.UserId" />
                                                    <input type="hidden" name="isBlocked" value="false" />
                                                    <button class="admin-success-button" type="submit">Reactivate</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="SetAccountStatus">
                                                    <input type="hidden" name="userId" value="@account.UserId" />
                                                    <input type="hidden" name="isBlocked" value="true" />
                                                    <button class="admin-danger-button" type="submit">Block</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>
        </section>
    </main>

    <partial name="_ValidationScriptsPartial" />

    <script>
        (() => {
            const teacherForm = document.getElementById("teacher-create-form");
            const teacherProgress = document.getElementById("teacher-progress");
            const teacherStageEl = document.getElementById("teacher-progress-stage");
            const teacherMessageEl = document.getElementById("teacher-progress-message");
            const teacherStages = [
                { stage: "Validating", message: "Checking teacher email…" },
                { stage: "Creating account", message: "Creating the teacher account…" },
                { stage: "Sending credentials", message: "Emailing login credentials…" }
            ];

            if (teacherForm) {
                teacherForm.addEventListener("submit", () => {
                    if (typeof teacherForm.checkValidity === "function" && !teacherForm.checkValidity()) {
                        return;
                    }

                    const submitButton = teacherForm.querySelector("button[type=submit]");
                    if (submitButton) {
                        submitButton.disabled = true;
                    }

                    teacherProgress.style.display = "block";
                    let stepIndex = 0;
                    teacherStageEl.textContent = teacherStages[0].stage;
                    teacherMessageEl.textContent = teacherStages[0].message;
                    window.setInterval(() => {
                        stepIndex = Math.min(stepIndex + 1, teacherStages.length - 1);
                        teacherStageEl.textContent = teacherStages[stepIndex].stage;
                        teacherMessageEl.textContent = teacherStages[stepIndex].message;
                    }, 900);
                });
            }
        })();
    </script>

    @if (importInFlight)
    {
        <script>
            (() => {
                const jobId = "@Model.ImportJobId!.Value";
                const stageEl = document.getElementById("import-progress-stage");
                const messageEl = document.getElementById("import-progress-message");
                const valueEl = document.getElementById("import-progress-value");
                const barEl = document.getElementById("import-progress-bar");

                async function pollStatus() {
                    try {
                        const response = await fetch(`/Accounts?handler=ImportStatus&jobId=${encodeURIComponent(jobId)}`, { credentials: "same-origin" });
                        if (!response.ok) {
                            throw new Error("Unable to read import status.");
                        }

                        const status = await response.json();
                        const percent = Math.max(0, Math.min(100, Number(status.progressPercent || 0)));
                        barEl.style.width = `${percent}%`;
                        barEl.setAttribute("aria-valuenow", percent);
                        valueEl.textContent = `${percent}%`;
                        stageEl.textContent = status.isCompleted ? "Completed" : (status.isFailed ? "Failed" : "Importing");
                        messageEl.textContent = status.isFailed
                            ? (status.errorMessage || "Import failed.")
                            : `Processed ${status.processedRows} of ${status.totalRows} row(s).`;

                        if (status.isCompleted || status.isFailed) {
                            if (status.isFailed) {
                                barEl.classList.add("is-failed");
                            }
                            window.setTimeout(() => {
                                window.location.href = `/Accounts?importJobId=${encodeURIComponent(jobId)}`;
                            }, 600);
                            return;
                        }

                        window.setTimeout(pollStatus, 1200);
                    } catch (error) {
                        messageEl.textContent = error.message || "Unable to read import status. Retrying…";
                        window.setTimeout(pollStatus, 2000);
                    }
                }

                pollStatus();
            })();
        </script>
    }
</body>
</html>
