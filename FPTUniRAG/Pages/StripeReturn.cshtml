@page "/payments/stripe/return"
@model FPTUniRAG.Pages.StripeReturnModel
@{
    Layout = null;
    ViewData["Title"] = "Stripe Payment Result - FPT UniRAG";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <style>
        body {
            min-height: 100vh;
            margin: 0;
            display: grid;
            place-items: center;
            padding: 24px;
            background: linear-gradient(180deg, #fbfdff 0%, #eef4ff 100%);
            color: #111c2d;
            font-family: Inter, system-ui, sans-serif;
        }

        .stripe-return-card {
            width: min(560px, 100%);
            padding: 36px;
            border: 1px solid rgba(193, 198, 214, 0.4);
            border-radius: 24px;
            background: rgba(255, 255, 255, 0.94);
            box-shadow: 0 24px 50px rgba(15, 23, 42, 0.08);
            text-align: center;
        }

        .stripe-return-card h1 {
            margin: 0;
            font-family: Manrope, Inter, sans-serif;
            font-size: 32px;
            line-height: 1.15;
        }

        .stripe-return-card p {
            margin: 16px 0 0;
            color: #54647a;
            font-size: 16px;
            line-height: 1.7;
        }

        .stripe-return-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 38px;
            padding: 0 16px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 18px;
            background: @(Model.IsSuccess ? "#ecfdf3" : "#fff1f0");
            color: @(Model.IsSuccess ? "#166534" : "#ba1a1a");
        }

        .stripe-return-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 48px;
            margin-top: 28px;
            padding: 0 22px;
            border-radius: 14px;
            background: #005bbf;
            color: #ffffff;
            font-size: 14px;
            font-weight: 800;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <main class="stripe-return-card">
        <div class="stripe-return-badge">@(Model.IsSuccess ? "Payment confirmed" : "Payment update")</div>
        <h1>@Model.Title</h1>
        <p>@Model.Message</p>
        <a class="stripe-return-link" href="@Model.BackLink">Back to subscription plans</a>
    </main>
</body>
</html>
