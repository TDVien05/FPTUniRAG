@page
@model FPTUniRAG.Pages.AdminDashboardModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard - FPT UniRAG";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page">
    <main class="admin-shell" aria-label="FPT UniRAG admin dashboard">
        @await Html.PartialAsync("_AdminNavigation")

        <section class="admin-main">
            <div class="admin-content">
                <header class="subject-create-header accounts-header">
                    <div>
                        <h1>Admin Dashboard</h1>
                        <p>Overview of subjects, documents, and account activity.</p>
                    </div>
                </header>

                <section class="admin-stat-grid" aria-label="Dashboard statistics">
                    <article class="admin-stat-card">
                        <span class="admin-stat-icon blue"><span class="material-symbols-outlined" aria-hidden="true">menu_book</span></span>
                        <div>
                            <p>Total Subjects</p>
                            <strong>@Model.Dashboard.TotalSubjects</strong>
                            <small>@Model.Dashboard.SubjectsWithDocuments with uploaded documents</small>
                        </div>
                    </article>
                    <article class="admin-stat-card">
                        <span class="admin-stat-icon cyan"><span class="material-symbols-outlined" aria-hidden="true">groups</span></span>
                        <div>
                            <p>Total Users</p>
                            <strong id="admin-total-users">0</strong>
                            <small id="admin-user-breakdown">Loading account summary...</small>
                        </div>
                    </article>
                </section>

                <div class="admin-grid">
                    <div class="admin-left-stack">
                        <section class="admin-panel admin-subject-panel">
                            <div class="admin-panel-header">
                                <div>
                                    <h2>Subject Repository</h2>
                                    <p>Manage academic subjects and indexed RAG documents.</p>
                                </div>
                                <a class="admin-secondary-button" href="/Subjects">View All</a>
                            </div>

                            <div class="admin-table-wrap">
                                <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Subject</th>
                                        <th>Owner</th>
                                        <th>Last Update</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Dashboard.RecentSubjects.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="5">No subjects are available in the database.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var subject in Model.Dashboard.RecentSubjects)
                                        {
                                            <tr>
                                                <td><strong>@subject.SubjectCode</strong><span>@subject.SubjectName</span></td>
                                                <td>@(string.IsNullOrWhiteSpace(subject.HeaderTeacherName) ? "Unassigned" : subject.HeaderTeacherName)</td>
                                                <td>@AdminDashboardModel.FormatLastUpdated(subject.LastUpdatedAt)</td>
                                                <td><span class="admin-badge @AdminDashboardModel.GetStatusCssClass(subject)">@AdminDashboardModel.GetStatusLabel(subject)</span></td>
                                                <td class="admin-row-actions">
                                                    <a asp-page="/Subjects/Edit" asp-route-subjectId="@subject.SubjectId" aria-label="Edit @subject.SubjectCode"><span class="material-symbols-outlined">edit</span></a>
                                                    <a asp-page="/Subjects/Delete" asp-route-subjectId="@subject.SubjectId" aria-label="Delete @subject.SubjectCode"><span class="material-symbols-outlined">delete</span></a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                                </table>
                            </div>
                        </section>

                        <section class="admin-panel admin-user-panel">
                            <div class="admin-panel-header">
                                <div>
                                    <h2>Account Management</h2>
                                    <p>Review user role, status, and manage account access.</p>
                                </div>
                            </div>

                            <div id="admin-account-feedback" class="accounts-feedback" hidden></div>

                            <div class="admin-table-wrap">
                                <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="admin-account-table-body">
                                    <tr>
                                        <td colspan="5">Loading account data...</td>
                                    </tr>
                                </tbody>
                                </table>
                            </div>
                        </section>
                    </div>

                </div>
            </div>
        </section>
    </main>
    <script>
        const accountTableBody = document.getElementById("admin-account-table-body");
        const totalUsersValue = document.getElementById("admin-total-users");
        const userBreakdown = document.getElementById("admin-user-breakdown");
        const feedbackBox = document.getElementById("admin-account-feedback");

        function roleBadgeClass(role) {
            switch ((role || "").toLowerCase()) {
                case "teacher":
                    return "info";
                case "admin":
                    return "pending";
                default:
                    return "cyan";
            }
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#39;");
        }

        function setFeedback(message, isError) {
            if (!feedbackBox) {
                return;
            }

            feedbackBox.hidden = !message;
            feedbackBox.textContent = message ?? "";
            feedbackBox.className = isError
                ? "accounts-feedback accounts-feedback-error"
                : "accounts-feedback accounts-feedback-success";
        }

        async function loadAccountSummary() {
            const response = await fetch("/api/admin/accounts/summary", { credentials: "same-origin" });
            if (!response.ok) {
                throw new Error("Failed to load account summary.");
            }

            const summary = await response.json();
            totalUsersValue.textContent = summary.totalUsers;
            userBreakdown.textContent = `${summary.studentCount} students, ${summary.teacherCount} teachers, ${summary.adminCount} admins, ${summary.blockedCount} blocked`;
        }

        async function loadAccounts() {
            const response = await fetch("/api/admin/accounts", { credentials: "same-origin" });
            if (!response.ok) {
                throw new Error("Failed to load accounts.");
            }

            const accounts = await response.json();
            if (!accounts.length) {
                accountTableBody.innerHTML = '<tr><td colspan="5">No accounts found.</td></tr>';
                return;
            }

            accountTableBody.innerHTML = accounts.map(account => {
                const role = (account.role || "").toLowerCase();
                const statusLabel = account.isBlocked ? "Blocked" : "Active";
                const statusClass = account.isBlocked ? "draft" : "success";
                const subLabel = account.studentCode || role;
                const actions = role === "admin"
                    ? '<span class="accounts-action-disabled">Protected</span>'
                    : account.isBlocked
                        ? `<button class="admin-success-button" type="button" data-action="reactivate" data-user-id="${escapeHtml(account.userId)}">Reactivate</button>`
                        : `<button class="admin-danger-button" type="button" data-action="block" data-user-id="${escapeHtml(account.userId)}">Block</button>`;

                return `
                    <tr>
                        <td><strong>${escapeHtml(account.fullName)}</strong><span>${escapeHtml(subLabel)}</span></td>
                        <td>${escapeHtml(account.email)}</td>
                        <td><span class="admin-badge ${roleBadgeClass(role)}">${escapeHtml(role)}</span></td>
                        <td><span class="admin-badge ${statusClass}">${statusLabel}</span></td>
                        <td class="admin-user-actions">${actions}</td>
                    </tr>`;
            }).join("");
        }

        async function updateAccountStatus(userId, action) {
            const response = await fetch(`/api/admin/accounts/${userId}/${action}`, {
                method: "POST",
                credentials: "same-origin"
            });

            const payload = await response.json().catch(() => ({ message: "Unexpected server response." }));
            if (!response.ok) {
                throw new Error(payload.message || "Failed to update account status.");
            }

            setFeedback(payload.message || "Account updated.", false);
            await Promise.all([loadAccountSummary(), loadAccounts()]);
        }

        accountTableBody?.addEventListener("click", async event => {
            const button = event.target.closest("button[data-action][data-user-id]");
            if (!button) {
                return;
            }

            button.disabled = true;
            setFeedback("", false);

            try {
                await updateAccountStatus(button.dataset.userId, button.dataset.action);
            } catch (error) {
                setFeedback(error.message || "Failed to update account status.", true);
            } finally {
                button.disabled = false;
            }
        });

        Promise.all([loadAccountSummary(), loadAccounts()]).catch(error => {
            setFeedback(error.message || "Failed to load dashboard account data.", true);
            accountTableBody.innerHTML = '<tr><td colspan="5">Failed to load accounts.</td></tr>';
        });
    </script>
</body>
</html>
