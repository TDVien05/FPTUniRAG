@page
@inject IConfiguration Configuration
@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard - FPT UniRAG";

    var totalSubjects = 124;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page">
    <main class="admin-shell" aria-label="FPT UniRAG admin dashboard">
        <aside class="admin-sidebar" aria-label="Admin navigation">
            <a class="admin-logo" href="/AdminDashboard" aria-label="FPT UniRAG dashboard">
                <span class="admin-logo-mark" aria-hidden="true">
                    <span class="material-symbols-outlined">school</span>
                </span>
                <span>
                    <strong>FPT UniRAG</strong>
                    <small>Academic RAG</small>
                </span>
            </a>

            <nav class="admin-nav">
                <a class="admin-nav-item active" href="/AdminDashboard" aria-current="page">
                    <span class="material-symbols-outlined" aria-hidden="true">dashboard</span>
                    Dashboard
                </a>
                <details class="admin-nav-group">
                    <summary class="admin-nav-item">
                        <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                        Subjects
                        <span class="material-symbols-outlined admin-nav-chevron" aria-hidden="true">expand_more</span>
                    </summary>
                    <div class="admin-subnav">
                        <a href="/Subjects">Manage Subjects</a>
                        <a href="/Subjects/AssignTeacher">Assign Teacher</a>
                        <a href="/Subjects/AssignHeader">Assign Header</a>
                    </div>
                </details>
                <a class="admin-nav-item" href="/Accounts">
                    <span class="material-symbols-outlined" aria-hidden="true">groups</span>
                    Accounts
                </a>
                <a class="admin-nav-item" href="/SubscriptionPlans">
                    <span class="material-symbols-outlined" aria-hidden="true">payments</span>
                    Subscription Plans
                </a>
                <a class="admin-nav-item" href="/Analysis">
                    <span class="material-symbols-outlined" aria-hidden="true">analytics</span>
                    Analytics
                </a>
            </nav>

            <section class="admin-sidebar-footer" aria-label="Sidebar actions">
                <a class="admin-sidebar-footer-link" href="#">
                    <span class="material-symbols-outlined" aria-hidden="true">help_outline</span>
                    <span>Help</span>
                </a>
                <a class="admin-sidebar-footer-link" href="/ChangePassword">
                    <span class="material-symbols-outlined" aria-hidden="true">lock</span>
                    <span>Change Password</span>
                </a>
                <a class="admin-sidebar-footer-link" href="/Logout">
                    <span class="material-symbols-outlined" aria-hidden="true">logout</span>
                    <span>Logout</span>
                </a>
            </section>
        </aside>

        <section class="admin-main">
            <div class="admin-content">
                <section class="admin-stat-grid" aria-label="Dashboard statistics">
                    <article class="admin-stat-card">
                        <span class="admin-stat-icon blue"><span class="material-symbols-outlined" aria-hidden="true">menu_book</span></span>
                        <div>
                            <p>Total Subjects</p>
                            <strong>@totalSubjects</strong>
                            <small>+8 this semester</small>
                        </div>
                    </article>
                    <article class="admin-stat-card">
                        <span class="admin-stat-icon cyan"><span class="material-symbols-outlined" aria-hidden="true">groups</span></span>
                        <div>
                            <p>Total Users</p>
                            <strong id="admin-total-users">0</strong>
                            <small id="admin-user-breakdown">Loading account summary...</small>
                        </div>
                    </article>
                </section>

                <div class="admin-grid">
                    <div class="admin-left-stack">
                        <section class="admin-panel admin-subject-panel">
                            <div class="admin-panel-header">
                                <div>
                                    <h2>Subject Repository</h2>
                                    <p>Manage academic subjects and indexed RAG documents.</p>
                                </div>
                                <a class="admin-secondary-button" href="/Subjects">View All</a>
                            </div>

                            <div class="admin-table-wrap">
                                <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Subject</th>
                                        <th>Owner</th>
                                        <th>Last Update</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><strong>SWD392</strong><span>Software Architecture</span></td>
                                        <td>Minh Tran</td>
                                        <td>Today, 09:42</td>
                                        <td><span class="admin-badge success">Indexed</span></td>
                                        <td class="admin-row-actions">
                                            <button type="button" aria-label="Edit SWD392"><span class="material-symbols-outlined">edit</span></button>
                                            <button type="button" aria-label="Open SWD392"><span class="material-symbols-outlined">open_in_new</span></button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>PRN222</strong><span>.NET Web Development</span></td>
                                        <td>Hoa Dao</td>
                                        <td>Yesterday, 15:10</td>
                                        <td><span class="admin-badge success">Ready</span></td>
                                        <td class="admin-row-actions">
                                            <button type="button" aria-label="Edit PRN222"><span class="material-symbols-outlined">edit</span></button>
                                            <button type="button" aria-label="Open PRN222"><span class="material-symbols-outlined">open_in_new</span></button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>NWC203</strong><span>Computer Networks</span></td>
                                        <td>Quang Nguyen</td>
                                        <td>Jul 01, 11:24</td>
                                        <td><span class="admin-badge pending">Processing</span></td>
                                        <td class="admin-row-actions">
                                            <button type="button" aria-label="Edit NWC203"><span class="material-symbols-outlined">edit</span></button>
                                            <button type="button" aria-label="Open NWC203"><span class="material-symbols-outlined">open_in_new</span></button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>AIL303</strong><span>Artificial Intelligence</span></td>
                                        <td>An Le</td>
                                        <td>Jun 30, 18:02</td>
                                        <td><span class="admin-badge draft">Review</span></td>
                                        <td class="admin-row-actions">
                                            <button type="button" aria-label="Edit AIL303"><span class="material-symbols-outlined">edit</span></button>
                                            <button type="button" aria-label="Open AIL303"><span class="material-symbols-outlined">open_in_new</span></button>
                                        </td>
                                    </tr>
                                </tbody>
                                </table>
                            </div>
                        </section>

                        <section class="admin-panel admin-user-panel">
                            <div class="admin-panel-header">
                                <div>
                                    <h2>Account Management</h2>
                                    <p>Review user role, status, and manage account access.</p>
                                </div>
                            </div>

                            <div id="admin-account-feedback" class="accounts-feedback" hidden></div>

                            <div class="admin-table-wrap">
                                <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="admin-account-table-body">
                                    <tr>
                                        <td colspan="5">Loading account data...</td>
                                    </tr>
                                </tbody>
                                </table>
                            </div>
                        </section>
                    </div>

                </div>
            </div>
        </section>
    </main>
    <script>
        const accountTableBody = document.getElementById("admin-account-table-body");
        const totalUsersValue = document.getElementById("admin-total-users");
        const userBreakdown = document.getElementById("admin-user-breakdown");
        const feedbackBox = document.getElementById("admin-account-feedback");

        function roleBadgeClass(role) {
            switch ((role || "").toLowerCase()) {
                case "teacher":
                    return "info";
                case "admin":
                    return "pending";
                default:
                    return "cyan";
            }
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#39;");
        }

        function setFeedback(message, isError) {
            if (!feedbackBox) {
                return;
            }

            feedbackBox.hidden = !message;
            feedbackBox.textContent = message ?? "";
            feedbackBox.className = isError
                ? "accounts-feedback accounts-feedback-error"
                : "accounts-feedback accounts-feedback-success";
        }

        async function loadAccountSummary() {
            const response = await fetch("/api/admin/accounts/summary", { credentials: "same-origin" });
            if (!response.ok) {
                throw new Error("Failed to load account summary.");
            }

            const summary = await response.json();
            totalUsersValue.textContent = summary.totalUsers;
            userBreakdown.textContent = `${summary.studentCount} students, ${summary.teacherCount} teachers, ${summary.adminCount} admins, ${summary.blockedCount} blocked`;
        }

        async function loadAccounts() {
            const response = await fetch("/api/admin/accounts", { credentials: "same-origin" });
            if (!response.ok) {
                throw new Error("Failed to load accounts.");
            }

            const accounts = await response.json();
            if (!accounts.length) {
                accountTableBody.innerHTML = '<tr><td colspan="5">No accounts found.</td></tr>';
                return;
            }

            accountTableBody.innerHTML = accounts.map(account => {
                const role = (account.role || "").toLowerCase();
                const statusLabel = account.isBlocked ? "Blocked" : "Active";
                const statusClass = account.isBlocked ? "draft" : "success";
                const subLabel = account.studentCode || role;
                const actions = role === "admin"
                    ? '<span class="accounts-action-disabled">Protected</span>'
                    : account.isBlocked
                        ? `<button class="admin-success-button" type="button" data-action="reactivate" data-user-id="${escapeHtml(account.userId)}">Reactivate</button>`
                        : `<button class="admin-danger-button" type="button" data-action="block" data-user-id="${escapeHtml(account.userId)}">Block</button>`;

                return `
                    <tr>
                        <td><strong>${escapeHtml(account.fullName)}</strong><span>${escapeHtml(subLabel)}</span></td>
                        <td>${escapeHtml(account.email)}</td>
                        <td><span class="admin-badge ${roleBadgeClass(role)}">${escapeHtml(role)}</span></td>
                        <td><span class="admin-badge ${statusClass}">${statusLabel}</span></td>
                        <td class="admin-user-actions">${actions}</td>
                    </tr>`;
            }).join("");
        }

        async function updateAccountStatus(userId, action) {
            const response = await fetch(`/api/admin/accounts/${userId}/${action}`, {
                method: "POST",
                credentials: "same-origin"
            });

            const payload = await response.json().catch(() => ({ message: "Unexpected server response." }));
            if (!response.ok) {
                throw new Error(payload.message || "Failed to update account status.");
            }

            setFeedback(payload.message || "Account updated.", false);
            await Promise.all([loadAccountSummary(), loadAccounts()]);
        }

        accountTableBody?.addEventListener("click", async event => {
            const button = event.target.closest("button[data-action][data-user-id]");
            if (!button) {
                return;
            }

            button.disabled = true;
            setFeedback("", false);

            try {
                await updateAccountStatus(button.dataset.userId, button.dataset.action);
            } catch (error) {
                setFeedback(error.message || "Failed to update account status.", true);
            } finally {
                button.disabled = false;
            }
        });

        Promise.all([loadAccountSummary(), loadAccounts()]).catch(error => {
            setFeedback(error.message || "Failed to load dashboard account data.", true);
            accountTableBody.innerHTML = '<tr><td colspan="5">Failed to load accounts.</td></tr>';
        });
    </script>
</body>
</html>
