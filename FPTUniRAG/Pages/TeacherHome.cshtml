@page "/TeacherHome"
@model FPTUniRAG.Pages.TeacherHomeModel
@{
    Layout = null;
    ViewData["Title"] = "Teacher Home - Subject Selection - FPT UniRAG";
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Manrope:wght@600;700&amp;family=JetBrains+Mono&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        try {
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            "primary-fixed-dim": "#adc7ff",
                            "primary": "#005bbf",
                            "secondary": "#505f76",
                            "tertiary-fixed-dim": "#c4c7c9",
                            "secondary-fixed": "#d3e4fe",
                            "on-error": "#ffffff",
                            "on-primary-fixed-variant": "#004493",
                            "on-tertiary-container": "#ffffff",
                            "on-secondary": "#ffffff",
                            "surface-tint": "#005bc0",
                            "on-primary-fixed": "#001a41",
                            "on-primary-container": "#ffffff",
                            "inverse-primary": "#adc7ff",
                            "surface-bright": "#f9f9ff",
                            "inverse-on-surface": "#ecf1ff",
                            "tertiary-fixed": "#e0e3e5",
                            "background": "#f9f9ff",
                            "on-secondary-fixed": "#0b1c30",
                            "on-secondary-fixed-variant": "#38485d",
                            "on-tertiary-fixed": "#191c1e",
                            "primary-container": "#1a73e8",
                            "on-surface": "#111c2d",
                            "outline-variant": "#c1c6d6",
                            "surface": "#f9f9ff",
                            "on-primary": "#ffffff",
                            "on-tertiary-fixed-variant": "#444749",
                            "on-secondary-container": "#54647a",
                            "secondary-container": "#d0e1fb",
                            "on-surface-variant": "#414754",
                            "surface-container-lowest": "#ffffff",
                            "surface-container-highest": "#d8e3fb",
                            "surface-container": "#e7eeff",
                            "error-container": "#ffdad6",
                            "primary-fixed": "#d8e2ff",
                            "on-tertiary": "#ffffff",
                            "inverse-surface": "#263143",
                            "surface-container-low": "#f0f3ff",
                            "error": "#ba1a1a",
                            "tertiary-container": "#747779",
                            "surface-container-high": "#dee8ff",
                            "on-background": "#111c2d",
                            "surface-dim": "#cfdaf2",
                            "outline": "#727785",
                            "tertiary": "#5b5e60",
                            "secondary-fixed-dim": "#b7c8e1",
                            "on-error-container": "#93000a",
                            "surface-variant": "#d8e3fb"
                        },
                        borderRadius: {
                            "DEFAULT": "0.25rem",
                            "lg": "0.5rem",
                            "xl": "0.75rem",
                            "full": "9999px"
                        },
                        spacing: {
                            "margin-desktop": "32px",
                            "container-max-width": "1280px",
                            "margin-mobile": "16px",
                            "gutter": "24px",
                            "base": "8px"
                        },
                        fontFamily: {
                            "label-md": ["Inter"],
                            "label-sm": ["Inter"],
                            "headline-lg": ["Manrope"],
                            "body-lg": ["Inter"],
                            "headline-xl": ["Manrope"],
                            "headline-lg-mobile": ["Manrope"],
                            "body-md": ["Inter"]
                        },
                        fontSize: {
                            "label-md": ["14px", { "lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500" }],
                            "label-sm": ["12px", { "lineHeight": "1.2", "fontWeight": "600" }],
                            "headline-lg": ["32px", { "lineHeight": "1.25", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                            "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                            "headline-xl": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                            "headline-lg-mobile": ["24px", { "lineHeight": "1.3", "fontWeight": "600" }],
                            "body-md": ["16px", { "lineHeight": "1.5", "fontWeight": "400" }]
                        }
                    }
                }
            };
        } catch (_e) { }
    </script>
</head>
<body class="font-body-md text-on-surface bg-background">
    <nav class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-md border-b border-outline-variant/30 shadow-sm">
        <div class="flex items-center justify-between px-gutter max-w-[1280px] mx-auto h-16">
            <div class="flex items-center gap-base md:gap-gutter">
                <span class="font-headline-lg text-[24px] font-bold text-primary">FPT UniRAG</span>
                <div class="hidden md:flex gap-gutter"></div>
            </div>
            <div class="flex items-center gap-base">
                <button class="material-symbols-outlined text-secondary hover:bg-surface-container-low p-2 rounded-full transition-all" type="button">notifications</button>
                <a class="material-symbols-outlined text-secondary hover:bg-surface-container-low p-2 rounded-full transition-all" href="/ChangePassword">settings</a>
                <div class="h-8 w-8 rounded-full bg-primary-container flex items-center justify-center text-white font-semibold">
                    @(string.IsNullOrWhiteSpace(User.Identity?.Name) ? "T" : User.Identity!.Name![0].ToString().ToUpperInvariant())
                </div>
            </div>
        </div>
    </nav>

    <aside class="h-screen w-64 fixed left-0 top-0 hidden md:flex flex-col bg-surface-container-lowest border-r border-outline-variant/20 pt-20 p-base gap-base">
        <div class="flex flex-col gap-1 mb-6 px-2">
            <span class="font-headline-lg text-[20px] font-bold text-primary leading-tight">FPT UniRAG</span>
            <span class="font-label-sm text-secondary opacity-70 uppercase tracking-wider text-[10px]">Academic AI Assistant</span>
        </div>
        <nav class="flex flex-col gap-1">
            <a class="flex items-center gap-base p-3 bg-primary/10 text-primary rounded-lg transition-all" href="/TeacherHome">
                <span class="material-symbols-outlined">home</span>
                <span class="font-label-md">Home</span>
            </a>
            <a class="flex items-center gap-base p-3 text-secondary hover:bg-surface-container-high rounded-lg transition-all" href="/TeacherDocuments">
                <span class="material-symbols-outlined">folder_open</span>
                <span class="font-label-md">Document Management</span>
            </a>
        </nav>
        <div class="mt-auto flex flex-col gap-1 border-t border-outline-variant/10 pt-base">
                <a class="flex items-center gap-base p-3 text-secondary hover:bg-surface-container-high rounded-lg transition-all" href="/ChangePassword">
                    <span class="material-symbols-outlined">lock</span>
                    <span class="font-label-md">Change Password</span>
                </a>
                <a class="flex items-center gap-base p-3 text-secondary hover:bg-surface-container-high rounded-lg transition-all" href="#">
                    <span class="material-symbols-outlined">help</span>
                    <span class="font-label-md">Help</span>
                </a>
            <a class="flex items-center gap-base p-3 text-secondary hover:bg-surface-container-high rounded-lg transition-all" href="/Logout">
                <span class="material-symbols-outlined">logout</span>
                <span class="font-label-md">Logout</span>
            </a>
        </div>
    </aside>

    <main class="md:ml-64 pt-20 px-gutter pb-8 max-w-[1280px] mx-auto">
        <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-gutter mb-8">
            <div class="max-w-2xl">
                <nav class="flex items-center gap-2 text-sm text-secondary mb-2">
                    <span class="hover:text-primary cursor-pointer">Workspace</span>
                    <span class="material-symbols-outlined text-xs">chevron_right</span>
                    <span class="text-on-surface font-medium">Home</span>
                </nav>
                <h1 class="font-headline-lg text-on-surface">Teacher Dashboard</h1>
                <p class="font-body-md text-secondary mt-1">Only subjects where you are the header teacher appear here. New assignments arrive in real time.</p>
            </div>
            <div class="flex gap-4">
                <div class="bg-surface-container-lowest border border-outline-variant/30 px-6 py-3 rounded-xl flex flex-col shadow-sm min-w-[140px]">
                    <span class="text-secondary font-label-sm uppercase tracking-tight text-[10px]">Total Uploaded</span>
                    <span class="text-primary font-bold text-xl" id="totalUploaded">@Model.TotalUploadedDocuments</span>
                </div>
                <div class="bg-surface-container-lowest border border-outline-variant/30 px-6 py-3 rounded-xl flex flex-col shadow-sm min-w-[140px]">
                    <span class="text-secondary font-label-sm uppercase tracking-tight text-[10px]">Header Subjects</span>
                    <span class="text-on-surface font-bold text-xl" id="activeSubjects">@Model.HeaderSubjects.Count</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
            <div class="lg:col-span-12 flex flex-col gap-6">
                <div class="flex items-center justify-between">
                    <h2 class="font-headline-lg text-[20px] text-on-surface">Subjects You Lead</h2>
                    <span class="text-primary font-label-md text-sm">Real-time sync enabled</span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" id="teacherHeaderSubjects"
                     data-initial-subjects='@System.Text.Json.JsonSerializer.Serialize(Model.HeaderSubjects, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase })'>
                    @if (Model.HeaderSubjects.Count == 0)
                    {
                        <div class="md:col-span-2 lg:col-span-4 bg-surface-container-lowest border border-outline-variant/30 rounded-xl p-8 shadow-sm text-center text-secondary" id="teacherHeaderSubjectsEmptyState">
                            No subjects are assigned to you as header yet.
                        </div>
                    }
                    else
                    {
                        foreach (var subject in Model.HeaderSubjects)
                        {
                            <article class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl p-6 shadow-sm hover:border-primary/50 transition-all group">
                                <div class="w-12 h-12 rounded-lg bg-primary/5 flex items-center justify-center mb-4 group-hover:bg-primary/10">
                                    <span class="material-symbols-outlined text-primary">school</span>
                                </div>
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary mb-2">@subject.SubjectCode</p>
                                <h3 class="font-bold text-on-surface mb-1">@subject.SubjectName</h3>
                                <p class="text-xs text-secondary mb-4">@(string.IsNullOrWhiteSpace(subject.Description) ? "Header teacher access enabled." : subject.Description)</p>
                                <p class="text-xs text-secondary mb-4">@subject.DocumentCount Documents • @subject.ChapterCount Chapters</p>
                                <a class="w-full py-2 bg-primary text-white rounded-lg text-sm font-medium inline-flex items-center justify-center" href="/TeacherUpload?subjectId=@subject.SubjectId">Upload Files</a>
                            </article>
                        }
                    }
                </div>
            </div>
        </div>
    </main>

    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-surface/95 backdrop-blur-md border-t border-outline-variant/20 flex justify-around p-2 z-50">
        <a class="flex flex-col items-center gap-1 text-primary" href="/TeacherHome">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[10px] font-medium">Home</span>
        </a>
        <a class="flex flex-col items-center gap-1 text-secondary" href="/TeacherDocuments">
            <span class="material-symbols-outlined">folder_open</span>
            <span class="text-[10px] font-medium">Files</span>
        </a>
        <a class="flex flex-col items-center gap-1 text-secondary" href="/Logout">
            <span class="material-symbols-outlined">logout</span>
            <span class="text-[10px] font-medium">Logout</span>
        </a>
    </nav>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (() => {
            const container = document.getElementById("teacherHeaderSubjects");
            const totalUploaded = document.getElementById("totalUploaded");
            const activeSubjects = document.getElementById("activeSubjects");
            if (!container || !totalUploaded || !activeSubjects) {
                return;
            }

            const iconByCode = (subjectCode) => {
                const normalized = (subjectCode || "").toLowerCase();
                if (normalized.includes("java") || normalized.includes("prn")) return "code";
                if (normalized.includes("ai") || normalized.includes("ml")) return "psychology";
                if (normalized.includes("db") || normalized.includes("sql")) return "database";
                if (normalized.includes("math") || normalized.includes("cal")) return "calculate";
                return "school";
            };

            const escapeHtml = (value) => (value || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#39;");

            const renderSubjects = (subjects) => {
                activeSubjects.textContent = String(subjects.length);
                totalUploaded.textContent = String(subjects.reduce((sum, subject) => sum + (subject.documentCount || 0), 0));

                if (!subjects.length) {
                    container.innerHTML = `
                        <div class="md:col-span-2 lg:col-span-4 bg-surface-container-lowest border border-outline-variant/30 rounded-xl p-8 shadow-sm text-center text-secondary" id="teacherHeaderSubjectsEmptyState">
                            No subjects are assigned to you as header yet.
                        </div>`;
                    return;
                }

                container.innerHTML = subjects.map(subject => `
                    <article class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl p-6 shadow-sm hover:border-primary/50 transition-all group">
                        <div class="w-12 h-12 rounded-lg bg-primary/5 flex items-center justify-center mb-4 group-hover:bg-primary/10">
                            <span class="material-symbols-outlined text-primary">${iconByCode(subject.subjectCode)}</span>
                        </div>
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary mb-2">${escapeHtml(subject.subjectCode)}</p>
                        <h3 class="font-bold text-on-surface mb-1">${escapeHtml(subject.subjectName)}</h3>
                        <p class="text-xs text-secondary mb-4">${escapeHtml(subject.description || "Header teacher access enabled.")}</p>
                        <p class="text-xs text-secondary mb-4">${subject.documentCount || 0} Documents • ${subject.chapterCount || 0} Chapters</p>
                        <a class="w-full py-2 bg-primary text-white rounded-lg text-sm font-medium inline-flex items-center justify-center" href="/TeacherUpload?subjectId=${encodeURIComponent(subject.subjectId)}">Upload Files</a>
                    </article>
                `).join("");
            };

            const fetchSubjects = async () => {
                const response = await fetch("/api/teacher/subjects/header", {
                    credentials: "same-origin",
                    headers: {
                        "Accept": "application/json"
                    }
                });

                if (!response.ok) {
                    throw new Error(`Failed to refresh subjects: ${response.status}`);
                }

                const subjects = await response.json();
                renderSubjects(subjects);
            };

            try {
                const initial = JSON.parse(container.dataset.initialSubjects || "[]");
                renderSubjects(initial);
            } catch (_error) {
                renderSubjects([]);
            }

            if (!window.signalR) {
                return;
            }

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/teacher-header-subjects")
                .withAutomaticReconnect()
                .build();

            connection.on("headerSubjectsChanged", async () => {
                try {
                    await fetchSubjects();
                } catch (_error) {
                }
            });

            connection.start().catch(() => {
            });
        })();
    </script>
</body>
</html>
