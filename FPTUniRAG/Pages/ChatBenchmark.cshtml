@page "/ChatBenchmark"
@model FPTUniRAG.Pages.ChatBenchmarkModel
@using System.Globalization
@{
    Layout = null;
    ViewData["Title"] = "Chat Model Benchmark - FPT UniRAG";

    var healthPoints = Model.HealthTrend;
    var latestHealth = healthPoints.LastOrDefault();
    var successChartPoints = BuildChartPoints(healthPoints.Select(point => (double?)point.SuccessRate), 100);
    var latencyAxisMax = NiceMax(healthPoints.Count == 0
        ? 0
        : healthPoints.Max(point => (point.P95LatencyMs ?? point.P50LatencyMs ?? 0) / 1000d));
    var p50ChartPoints = BuildChartPoints(healthPoints.Select(point => point.P50LatencyMs / 1000d), latencyAxisMax);
    var p95ChartPoints = BuildChartPoints(healthPoints.Select(point => point.P95LatencyMs / 1000d), latencyAxisMax);
    var tokenAxisMax = NiceMax(healthPoints.Count == 0
        ? 0
        : healthPoints.Max(point => point.PromptTokens + point.CompletionTokens));

    var latencyRuns = Model.RunSummaries.Where(run => run.P50LatencyMs.HasValue).ToList();
    double? bestP50 = latencyRuns.Count == 0 ? null : latencyRuns.Min(run => run.P50LatencyMs!.Value);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined&display=block" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page accounts-page">
    <main class="admin-shell" aria-label="Chat model benchmark">
        @await Html.PartialAsync("_AdminNavigation")

        <section class="accounts-main">
            <div class="accounts-canvas">
                <header class="accounts-header">
                    <div>
                        <p class="accounts-eyebrow">Chat operations</p>
                        <h1>Chat Model Benchmark</h1>
                        <p>Replay one prompt set through the real RAG pipeline against each model, then compare the results side by side.</p>
                    </div>
                </header>

                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                {
                    <div class="accounts-feedback accounts-feedback-success" role="status">@Model.SuccessMessage</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="accounts-feedback accounts-feedback-error" role="alert">@Model.ErrorMessage</div>
                }

                <section class="benchmark-stats" aria-label="Latest benchmark health">
                    <article class="benchmark-stat">
                        <p class="benchmark-stat-label">Latest success rate</p>
                        <p class="benchmark-stat-value">@(latestHealth is null ? "—" : $"{latestHealth.SuccessRate.ToString("0.#", CultureInfo.InvariantCulture)}%")</p>
                        <p class="benchmark-stat-meta">@(latestHealth is null ? "No completed batches" : $"{latestHealth.SuccessCount} of {latestHealth.AttemptCount} prompts")</p>
                    </article>
                    <article class="benchmark-stat">
                        <p class="benchmark-stat-label">Latest p95 latency</p>
                        <p class="benchmark-stat-value">@FormatMs(latestHealth?.P95LatencyMs)</p>
                        <p class="benchmark-stat-meta">Successful responses only</p>
                    </article>
                    <article class="benchmark-stat @((latestHealth?.FailedPromptCount ?? 0) > 0 || (latestHealth?.FailedRunCount ?? 0) > 0 ? "is-warning" : string.Empty)">
                        <p class="benchmark-stat-label">Latest failures</p>
                        <p class="benchmark-stat-value">@(latestHealth is null ? "—" : latestHealth.FailedPromptCount.ToString("N0"))</p>
                        <p class="benchmark-stat-meta">@(latestHealth is null ? "No completed batches" : $"{latestHealth.FailedRunCount} failed run(s)")</p>
                    </article>
                    <article class="benchmark-stat">
                        <p class="benchmark-stat-label">Latest token usage</p>
                        <p class="benchmark-stat-value">@(latestHealth is null ? "—" : (latestHealth.PromptTokens + latestHealth.CompletionTokens).ToString("N0"))</p>
                        <p class="benchmark-stat-meta">@(latestHealth is null ? "No completed batches" : $"Completed {latestHealth.StartedAt:yyyy-MM-dd HH:mm}")</p>
                    </article>
                </section>

                @{
                    var hasModels = Model.AvailableModels.Count > 0;
                }

                <!-- Write a prompt, pick a subject, run it. Nothing is saved between runs. -->
                <section class="accounts-card benchmark-setup-card" aria-labelledby="benchmark-run-title">
                    <div class="accounts-card-header">
                        <div>
                            <p class="accounts-eyebrow">Controlled benchmark</p>
                            <h2 id="benchmark-run-title">Run a benchmark</h2>
                            <p>Write one prompt and choose a subject. Every selected model answers it with the exact same retrieved context, so the results are comparable.</p>
                        </div>
                        <span class="accounts-card-icon" aria-hidden="true">
                            <span class="material-symbols-outlined">play_circle</span>
                        </span>
                    </div>

                    <div class="benchmark-setup-section">
                        @if (!hasModels)
                        {
                            <div class="benchmark-empty benchmark-empty-inline">
                                <span class="material-symbols-outlined" aria-hidden="true">smart_toy</span>
                                <p><strong>No chat models registered yet.</strong></p>
                                <p>Add one on <a href="/ChatModels">Chat Models</a> first.</p>
                            </div>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Run" class="accounts-form" id="benchmark-run-form">
                                <label class="subject-field">
                                    <span>Prompt</span>
                                    <textarea class="accounts-select" asp-for="PromptText" rows="3" required
                                              placeholder="Explain the difference between process and thread with an example."></textarea>
                                </label>

                                <label class="subject-field benchmark-subject-field">
                                    <span>Subject to retrieve against</span>
                                    <span class="benchmark-subject-select">
                                        <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                                        <select asp-for="RunSubjectId" required>
                                            <option value="">Choose a subject…</option>
                                            @foreach (var subject in Model.Subjects)
                                            {
                                                <option value="@subject.SubjectId">@subject.SubjectCode — @subject.SubjectName</option>
                                            }
                                        </select>
                                        <span class="material-symbols-outlined benchmark-select-chevron" aria-hidden="true">expand_more</span>
                                    </span>
                                    <small class="text-secondary">The subject must already have embedded documents.</small>
                                </label>

                                <fieldset class="subject-field">
                                    <legend>Models to compare</legend>
                                    <div class="benchmark-model-choices">
                                        @foreach (var entry in Model.AvailableModels)
                                        {
                                            <label class="benchmark-model-choice">
                                                <input type="checkbox" name="SelectedModels" value="@entry.ModelName" checked="@entry.IsSelected" />
                                                <span>@entry.ModelName @(entry.IsSelected ? "(active)" : string.Empty)</span>
                                            </label>
                                        }
                                    </div>
                                </fieldset>

                                <!-- Cost is the one thing worth interrupting for: these are paid calls. -->
                                <p class="benchmark-cost-callout" id="benchmark-cost-hint" role="status">
                                    <span class="material-symbols-outlined" aria-hidden="true">payments</span>
                                    <span>
                                        This will send <strong id="benchmark-request-count">0</strong> paid OpenRouter request(s)
                                        — one per model you tick.
                                    </span>
                                </p>

                                <footer class="subject-form-actions accounts-actions">
                                    <button class="subject-submit-button" type="submit" id="benchmark-run-button">
                                        Run benchmark
                                        <span class="material-symbols-outlined" aria-hidden="true">play_arrow</span>
                                    </button>
                                </footer>
                            </form>
                        }
                    </div>
                </section>

                <!-- Controlled benchmark: results -->
                <section class="accounts-card accounts-table-card" aria-labelledby="benchmark-results-title">
                    <div class="accounts-card-header">
                        <div>
                            <p class="accounts-eyebrow">Controlled benchmark</p>
                            <h2 id="benchmark-results-title">Model comparison</h2>
                            <p>
                                @if (Model.SelectedBatch is not null)
                                {
                                    <text>Showing the benchmark from @Model.SelectedBatch.StartedAt.ToString("yyyy-MM-dd HH:mm")</text>
                                    @if (!string.IsNullOrWhiteSpace(Model.SelectedBatch.SubjectCode))
                                    {
                                        <text> · @Model.SelectedBatch.SubjectCode</text>
                                    }
                                    <text>. Latency percentiles come from successful calls only; success rate counts every attempt.</text>
                                }
                                else
                                {
                                    <text>Latency percentiles come from successful calls only; success rate counts every attempt, including failures.</text>
                                }
                            </p>
                        </div>
                    </div>

                    @if (Model.Batches.Count > 1)
                    {
                        <form method="get" class="benchmark-history" id="benchmark-history-form">
                            <label class="subject-field benchmark-subject-field">
                                <span>Compare a previous run</span>
                                <span class="benchmark-subject-select">
                                    <span class="material-symbols-outlined" aria-hidden="true">history</span>
                                    <select name="batchId" onchange="this.form.submit()" aria-label="Choose which benchmark to display">
                                        @foreach (var batch in Model.Batches)
                                        {
                                            var label = $"{batch.StartedAt:yyyy-MM-dd HH:mm} · {batch.ModelCount} model(s)"
                                                + (string.IsNullOrWhiteSpace(batch.SubjectCode) ? string.Empty : $" · {batch.SubjectCode}")
                                                + (string.IsNullOrWhiteSpace(batch.PromptText) ? string.Empty : $" · {Preview(batch.PromptText)}");
                                            <option value="@batch.BatchId" selected="@(Model.SelectedBatch?.BatchId == batch.BatchId)">@label</option>
                                        }
                                    </select>
                                    <span class="material-symbols-outlined benchmark-select-chevron" aria-hidden="true">expand_more</span>
                                </span>
                            </label>
                            @if (!Model.IsViewingLatestBatch)
                            {
                                <a class="benchmark-link-button" href="/ChatBenchmark">
                                    <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
                                    <span>Back to latest</span>
                                </a>
                            }
                            <noscript><button class="admin-ghost-button" type="submit">Show</button></noscript>
                        </form>
                    }
                    <div class="admin-table-wrap benchmark-table-wrap">
                        <table class="admin-table benchmark-compare-table" id="benchmark-runs-table">
                            <thead>
                                <tr>
                                    <th scope="col">Model</th>
                                    <th scope="col">Subject</th>
                                    <th scope="col">Progress</th>
                                    <th scope="col" class="is-numeric">Success</th>
                                    <th scope="col" class="is-numeric">p50</th>
                                    <th scope="col" class="is-numeric">p95</th>
                                    <th scope="col" class="is-numeric">Avg. tokens</th>
                                    <th scope="col" class="is-numeric">Avg. chunks</th>
                                    <th scope="col">Started</th>
                                </tr>
                            </thead>
                            <tbody>
                            @if (Model.RunSummaries.Count == 0)
                            {
                                <tr>
                                    <td colspan="9">
                                        <div class="benchmark-empty">
                                            <span class="material-symbols-outlined" aria-hidden="true">bar_chart</span>
                                            <p><strong>No benchmark has been run yet.</strong></p>
                                            <p>Write a prompt above, pick a subject and at least one model, then run it.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var run in Model.RunSummaries)
                                {
                                    var isFastest = bestP50 is not null && run.P50LatencyMs == bestP50;
                                    <tr class="@(isFastest ? "is-best" : string.Empty)">
                                        <td>
                                            <strong class="benchmark-model-name">
                                                @run.ModelName
                                                @if (isFastest)
                                                {
                                                    <span class="benchmark-tag" title="Lowest median latency in this list">Fastest</span>
                                                }
                                            </strong>
                                        </td>
                                        <td>@(run.SubjectCode ?? "—")</td>
                                        <td>
                                            <span class="benchmark-status benchmark-status-@run.Status">
                                                <span class="benchmark-status-dot" aria-hidden="true"></span>@run.Status
                                            </span>
                                            <span class="benchmark-progress" role="progressbar"
                                                  aria-valuemin="0" aria-valuemax="100" aria-valuenow="@run.ProgressPercent"
                                                  aria-label="@run.CompletedCount of @run.PromptCount prompts completed">
                                                <span class="benchmark-progress-fill" style="width:@run.ProgressPercent%"></span>
                                            </span>
                                            <span class="benchmark-progress-label">@run.CompletedCount / @run.PromptCount prompts</span>
                                        </td>
                                        <td class="is-numeric @(run.SuccessRate < 100m ? "is-alert" : string.Empty)">
                                            @run.SuccessRate.ToString("0.##", CultureInfo.InvariantCulture)%
                                        </td>
                                        <td class="is-numeric">@FormatMs(run.P50LatencyMs)</td>
                                        <td class="is-numeric">@FormatMs(run.P95LatencyMs)</td>
                                        <td class="is-numeric">@(run.AverageTotalTokens is null ? "—" : run.AverageTotalTokens.Value.ToString("N0", CultureInfo.InvariantCulture))</td>
                                        <td class="is-numeric">@(run.AverageRetrievedChunks is null ? "—" : run.AverageRetrievedChunks.Value.ToString("0.#", CultureInfo.InvariantCulture))</td>
                                        <td>@run.StartedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    </tr>
                                    @if (!string.IsNullOrWhiteSpace(run.ErrorMessage))
                                    {
                                        <tr class="benchmark-error-row">
                                            <td colspan="9">
                                                <span class="material-symbols-outlined" aria-hidden="true">error</span>
                                                <span>@run.ErrorMessage</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </section>

                @{
                    // Answers are shown for every recorded run, newest first — no drill-down.
                    var answerRuns = Model.RunSummaries.Where(run => run.Results.Count > 0).ToList();
                }
                @if (answerRuns.Count > 0)
                {
                    <section class="accounts-card" id="run-answers" aria-labelledby="benchmark-answers-title">
                        <div class="accounts-card-header">
                            <div>
                                <p class="accounts-eyebrow">Controlled benchmark</p>
                                <h2 id="benchmark-answers-title">Answers</h2>
                                <p>What each model actually replied. Read them side by side to judge quality yourself.</p>
                            </div>
                            <span class="accounts-card-icon" aria-hidden="true">
                                <span class="material-symbols-outlined">chat_bubble</span>
                            </span>
                        </div>

                        <div class="benchmark-answer-grid">
                            @foreach (var run in answerRuns)
                            {
                                foreach (var result in run.Results)
                                {
                                    <article class="benchmark-answer-card @(result.IsSuccess ? string.Empty : "is-failed")">
                                        <header class="benchmark-answer-head">
                                            <strong>@run.ModelName</strong>
                                            <span class="admin-badge @(result.IsSuccess ? "success" : "danger")">@(result.IsSuccess ? "OK" : "Failed")</span>
                                        </header>
                                        <p class="benchmark-answer-prompt">
                                            <span class="material-symbols-outlined" aria-hidden="true">help</span>
                                            @result.PromptText
                                        </p>
                                        @if (result.IsSuccess)
                                        {
                                            <p class="benchmark-answer">@result.AnswerText</p>
                                        }
                                        else
                                        {
                                            <p class="benchmark-answer is-error">@result.ErrorMessage</p>
                                        }
                                        <footer class="benchmark-answer-meta">
                                            <span>@FormatMs(result.ResponseTimeMs)</span>
                                            <span>@result.TotalTokens.ToString("N0") tokens</span>
                                            <span>@result.RetrievedChunkCount chunks</span>
                                            <span>@run.StartedAt.ToString("yyyy-MM-dd HH:mm")</span>
                                        </footer>
                                    </article>
                                }
                            }
                        </div>
                    </section>
                }

                <header class="accounts-header benchmark-health-header">
                    <div>
                        <p class="accounts-eyebrow">Operational health</p>
                        <h2>Benchmark health trends</h2>
                        <p>Recent completed batches reveal reliability, response-time stability, and token demand over time.</p>
                    </div>
                </header>

                @if (healthPoints.Count == 0)
                {
                    <section class="accounts-card benchmark-health-empty" aria-label="Benchmark health trends">
                        <span class="material-symbols-outlined" aria-hidden="true">monitoring</span>
                        <h3>No completed health history yet</h3>
                        <p>Complete a benchmark above to create the first health data point.</p>
                    </section>
                }
                else
                {
                    <div class="benchmark-health-grid">
                        <section class="accounts-card benchmark-health-card" aria-labelledby="health-success-title">
                            <div class="chatviz-header">
                                <div>
                                    <h3 class="chatviz-title" id="health-success-title">Success rate</h3>
                                    <p class="chatviz-subtitle">Successful prompt responses in each completed batch.</p>
                                </div>
                                <span class="benchmark-health-value">@healthPoints.Last().SuccessRate.ToString("0.#", CultureInfo.InvariantCulture)% latest</span>
                            </div>
                            <div class="benchmark-svg-scroll">
                                <svg class="benchmark-line-chart" viewBox="0 0 760 220" role="img" aria-labelledby="health-success-title">
                                    @foreach (var tick in new[] { 100, 75, 50, 25, 0 })
                                    {
                                        var y = 10 + (100 - tick) * 1.8;
                                        <line class="benchmark-chart-gridline" x1="42" y1="@y" x2="750" y2="@y"></line>
                                    }
                                    <polyline class="benchmark-chart-line benchmark-chart-line-success" points="@PointList(successChartPoints)"></polyline>
                                    @for (var index = 0; index < healthPoints.Count; index++)
                                    {
                                        var health = healthPoints[index];
                                        var point = successChartPoints[index];
                                        var tooltip = $"{health.StartedAt:yyyy-MM-dd HH:mm} · {health.SuccessRate:0.#}% · {health.SuccessCount}/{health.AttemptCount} successful";
                                        <circle class="benchmark-chart-point benchmark-chart-point-success" cx="@point.X" cy="@point.Y" r="5"
                                                tabindex="0" data-tooltip="@tooltip" aria-label="@tooltip"></circle>
                                    }
                                </svg>
                            </div>
                            <div class="benchmark-chart-labels" style="grid-template-columns:repeat(@healthPoints.Count, minmax(34px, 1fr))" aria-hidden="true">
                                @foreach (var health in healthPoints)
                                {
                                    <span>@health.StartedAt.ToString("MM-dd")</span>
                                }
                            </div>
                        </section>

                        <section class="accounts-card benchmark-health-card" aria-labelledby="health-latency-title">
                            <div class="chatviz-header">
                                <div>
                                    <h3 class="chatviz-title" id="health-latency-title">Response-time percentiles</h3>
                                    <p class="chatviz-subtitle">p50 and p95 latency from successful responses.</p>
                                </div>
                            </div>
                            <div class="chatviz-legend" aria-hidden="true">
                                <span class="chatviz-legend-item"><span class="chatviz-legend-swatch benchmark-swatch-p50"></span>p50</span>
                                <span class="chatviz-legend-item"><span class="chatviz-legend-swatch benchmark-swatch-p95"></span>p95</span>
                            </div>
                            <div class="benchmark-svg-scroll">
                                <svg class="benchmark-line-chart" viewBox="0 0 760 220" role="img" aria-labelledby="health-latency-title">
                                    @for (var step = 0; step <= 4; step++)
                                    {
                                        var y = 10 + step * 45;
                                        <line class="benchmark-chart-gridline" x1="42" y1="@y" x2="750" y2="@y"></line>
                                    }
                                    <polyline class="benchmark-chart-line benchmark-chart-line-p50" points="@PointList(p50ChartPoints)"></polyline>
                                    <polyline class="benchmark-chart-line benchmark-chart-line-p95" points="@PointList(p95ChartPoints)"></polyline>
                                    @for (var index = 0; index < healthPoints.Count; index++)
                                    {
                                        var health = healthPoints[index];
                                        @if (health.P50LatencyMs.HasValue)
                                        {
                                            var point = p50ChartPoints[index];
                                            var tooltip = $"{health.StartedAt:yyyy-MM-dd HH:mm} · p50 {FormatMs(health.P50LatencyMs)}";
                                            <circle class="benchmark-chart-point benchmark-chart-point-p50" cx="@point.X" cy="@point.Y" r="4"
                                                    tabindex="0" data-tooltip="@tooltip" aria-label="@tooltip"></circle>
                                        }
                                        @if (health.P95LatencyMs.HasValue)
                                        {
                                            var point = p95ChartPoints[index];
                                            var tooltip = $"{health.StartedAt:yyyy-MM-dd HH:mm} · p95 {FormatMs(health.P95LatencyMs)}";
                                            <circle class="benchmark-chart-point benchmark-chart-point-p95" cx="@point.X" cy="@point.Y" r="4"
                                                    tabindex="0" data-tooltip="@tooltip" aria-label="@tooltip"></circle>
                                        }
                                    }
                                </svg>
                            </div>
                            <div class="benchmark-chart-labels" style="grid-template-columns:repeat(@healthPoints.Count, minmax(34px, 1fr))" aria-hidden="true">
                                @foreach (var health in healthPoints)
                                {
                                    <span>@health.StartedAt.ToString("MM-dd")</span>
                                }
                            </div>
                        </section>
                    </div>

                    <section class="accounts-card benchmark-health-card benchmark-token-card" aria-labelledby="health-token-title">
                        <div class="chatviz-header">
                            <div>
                                <h3 class="chatviz-title" id="health-token-title">Token usage</h3>
                                <p class="chatviz-subtitle">Input and output tokens consumed by successful responses in each batch.</p>
                            </div>
                        </div>
                        <div class="chatviz-legend" aria-hidden="true">
                            <span class="chatviz-legend-item"><span class="chatviz-legend-swatch benchmark-swatch-input"></span>Input</span>
                            <span class="chatviz-legend-item"><span class="chatviz-legend-swatch benchmark-swatch-output"></span>Output</span>
                        </div>
                        <div class="benchmark-token-chart" role="img" aria-labelledby="health-token-title">
                            @foreach (var health in healthPoints)
                            {
                                var inputHeight = BarHeightPercent(health.PromptTokens, tokenAxisMax);
                                var outputHeight = BarHeightPercent(health.CompletionTokens, tokenAxisMax);
                                var tooltip = $"{health.StartedAt:yyyy-MM-dd HH:mm} · {health.PromptTokens:N0} input · {health.CompletionTokens:N0} output";
                                <div class="benchmark-token-column">
                                    <div class="benchmark-token-stack" tabindex="0" data-tooltip="@tooltip" aria-label="@tooltip">
                                        <span class="benchmark-token-output" style="height:@outputHeight%"></span>
                                        <span class="benchmark-token-input" style="height:@inputHeight%"></span>
                                    </div>
                                    <span aria-hidden="true">@health.StartedAt.ToString("MM-dd")</span>
                                </div>
                            }
                        </div>
                    </section>

                    <section class="accounts-card accounts-table-card benchmark-health-table-card" aria-labelledby="health-table-title">
                        <div class="accounts-card-header">
                            <div>
                                <p class="accounts-eyebrow">Exact values</p>
                                <h2 id="health-table-title">Recent batch health</h2>
                                <p>Latest completed batches first.</p>
                            </div>
                        </div>
                        <div class="admin-table-wrap">
                            <table class="admin-table benchmark-health-table">
                                <thead>
                                    <tr>
                                        <th>Started</th>
                                        <th>Subject</th>
                                        <th class="is-numeric">Attempts</th>
                                        <th class="is-numeric">Success</th>
                                        <th class="is-numeric">Failures</th>
                                        <th class="is-numeric">p50</th>
                                        <th class="is-numeric">p95</th>
                                        <th class="is-numeric">Tokens</th>
                                        <th class="is-numeric">Avg. chunks</th>
                                        <th class="is-numeric">Duration</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var health in healthPoints.Reverse())
                                    {
                                        <tr>
                                            <td><strong>@health.StartedAt.ToString("yyyy-MM-dd")</strong><span>@health.StartedAt.ToString("HH:mm")</span></td>
                                            <td>@(health.SubjectCode ?? "All")</td>
                                            <td class="is-numeric">@health.AttemptCount.ToString("N0")</td>
                                            <td class="is-numeric">@health.SuccessRate.ToString("0.#", CultureInfo.InvariantCulture)%</td>
                                            <td class="is-numeric @((health.FailedPromptCount > 0 || health.FailedRunCount > 0) ? "is-alert" : string.Empty)">
                                                @health.FailedPromptCount prompt / @health.FailedRunCount run
                                            </td>
                                            <td class="is-numeric">@FormatMs(health.P50LatencyMs)</td>
                                            <td class="is-numeric">@FormatMs(health.P95LatencyMs)</td>
                                            <td class="is-numeric">@((health.PromptTokens + health.CompletionTokens).ToString("N0"))</td>
                                            <td class="is-numeric">@(health.AverageRetrievedChunks?.ToString("0.#", CultureInfo.InvariantCulture) ?? "—")</td>
                                            <td class="is-numeric">@FormatMs(health.DurationMs)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                }
            </div>
        </section>
    </main>

    <div id="chatviz-tooltip" class="chatviz-tooltip" role="tooltip"></div>

    <script>
        // Keeps the "this will send N paid requests" warning honest as models are ticked.
        (() => {
            const form = document.getElementById("benchmark-run-form");
            const hint = document.getElementById("benchmark-cost-hint");
            const counter = document.getElementById("benchmark-request-count");
            if (!form || !hint || !counter) {
                return;
            }

            const checkboxes = form.querySelectorAll('input[name="SelectedModels"]');

            // One prompt per run, so the request count is simply the models ticked.
            const update = () => {
                let selected = 0;
                checkboxes.forEach((box) => { if (box.checked) { selected += 1; } });
                counter.textContent = selected.toLocaleString();
            };

            checkboxes.forEach((box) => box.addEventListener("change", update));
            update();

            form.addEventListener("submit", (event) => {
                const total = Number(counter.textContent.replace(/[^0-9]/g, ""));
                if (total === 0) {
                    event.preventDefault();
                    window.alert("Select at least one model to benchmark.");
                    return;
                }
                if (!window.confirm(`This will send ${total} paid OpenRouter request(s). Continue?`)) {
                    event.preventDefault();
                    return;
                }

                // Runs are queued server-side; without this the button looks inert
                // for the whole round trip and invites a second submit.
                const button = document.getElementById("benchmark-run-button");
                if (button) {
                    button.disabled = true;
                    button.classList.add("is-busy");
                    button.firstChild.textContent = "Starting… ";
                }
            });
        })();
    </script>

    @if (Model.HasRunInFlight)
    {
        <script>
            // Runs execute in the background and record progress in the database, so the
            // page simply polls until every run reports finished, then reloads once.
            (() => {
                async function pollRuns() {
                    try {
                        const response = await fetch("/ChatBenchmark?handler=RunStatus", { credentials: "same-origin" });
                        if (!response.ok) {
                            throw new Error("status unavailable");
                        }

                        const runs = await response.json();
                        if (runs.every((run) => run.isFinished)) {
                            window.location.reload();
                            return;
                        }

                        document.querySelectorAll("#benchmark-runs-table tbody tr").forEach((row) => {
                            const label = row.querySelector("td:first-child strong");
                            if (!label) {
                                return;
                            }
                            const match = runs.find((run) => run.model === label.textContent.trim());
                            if (!match) {
                                return;
                            }
                            const progressCell = row.querySelector("td:nth-child(3)");
                            if (progressCell) {
                                progressCell.innerHTML =
                                    `<span class="benchmark-status benchmark-status-${match.status}">` +
                                    `<span class="benchmark-status-dot" aria-hidden="true"></span>${match.status}</span>` +
                                    `<span class="benchmark-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" ` +
                                    `aria-valuenow="${match.progressPercent}" ` +
                                    `aria-label="${match.completedCount} of ${match.promptCount} prompts completed">` +
                                    `<span class="benchmark-progress-fill" style="width:${match.progressPercent}%"></span></span>` +
                                    `<span class="benchmark-progress-label">${match.completedCount} / ${match.promptCount} prompts</span>`;
                            }
                        });

                        window.setTimeout(pollRuns, 2000);
                    } catch {
                        window.setTimeout(pollRuns, 4000);
                    }
                }

                pollRuns();
            })();
        </script>
    }

    <script>
        (() => {
            const tooltip = document.getElementById("chatviz-tooltip");
            if (!tooltip) {
                return;
            }

            const showTooltip = (bar, event) => {
                const text = bar.dataset.tooltip;
                if (!text) {
                    return;
                }
                tooltip.textContent = text;
                const point = event instanceof PointerEvent ? event : null;
                const rect = bar.getBoundingClientRect();
                const x = point ? point.clientX : rect.left + rect.width / 2;
                const y = point ? point.clientY : rect.top;
                tooltip.style.left = `${x}px`;
                tooltip.style.top = `${y}px`;
                tooltip.classList.add("is-visible");
            };

            const hideTooltip = () => {
                tooltip.classList.remove("is-visible");
            };

            document.querySelectorAll("[data-tooltip]").forEach((target) => {
                target.addEventListener("pointerenter", (event) => showTooltip(target, event));
                target.addEventListener("pointermove", (event) => showTooltip(target, event));
                target.addEventListener("pointerleave", hideTooltip);
                target.addEventListener("focus", (event) => showTooltip(target, event));
                target.addEventListener("blur", hideTooltip);
            });
        })();
    </script>
</body>
</html>

@functions {
    private static string Preview(string text)
    {
        var single = text.Replace('\n', ' ').Replace('\r', ' ').Trim();
        return single.Length <= 48 ? single : single[..48] + "…";
    }

    private static string FormatMs(double? milliseconds)
    {
        if (milliseconds is null) return "—";
        if (milliseconds < 1000) return $"{milliseconds.Value:0} ms";
        return $"{milliseconds.Value / 1000:0.##} s";
    }

    private static string FormatMs(int? milliseconds) => FormatMs(milliseconds.HasValue ? milliseconds.Value : (double?)null);

    private static string FormatMs(long? milliseconds) => FormatMs(milliseconds.HasValue ? milliseconds.Value : (double?)null);

    private static IReadOnlyList<ChartPoint> BuildChartPoints(IEnumerable<double?> values, double axisMax)
    {
        var source = values.ToArray();
        if (source.Length == 0)
        {
            return [];
        }

        return source.Select((value, index) =>
        {
            var x = source.Length == 1 ? 396d : 50d + index * 700d / (source.Length - 1);
            var normalized = axisMax <= 0 || !value.HasValue ? 0 : Math.Clamp(value.Value / axisMax, 0, 1);
            var y = 190d - normalized * 180d;
            return new ChartPoint(x, y, value.HasValue);
        }).ToArray();
    }

    private static string PointList(IEnumerable<ChartPoint> points) => string.Join(
        " ",
        points.Where(point => point.HasValue).Select(point =>
            $"{point.X.ToString("0.##", CultureInfo.InvariantCulture)},{point.Y.ToString("0.##", CultureInfo.InvariantCulture)}"));

    private static double NiceMax(double rawMax)
    {
        if (rawMax <= 0)
        {
            return 1;
        }

        var magnitude = Math.Pow(10, Math.Floor(Math.Log10(rawMax)));
        var normalized = rawMax / magnitude;
        var niceNormalized = normalized switch
        {
            <= 1 => 1,
            <= 2 => 2,
            <= 2.5 => 2.5,
            <= 5 => 5,
            _ => 10
        };
        return niceNormalized * magnitude;
    }

    private static string BarHeightPercent(double value, double axisMax)
    {
        if (axisMax <= 0)
        {
            return "0";
        }

        var percent = Math.Clamp(value / axisMax * 100, 0, 100);
        return percent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    }

    private sealed record ChartPoint(double X, double Y, bool HasValue);
}
