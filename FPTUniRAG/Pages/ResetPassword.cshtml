@page
@model FPTUniRAG.Pages.ResetPasswordModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Reset Password - FPT UniRAG";
}

<section class="auth-card ui-card" data-slot="card" aria-labelledby="reset-password-card-title">
    <h2 id="reset-password-card-title" class="visually-hidden">Set a new password</h2>

    <div class="ui-card-content" data-slot="card-content">
        @if (Model.IsTokenMissing)
        {
            <div class="auth-alert ui-alert" data-slot="alert" role="alert">
                <span class="material-symbols-outlined" aria-hidden="true">error</span>
                <span>This password reset link is invalid. Please request a new one.</span>
            </div>
        }
        else if (Model.ResetSucceeded)
        {
            <div class="auth-alert ui-alert" data-slot="alert" role="status">
                <span class="material-symbols-outlined" aria-hidden="true">check_circle</span>
                <span>@Model.SuccessMessage</span>
            </div>
        }
        else
        {
            <p style="margin: 0 0 16px; color: #54647a; font-size: 14px; line-height: 1.6;">
                Choose a new password with at least 8 characters.
            </p>

            <form method="post" class="auth-form ui-form" data-slot="form" novalidate>
                <input type="hidden" asp-for="Token" />

                <div asp-validation-summary="ModelOnly" class="auth-validation-summary" role="alert"></div>

                <div class="auth-field-group ui-field-group" data-slot="field-group">
                    <div class="auth-field ui-field" data-slot="field">
                        <label asp-for="Input.NewPassword" class="ui-label" data-slot="field-label">New Password</label>
                        <div class="auth-input-group ui-input-group" data-slot="input-group">
                            <span class="auth-input-leading-icon material-symbols-outlined" aria-hidden="true">lock</span>
                            <input asp-for="Input.NewPassword" class="ui-input" data-slot="input" type="password" autocomplete="new-password" placeholder="Enter a new password" />
                        </div>
                        <span asp-validation-for="Input.NewPassword" class="auth-field-message"></span>
                    </div>

                    <div class="auth-field ui-field" data-slot="field">
                        <label asp-for="Input.ConfirmPassword" class="ui-label" data-slot="field-label">Confirm New Password</label>
                        <div class="auth-input-group ui-input-group" data-slot="input-group">
                            <span class="auth-input-leading-icon material-symbols-outlined" aria-hidden="true">lock</span>
                            <input asp-for="Input.ConfirmPassword" class="ui-input" data-slot="input" type="password" autocomplete="new-password" placeholder="Re-enter the new password" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="auth-field-message"></span>
                    </div>
                </div>

                <button type="submit" class="ui-button ui-button-primary" data-slot="button">
                    <span>Reset Password</span>
                    <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                </button>
            </form>
        }

        <p style="margin: 20px 0 0; text-align: center; font-size: 14px;">
            <a href="/Login" style="color: #005bbf; font-weight: 700; text-decoration: none;">Back to sign in</a>
        </p>
    </div>
</section>
