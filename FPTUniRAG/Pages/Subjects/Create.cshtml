@page
@model FPTUniRAG.Pages.Subjects.CreateModel
@{
    Layout = null;
    ViewData["Title"] = "Create Subject - FPT UniRAG";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-dashboard-page subject-create-page">
    <main class="admin-shell" aria-label="Create subject">
        <aside class="admin-sidebar" aria-label="Admin navigation">
            <a class="admin-logo" href="/AdminDashboard" aria-label="FPT UniRAG dashboard">
                <span class="admin-logo-mark" aria-hidden="true">
                    <span class="material-symbols-outlined">school</span>
                </span>
                <span>
                    <strong>FPT UniRAG</strong>
                    <small>Academic RAG</small>
                </span>
            </a>

            <nav class="admin-nav">
                <a class="admin-nav-item" href="/AdminDashboard">
                    <span class="material-symbols-outlined" aria-hidden="true">dashboard</span>
                    Dashboard
                </a>
                <details class="admin-nav-group" open>
                    <summary class="admin-nav-item active">
                        <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                        Subjects
                        <span class="material-symbols-outlined admin-nav-chevron" aria-hidden="true">expand_more</span>
                    </summary>
                    <div class="admin-subnav">
                        <a href="/Subjects">Manage Subjects</a>
                        <a href="/Subjects/AssignTeacher">Assign Teacher</a>
                        <a href="/Subjects/AssignHeader">Assign Header</a>
                    </div>
                </details>
                <a class="admin-nav-item" href="/Accounts">
                    <span class="material-symbols-outlined" aria-hidden="true">groups</span>
                    Accounts
                </a>
                <a class="admin-nav-item" href="/Analysis">
                    <span class="material-symbols-outlined" aria-hidden="true">analytics</span>
                    Analytics
                </a>
            </nav>

            <section class="admin-sidebar-footer" aria-label="Sidebar actions">
                <a class="admin-sidebar-footer-link" href="#">
                    <span class="material-symbols-outlined" aria-hidden="true">help_outline</span>
                    <span>Help</span>
                </a>
                <a class="admin-sidebar-footer-link" href="/Login?logout=true">
                    <span class="material-symbols-outlined" aria-hidden="true">logout</span>
                    <span>Logout</span>
                </a>
            </section>
        </aside>

        <section class="subject-create-main">
            <div class="subject-create-canvas">
                <nav class="subject-breadcrumbs" aria-label="Breadcrumb">
                    <a href="/AdminDashboard">Dashboard</a>
                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                    <a href="/Subjects">Subjects</a>
                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                    <strong>Create Subject</strong>
                </nav>

                <header class="subject-create-header">
                    <div>
                        <h1>Create Subject</h1>
                        <p>Add a subject and choose the default chunking strategy for documents in that subject.</p>
                    </div>
                    <a class="subject-close-button" href="/Subjects" aria-label="Close create subject screen">
                        <span class="material-symbols-outlined" aria-hidden="true">close</span>
                    </a>
                </header>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="accounts-feedback accounts-feedback-error" role="alert">
                        @Model.ErrorMessage
                    </div>
                }

                <section class="subject-form-card" aria-labelledby="create-subject-title">
                    <div class="subject-form-content">
                        <h2 id="create-subject-title" class="visually-hidden">Create subject form</h2>
                        <form class="subject-form" method="post">
                            <div class="subject-form-grid">
                                <label class="subject-field">
                                    <span>Subject Code</span>
                                    <div class="subject-input-with-icon">
                                        <span class="material-symbols-outlined" aria-hidden="true">tag</span>
                                        <input asp-for="Input.SubjectCode" type="text" placeholder="e.g. PRN222" autocomplete="off" />
                                    </div>
                                    <small>Unique code stored in the `subjects.subject_code` column.</small>
                                    <span asp-validation-for="Input.SubjectCode" class="accounts-field-error"></span>
                                </label>

                                <label class="subject-field">
                                    <span>Subject Name</span>
                                    <input asp-for="Input.SubjectName" type="text" placeholder="e.g. .NET Web Development" autocomplete="off" />
                                    <small>Stored in the `subjects.subject_name` column.</small>
                                    <span asp-validation-for="Input.SubjectName" class="accounts-field-error"></span>
                                </label>
                            </div>

                            <label class="subject-field">
                                <span>Description</span>
                                <textarea asp-for="Input.Description" placeholder="Optional subject overview..."></textarea>
                                <small>Optional text stored in the `subjects.description` column.</small>
                                <span asp-validation-for="Input.Description" class="accounts-field-error"></span>
                            </label>

                            <label class="subject-field">
                                <span>Default Chunking Strategy</span>
                                <select asp-for="Input.DefaultChunkingStrategy">
                                    <option value="fixed">Fixed size</option>
                                    <option value="semantic">Semantic chunking</option>
                                </select>
                                <small>Stored in the `subjects.default_chunking_strategy` column and used for new document uploads.</small>
                                <span asp-validation-for="Input.DefaultChunkingStrategy" class="accounts-field-error"></span>
                            </label>

                            <label class="subject-field" id="fixed-chunk-size-field">
                                <span>Fixed Chunk Size</span>
                                <input asp-for="Input.DefaultFixedChunkSize" type="number" min="1" step="1" />
                                <small>Stored in the `subjects.default_fixed_chunk_size` column and used only when the subject uses fixed-size chunking.</small>
                                <span asp-validation-for="Input.DefaultFixedChunkSize" class="accounts-field-error"></span>
                            </label>

                            <footer class="subject-form-actions">
                                <a class="subject-cancel-button" href="/Subjects">Cancel</a>
                                <button class="subject-submit-button" type="submit">
                                    Create Subject
                                    <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                                </button>
                            </footer>
                        </form>
                    </div>
                </section>
            </div>
        </section>
    </main>

    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const strategySelect = document.getElementById("Input_DefaultChunkingStrategy");
            const fixedChunkSizeField = document.getElementById("fixed-chunk-size-field");

            if (!strategySelect || !fixedChunkSizeField) {
                return;
            }

            const syncFixedChunkSizeVisibility = () => {
                fixedChunkSizeField.hidden = strategySelect.value === "semantic";
            };

            strategySelect.addEventListener("change", syncFixedChunkSizeVisibility);
            syncFixedChunkSizeVisibility();
        })();
    </script>
</body>
</html>
